    description: "和后备宝可梦进行替换。换上的宝可梦能直接继承其能力的变化。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "自身替换宝可梦下场，训练家选择队伍中另外一只宝可梦上场。能力变化、以及部分的状态变化会传递给交换上场的宝可梦。\n该招式无视踩影、沙穴、磁力或是扎根、无法逃走、束缚状态的影响，可以进行交换。\n轻装特性发动中的速度加倍状态不会被该招式传递。\n以该招式的使用者为目标的追打不会发动特效。\n能力变化不论正负均可被传递。\n在对战竞技场使用，或者在没有其它能上场的宝可梦时使用会失败。\n如果交换上场的宝可梦能够使用接棒，并且在此时受到再来一次的招式影响，则将只能使用接棒。",
    range: "自身"
  },
  "beak-blast": {
    description: "先加热鸟嘴后再进行攻击。鸟嘴在加热时对手触碰的话，就会使其灼伤。"
  },
  "beat-up": {
    intro: "围攻（日文︰ふくろだたき，英文︰Beat Up）是第二世代引入的恶属性招式。",
    description: "我方全员进行攻击。同行的宝可梦越多，招式的攻击次数越多。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，没有异常状态或昏厥的全部同行宝可梦都会攻击对手。招式的威力会根据同行宝可梦的攻击种族值变化。\n每一击的威力=使用方的一只同行宝可梦的攻击种族值⁄10 + 5。\n使用方的每一只同行宝可梦都会参与计算1次攻击的威力。\n每一击击中要害的概率都相等。\n如果某一下触发了目标的气势披带、气势头带、结实特性或打破了替身，招式会继续攻击。\n忍耐、金属爆炸和双倍奉还只计算最后一次的伤害。\n如果使用者持有王者之证或锐利之牙，或具有恶臭特性，每一下攻击都有相同的概率造成对手畏缩。\n如果目标拥有咒术之躯、碎裂铠甲特性，每一下攻击都会触发效果。即使特性发动令攻击方陷入一些可能无法行动的状态（如麻痹、畏缩、着迷、定身法状态），也不会影响本次攻击，但陷入睡眠和昏厥时攻击即刻停止。\n目标的变色特性在最后一下攻击完成后才发动。\n狙击手特性无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "belch": {
    description: "朝着对手打嗝，并给予伤害。如果不吃树果则无法使出。"
  },
  "belly-drum": {
    intro: "腹鼓（日文︰はらだいこ，英文︰Belly Drum）是第二世代引入的一般属性招式。",
    description: "将自己的HP减少到最大HP的一半，从而最大限度提高自己的攻击。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "使用者损失最大HP的1⁄2（向下取整）。\n令使用者的攻击提升至最大（+6）。\n如果使用者自身HP不足1⁄2，招式使用失败，除非使用Ｚ腹鼓。",
    range: "自身"
  },
  "bestow": {
    description: "当对手未携带道具时，能够将自己携带的道具交给对手。"
  },
  "bide": {
    intro: "这篇文章讲述的是第一世代引入的一般属性招式。如果您在寻找第二世代引入的一般属性招式，请移步挺住（招式）。\n克制重定向至此。如果您在寻找“效果拔群”等属性相性，请移步属性适性加成。",
    description: "在2回合内忍受攻击，受到的伤害会2倍返还给对手。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "主页面：忍耐（状态）\n进入忍耐状态，2回合内无法使用其它招式、使用道具、交换宝可梦、逃跑。\n第三回合，以处于忍耐状态期间上次使用攻击招式对使用者造成伤害的对手所在场地的宝可梦为目标，对目标造成处于忍耐状态期间受到攻击招式的总伤害×2的伤害。该招式无法对没有效果的属性的宝可梦造成伤害，但忽略其它属性相克和属性一致加成。\n忍耐一定会命中，除非目标正在使用蓄力的招式并不在场地上。\n该招式不能被梦话发动。",
    range: "自身"
  },
  "bind": {
    intro: "绑紧（日文︰しめつける，英文︰Bind）是第一世代引入的一般属性招式。",
    description: "使用长长的身体或藤蔓等，在4～5回合内绑紧对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "主页面：束缚（状态）\n攻击目标造成伤害。使目标陷入束缚状态。束缚状态持续4～5回合，处于束缚状态的宝可梦会持续受到伤害并不能换下。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "bite": {
    intro: "咬住（日文︰かみつく，英文︰Bite）是第一世代引入的恶属性招式。",
    description: "用尖锐的牙咬住对手进行攻击。有时会使对手畏缩。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n咬住有30%的几率使尚未行动的目标陷入畏缩状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "bitter-blade": {
    description: "将对世间的留恋聚集于剑尖，并斩击对手。可以回复给予对手伤害的一半HP。"
  },
  "blast-burn": {
    intro: "爆炸烈焰（日文︰ブラストバーン，英文︰Blast Burn）是第三世代引入的火属性招式。",
    description: "用爆炸的火焰烧尽对手进行攻击。下一回合自己将无法动弹。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n下一回合无法使用招式、使用道具、逃走或替换宝可梦。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "blaze-kick": {
    intro: "火焰踢（日文︰ブレイズキック，英文︰Blaze Kick）是第三世代引入的火属性招式。",
    description: "攻击对手后，有时会使其陷入灼伤状态。也容易击中要害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。击中要害率比大部分招式高1级。\n火焰踢有10%的几率使目标陷入灼伤状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "bleakwind-storm": {
    description: "用足以让身心都止不住颤抖的冰冷狂风进行攻击。有时会降低对手的速度。"
  },
  "blizzard": {
    intro: "暴风雪（日文︰ふぶき，英文︰Blizzard）是第一世代引入的冰属性招式。",
    description: "将猛烈的暴风雪刮向对手进行攻击。有时会让对手陷入冰冻状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n暴风雪有10%的几率使目标陷入冰冻状态。\n在冰雹或下雪天气下，暴风雪一定会命中，除非目标正在使用蓄力的招式并不在场地上。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "block": {
    intro: "挡路（日文︰とおせんぼう，英文︰Block）是第三世代引入的一般属性招式。",
    description: "张开双手进行阻挡，封住对手的退路，使其不能逃走。",
    effect: ["不是接触类招式", "不受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：无法逃走（状态）\n使目标陷入无法逃走状态。处于无法逃走状态的宝可梦不能换下。\n当使用挡路的宝可梦替换下场时，无法逃走状态消失。\n挡路一定会命中，除非目标正在使用蓄力的招式并不在场地上。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "blue-flare": {
    description: "用美丽而激烈的青焰包裹住对手进行攻击。有时会让对手陷入灼伤状态。"
  },
  "body-press": {
    description: "用身体撞向对手进行攻击。防御越高，给予的伤害就越高。"
  },
  "body-slam": {
    intro: "泰山压顶（日文︰のしかかり，英文︰Body Slam）是第一世代引入的一般属性招式。",
    description: "用整个身体压住对手进行攻击。有时会让对手陷入麻痹状态。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。泰山压顶有30%的几率使目标陷入麻痹状态。\n如果目标处于变小状态，威力翻倍。同时在这种状况下，泰山压顶一定会命中，除非目标正在使用蓄力的招式并不在场地上。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "bolt-beak": {
    description: "用带电的喙啄刺对手。如果比对手先出手攻击，招式的威力会变成2倍。"
  },
  "bolt-strike": {
    description: "让强大的电流覆盖全身，猛撞向对手进行攻击。有时会让对手陷入麻痹状态。"
  },
  "bone-club": {
    intro: "这篇文章讲述的是一种招式。如果您在寻找一种道具，请移步粗骨头（道具）。",
    description: "用手中的骨头殴打对手进行攻击。有时会使对手畏缩。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n骨棒有10%的几率使尚未行动的目标陷入畏缩状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "bone-rush": {
    intro: "骨棒乱打（日文︰ボーンラッシュ，英文︰Bone Rush）是第二世代引入的地面属性招式。",
    description: "用坚硬的骨头殴打对手进行攻击。连续攻击2～5次。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "用坚硬的骨头殴打对手进行攻击。连续攻击2～5次。\n攻击目标造成伤害，一回合内连续攻击2～5次。命中时，各有15%的几率攻击5或4次，35%的几率攻击3或2次，攻击次数的数学期望是3.1次，对应的威力的数学期望是77.5。\n携带机变骰子且命中时，各有1⁄2的几率攻击5或4次，攻击次数的数学期望是4.5次，对应的威力的数学期望是112.5。\n每一击击中要害的概率都相等。\n如果某一下触发了目标的气势披带、气势头带、结实特性或打破了替身，招式会继续攻击。\n忍耐、金属爆炸和双倍奉还只计算最后一次的伤害。\n如果使用者持有王者之证或锐利之牙，或具有恶臭特性，每一下攻击都有相同的概率造成对手畏缩。\n如果目标拥有咒术之躯、碎裂铠甲特性，每一下攻击都会触发效果。即使特性发动令攻击方陷入一些可能无法行动的状态（如麻痹、畏缩、着迷、定身法状态），也不会影响本次攻击，但陷入睡眠和昏厥时攻击即刻停止。\n目标的变色特性在最后一下攻击完成后才发动。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "bonemerang": {
    intro: "骨头回力镖（日文︰ホネブーメラン，英文︰Bonemerang）是第一世代引入的地面属性招式。",
    description: "用手中的骨头投掷对手，来回连续2次给予伤害。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，一回合内连续攻击2次。\n每一击击中要害的概率都相等。\n如果第一下触发了目标的气势披带、气势头带、结实特性或打破了替身，招式会继续攻击。\n忍耐、金属爆炸和双倍奉还只计算最后一次的伤害。\n如果使用者持有王者之证或锐利之牙，或具有恶臭特性，每一下攻击都有相同的概率造成对手畏缩。\n如果目标拥有咒术之躯、碎裂铠甲特性，每一下攻击都会触发效果。即使特性发动令攻击方陷入一些可能无法行动的状态（如麻痹、畏缩、着迷、定身法状态），也不会影响本次攻击，但陷入睡眠和昏厥时攻击即刻停止。\n目标的变色特性在最后一下攻击完成后才发动。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "boomburst": {
    description: "通过震耳欲聋的爆炸声产生的破坏力，攻击自己周围所有的宝可梦。"
  },
  "bounce": {
    intro: "这篇文章讲述的是第三世代登场的飞行属性招式。如果您在寻找第一世代一般属性招式，请移步跃起（招式）。",
    description: "弹跳到高高的空中，第2回合攻击对手。有时会让对手陷入麻痹状态。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响", "是远程招式"],
    additionalEffect: "主页面：飞翔（状态）\n使用弹跳的宝可梦在第一回合飞上天空进行蓄力。进行蓄力时的提示为：“[宝可梦的名字]高高地跳了起来！”。进行蓄力时不能下达指令。\n在第二回合发动招式。弹跳有30%的几率使目标陷入麻痹状态。\n存在重力的情况下不能使用该招式。\n蓄力的回合会进行行动判定，成功进行蓄力则消耗PP。\n攻击的回合也会进行行动判定，出现不能行动的情况则招式失败。\n在蓄力的回合，消耗携带的强力香草，可以立刻结束蓄力，在当回合发动招式。\n对使用弹跳的宝可梦（无论当回合是在进行蓄力或进行攻击）使用突袭可以成功，但是否命中需要另外计算，进行攻击的那回合使用突袭必定未命中。",
    range: "除自身以外场上一只宝可梦"
  },
  "branch-poke": {
    description: "使用尖锐的树枝刺向对手进行攻击。"
  },
  "brave-bird": {
    description: "收拢翅膀，通过低空飞行突击对手。自己也会受到不小的伤害。"
  },
  "breaking-swipe": {
    description: "用坚韧的尾巴猛扫对手进行攻击，从而降低对手的攻击。"
  },
  "brick-break": {
    intro: "劈瓦（日文︰かわらわり，英文︰Brick Break）是第三世代引入的格斗属性招式。",
    description: "将手刀猛烈地挥下攻击对手。还可以破坏光墙和反射壁等。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "破坏对方场地的光墙、反射壁和极光幕，并攻击目标造成伤害。\n不受反射壁和极光幕的伤害降低影响。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "brine": {
    description: "当对手的HP负伤到一半左右时，招式威力会变成2倍。"
  },
  "brutal-swing": {
    description: "用自己的身体狂舞挥打，给予对手伤害。"
  },
  "bubble": {
    intro: "泡沫（日文︰あわ，英文︰Bubble）是第一世代引入的水属性招式。",
    description: "向对手用力吹起无数泡泡进行攻击。有时会降低对手的速度。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n10%几率令目标的速度降低1级。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "bubble-beam": {
    intro: "泡沫光线（日文︰バブルこうせん，英文︰Bubble Beam）是第一世代引入的水属性招式。",
    description: "向对手猛烈地喷射泡沫进行攻击。有时会降低对手的速度。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n10%几率令目标的速度降低1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "bug-bite": {
    description: "咬住进行攻击。当对手携带树果时，可以食用并获得其效果。"
  },
  "bug-buzz": {
    description: "利用振动发出音波进行攻击。有时会降低对手的特防。"
  },
  "bulk-up": {
    intro: "健美（日文︰ビルドアップ，英文︰Bulk Up）是第三世代引入的格斗属性招式。",
    description: "使出全身力气绷紧肌肉，从而提高自己的攻击和防御。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令使用者的攻击提升1级。\n令使用者的防御提升1级。",
    range: "自身"
  },
  "bulldoze": {
    description: "用力踩踏地面并攻击自己周围所有的宝可梦。会降低对方的速度。"
  },
  "bullet-punch": {
    description: "向对手使出如子弹般快速而坚硬的拳头。必定能够先制攻击。"
  },
  "bullet-seed": {
    intro: "种子机关枪（日文︰タネマシンガン，英文︰Bullet Seed）是第三世代引入的草属性招式。",
    description: "向对手猛烈地发射种子进行攻击。连续攻击2～5次。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，一回合内连续攻击2～5次。命中时，各有15%的几率攻击5或4次，35%的几率攻击3或2次，攻击次数的数学期望是3.1次，对应的威力的数学期望是77.5。\n携带机变骰子且命中时，各有1⁄2的几率攻击5或4次，攻击次数的数学期望是4.5次，对应的威力的数学期望是112.5。\n每一击击中要害的概率都相等。\n如果某一下触发了目标的气势披带、气势头带、结实特性或打破了替身，招式会继续攻击。\n忍耐、金属爆炸和双倍奉还只计算最后一次的伤害。\n如果使用者持有王者之证或锐利之牙，或具有恶臭特性，每一下攻击都有相同的概率造成对手畏缩。\n如果目标拥有咒术之躯、碎裂铠甲特性，每一下攻击都会触发效果。即使特性发动令攻击方陷入一些可能无法行动的状态（如麻痹、畏缩、着迷、定身法状态），也不会影响本次攻击，但陷入睡眠和昏厥时攻击即刻停止。\n目标的变色特性在最后一下攻击完成后才发动。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "burn-up": {
    description: "将自己全身燃烧起火焰来，给予对手大大的伤害。自己的火属性将会消失。"
  },
  "burning-bulwark": {
    description: "用超高温的体毛防住对手攻击的同时，让接触到自己的对手灼伤。"
  },
  "burning-jealousy": {
    description: "用嫉妒的能量攻击对手。会让在该回合内能力有所提高的宝可梦陷入灼伤状态。"
  },
  "calm-mind": {
    intro: "冥想（日文︰めいそう，英文︰Calm Mind）是第三世代引入的超能力属性招式。",
    description: "静心凝神，从而提高自己的特攻和特防。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令使用者的特攻提升1级。\n令使用者的特防提升1级。",
    range: "自身"
  },
  "camouflage": {
    intro: "保护色（日文︰ほごしょく，英文︰Camouflage）是第三世代引入的一般属性招式。",
    description: "根据所在场所不同，如水边、草丛和洞窟等，可以改变自己的属性。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：战斗场所\n根据场所改变自身的属性。\n当场上有场地型状态时，场地型状态的效果覆盖地形的效果，对应的属性列表如下：",
    range: "自身"
  },
  "captivate": {
    description: "♂诱惑♀或♀诱惑♂，从而大幅降低对手的特攻。"
  },
  "charge": {
    intro: "充电（日文︰じゅうでん，英文︰Charge）是第三世代引入的电属性招式。",
    description: "变为充电状态，提高下次使出的电属性的招式威力。自己的特防也会提高。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：充电（状态）\n使自身进入充电状态。处于充电状态的宝可梦使用的电属性招式的威力加倍。充电状态在下次使用电属性招式后结束。\n除此以外，同时还令使用者的特防提升1级。",
    range: "自身"
  },
  "charge-beam": {
    description: "向对手发射电击光束。由于蓄满电流，有时会提高自己的特攻。"
  },
  "charm": {
    intro: "撒娇（日文︰あまえる，英文︰Charm）是第二世代引入的妖精属性招式。",
    description: "可爱地凝视，诱使对手疏忽大意，从而大幅降低对手的攻击。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令目标的攻击降低2级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "chatter": {
    description: "用非常烦人的，喋喋不休的音波攻击对手。使对手混乱。"
  },
  "chilling-water": {
    description: "泼洒冰冷得足以让对手失去活力的水进行攻击。会降低对手的攻击。"
  },
  "chilly-reception": {
    description: "留下冷场的冷笑话后，和后备宝可梦进行替换。在5回合内会下雪。"
  },
  "chip-away": {
    description: "看准机会稳步攻击。无视对手的能力变化，直接给予伤害。"
  },
  "circle-throw": {
    description: "扔飞对手，强制拉后备宝可梦上场。如果对手为野生宝可梦，战斗将直接结束。"
  },
  "clamp": {
    intro: "贝壳夹击（日文︰からではさむ，英文︰Clamp）是第一世代引入的水属性招式。",
    description: "用非常坚固且厚实的贝壳，在4～5回合内夹住对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "主页面：束缚（状态）\n攻击目标造成伤害。使目标陷入束缚状态。束缚状态持续4～5回合，处于束缚状态的宝可梦会持续受到伤害并不能换下。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "clanging-scales": {
    description: "摩擦全身鳞片，发出响亮的声音进行攻击。攻击后自己的防御会降低。"
  },
  "clangorous-soul": {
    description: "削减少许自己的HP，使所有能力都提高。"
  },
  "clear-smog": {
    description: "向对手投掷特殊的泥块进行攻击。使其能力变回原点。"
  },
  "close-combat": {
    description: "放弃守护，向对手的怀里突击。自己的防御和特防会降低。"
  },
  "coaching": {
    description: "通过进行正确合理的指导，提高我方全员的攻击和防御。"
  },
  "coil": {
    description: "盘蜷着集中精神。提高自己的攻击、防御和命中率。"
  },
  "collision-course": {
    description: "边变形边凶暴地落下，并引发起古老的大爆炸。若针对到弱点，威力会进一步。"
  },
  "comet-punch": {
    intro: "连续拳（日文︰れんぞくパンチ，英文︰Comet Punch）是第一世代引入的一般属性招式。",
    description: "用拳头怒涛般的殴打对手进行攻击。连续攻击2～5次。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，一回合内连续攻击2～5次。命中时，各有15%的几率攻击5或4次，35%的几率攻击3或2次，攻击次数的数学期望是3.1次，对应的威力的数学期望是55.8。\n携带机变骰子且命中时，各有1⁄2的几率攻击5或4次，攻击次数的数学期望是4.5次，对应的威力的数学期望是81。\n每一击击中要害的概率都相等。\n如果某一下触发了目标的气势披带、气势头带、结实特性或打破了替身，招式会继续攻击。\n忍耐、金属爆炸和双倍奉还只计算最后一次的伤害。\n如果使用者持有王者之证或锐利之牙，或具有恶臭特性，每一下攻击都有相同的概率造成对手畏缩。如果使用者具有毒手特性，每一下攻击都有相同的概率造成对手中毒。\n如果目标拥有咒术之躯、碎裂铠甲或与接触类招式相关的特性或持有凸凸头盔，每一下攻击都会触发效果。即使特性发动令攻击方陷入一些可能无法行动的状态（如麻痹、畏缩、着迷、定身法状态），也不会影响本次攻击，但陷入睡眠和昏厥时攻击即刻停止。\n目标的木乃伊、游魂或甩不掉的气味特性会在第一下攻击之后就发动。使用方的顺手牵羊特性或目标的变色特性在最后一下攻击完成后才发动。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "comeuppance": {
    description: "使出招式前，将最后受到的招式的伤害大力返还给对手。"
  },
  "confide": {
    description: "和对手进行密语，使其失去集中力，从而降低对手的特攻。"
  },
  "confuse-ray": {
    intro: "奇异之光（日文︰あやしいひかり，英文︰Confuse Ray）是第一世代引入的幽灵属性招式。",
    description: "显示奇怪的光，扰乱对手。使对手混乱。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "奇异之光会使目标陷入混乱状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "confusion": {
    intro: "念力（日文︰ねんりき，英文︰Confusion）是第一世代引入的超能力属性招式。",
    description: "向对手发送微弱的念力进行攻击。有时会使对手混乱。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n念力有10%的几率使目标陷入混乱状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "constrict": {
    intro: "缠绕（日文︰からみつく，英文︰Constrict）是第一世代引入的一般属性招式。",
    description: "用触手或青藤等缠绕进行攻击。有时会降低对手的速度。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n10%几率令目标的速度降低1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "conversion": {
    intro: "纹理（日文︰テクスチャー，英文︰Conversion）是第一世代引入的一般属性招式。",
    description: "将自己的属性转换成和已学会的招式中第一个招式相同的属性。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "改变自身属性为自己学会的第一个招式的属性，不会改变为???属性。",
    range: "自身"
  },
  "conversion-2": {
    intro: "纹理2（日文︰テクスチャー2，英文︰Conversion 2）是第二世代引入的一般属性招式。",
    description: "为了可以抵抗对手最后使用的招式，从而使自己的属性发生变化。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "自身的属性改变为目标上次使用招式的属性对自身效果不理想或没有效果的属性。属性随机选择，并且不为自身当前属性。如果没有合适的新属性，招式使用失败。\n若目标上次行动使用招式的属性为星晶属性，招式使用失败。\n无视目标在使用招式之后的属性及特性变化，例如目标在使用招式时拥有一般皮肤特性，则纹理2按一般属性计算，即使在目标使用招式后被消除了一般皮肤特性。\n自然之恩、觉醒力量、秘密之力、觉醒之舞按伤害属性计算，自然之恩若使用失败按一般属性招式计算。\n复制类招式按最终使出的招式属性计算。[待确认]\n纹理2一定会命中，除非目标正在使用蓄力的招式并不在场地上。\n该招式不受替身、守住影响，但受戏法防守影响。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "copycat": {
    description: "模仿对手刚才使出的招式，并使出相同招式。如果对手还没出招则会失败。"
  },
  "core-enforcer": {
    description: "如果给予过伤害的对手已经结束行动，其特性就会被消除。"
  },
  "corrosive-gas": {
    description: "用具有强酸性的气体包裹住自己周围所有的宝可梦，并融化其所携带的道具。"
  },
  "cosmic-power": {
    intro: "这篇文章讲述的是一种超能力属性招式，不是∞能量。",
    description: "汲取宇宙中神秘的力量，从而提高自己的防御和特防。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令使用者的防御提升1级。\n令使用者的特防提升1级。",
    range: "自身"
  },
  "cotton-guard": {
    description: "用软绵绵的绒毛包裹住自己的身体进行守护。巨幅提高自己的防御。"
  },
  "cotton-spore": {
    intro: "棉孢子（日文︰わたほうし，英文︰Cotton Spore）是第二世代引入的草属性招式。",
    description: "将棉花般柔软的孢子紧贴对手，从而大幅降低对手的速度。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令目标的速度降低2级。\n对草属性、防尘特性、携带防尘护目镜的宝可梦无效。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "counter": {
    intro: "双倍奉还（日文︰カウンター，英文︰Counter）是第一世代引入的格斗属性招式。",
    description: "从对手那里受到物理攻击的伤害将以2倍返还给同一个对手。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "对最后使用物理招式造成自身伤害的对应位置宝可梦为目标，造成受到的招式×2倍固定伤害。该招式无法对没有效果的属性的宝可梦造成伤害，但忽略其它属性相克和属性一致加成。\n对于多次攻击类招式，仅使用最后一击的伤害计算双倍奉还的伤害。\n双倍奉还的攻击目标会受万众瞩目状态的影响。\n在三打对战中，双倍奉还可以攻击到对侧的宝可梦，但它不算是远程招式，因为在使用招式时只能选择自己作为目标。\n当回合所有对手都没有使用过物理招式攻击到使用者时，招式使用失败。\n该招式不会被借助或挥指发动。",
    range: "取决于招式的具体效果"
  },
  "court-change": {
    description: "用神奇的力量交换双方的场地效果。"
  },
  "covet": {
    intro: "渴望（日文︰ほしがる，英文︰Covet）是第三世代引入的一般属性招式。",
    description: "一边可爱地撒娇，一边靠近对手进行攻击，还能夺取对手携带的道具。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "主页面：拍落（状态）\n攻击目标造成伤害。\n如果攻击方没有或失去携带物品，则会在本次战斗中获得目标的携带物品。\n不能偷取Ｚ纯晶。涉及到形态变化的道具（例如超级石）通常也不能偷取。\n如果攻击方因为防御方的铁刺特性、粗糙皮肤特性或凸凸头盔而陷入昏厥状态，则该特效不会发动。\n如果防御方具有黏着特性或替身状态，则该特效不会发动。\n如果偷取到对方的生命宝珠，则该次攻击不会产生伤害加成，但攻击结束后自身会损失HP。\n除非是在野生对战中，否则偷取的物品在战斗结束后还原。\n野生宝可梦使用该招式只能造成伤害，不能偷取物品。\n在野生对战中，从野生宝可梦取得的道具会永久取得。\n这个招式不能被借助和挥指抽到。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "crabhammer": {
    intro: "蟹钳锤（日文︰クラブハンマー，英文︰Crabhammer）是第一世代引入的水属性招式。",
    description: "用大钳子敲打对手进行攻击。容易击中要害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。击中要害率比大部分招式高1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "crafty-shield": {
    description: "使用神奇的力量防住攻击我方的变化招式。但无法防住伤害招式的攻击。"
  },
  "cross-chop": {
    intro: "十字劈（日文︰クロスチョップ，英文︰Cross Chop）是第二世代引入的格斗属性招式。",
    description: "用两手呈十字劈打对手进行攻击。容易击中要害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。击中要害率比大部分招式高1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "cross-poison": {
    description: "用毒刃劈开对手。有时会让对手陷入中毒状态，也容易击中要害。"
  },
  "crunch": {
    intro: "咬碎（日文︰かみくだく，英文︰Crunch）是第二世代引入的恶属性招式。",
    description: "用利牙咬碎对手进行攻击。有时会降低对手的防御。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n20%几率令目标的防御降低1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "crush-claw": {
    intro: "撕裂爪（日文︰ブレイククロー，英文︰Crush Claw）是第三世代引入的一般属性招式。",
    description: "用坚硬的锐爪劈开对手进行攻击。有时会降低对手的防御。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n50%几率令目标的防御降低1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "crush-grip": {
    description: "用骇人的力量捏碎对手。对手剩余的HP越多，威力越大。"
  },
  "curse": {
    intro: "咒术（日文︰のろい，英文︰Curse）是第二世代引入的幽灵属性招式。",
    description: "使用该招式的宝可梦，其属性是幽灵属性或其他属性时，效果会不一样。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "如果使用该招式宝可梦在该回合时，使用招式前改变了属性（包括太晶化），该招式的效果以当前属性为根据。",
    range: "取决于招式的具体效果"
  },
  "cut": {
    intro: "这篇文章讲述的是一种招式。如果您在寻找第一世代的游戏漏洞，请移步居合劈（漏洞）。",
    description: "用镰刀或爪子等切斩对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响", "可以在对战外使用"],
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "dark-pulse": {
    description: "从体内发出充满恶意的恐怖气场。有时会使对手畏缩。"
  },
  "dark-void": {
    description: "将对手强制拖入黑暗的世界，从而让对手陷入睡眠状态。"
  },
  "darkest-lariat": {
    description: "旋转双臂打向对手。无视对手的能力变化，直接给予伤害。"
  },
  "dazzling-gleam": {
    description: "向对手发射强光，并给予伤害。"
  },
  "decorate": {
    description: "通过装饰，大幅提高对方的攻击和特攻。"
  },
  "defend-order": {
    description: "召唤手下，让其附在自己的身体上。可以提高自己的防御和特防。"
  },
  "defense-curl": {
    intro: "变圆（日文︰まるくなる，英文︰Defense Curl）是第一世代引入的一般属性招式。",
    description: "将身体蜷曲变圆，从而提高自己的防御。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令使用者的防御提升1级。\n进入变圆状态，使用冰球和滚动进行攻击的威力将加倍。",
    range: "自身"
  },
  "defog": {
    description: "用强风吹开对手的反射壁或光墙等。也会降低对手的闪避率。"
  },
  "destiny-bond": {
    intro: "同命（日文︰みちづれ，英文︰Destiny Bond）是第二世代引入的幽灵属性招式。",
    description: "使出招式后，当受到对手攻击陷入昏厥时，对手也会一同昏厥。连续使出则会失败。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：同命（状态）\n使用者陷入同命状态。\n如果使用者因招式直接造成的伤害而陷入昏厥状态，攻击方也会进入昏厥状态。\n如果上个回合此宝可梦已成功使出同命，则本回合使用同命会失败。\n该招式不会被借助或挥指发动。\n该招式对极巨化和超极巨化的宝可梦无效。",
    range: "自身"
  },
  "detect": {
    intro: "这篇文章讲述的是一种格斗属性招式，不是特性察觉或一般属性招式识破。",
    description: "完全抵挡对手的攻击。连续使出则容易失败。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：守住（状态）\n在当回合内，使自身进入守住状态，保护自身不受到来自其他宝可梦的大部分招式的影响。\n如果在本回合使用者最后行动，则招式会失败。\n若成功使用看穿、挺住、守住、王者盾牌、尖刺防守、碉堡、拦堵、极巨防壁、线阱、火焰守护、掀榻榻米、广域防守或快速防守，则连续使用看穿的成功率降低至上一次的1⁄3（最低至1⁄729）。\n若成功使用看穿，则连续使用看穿、挺住、守住、王者盾牌、尖刺防守、碉堡、拦堵、极巨防壁、线阱或火焰守护的成功率降低至上一次的1⁄3（最低至1⁄729）。\n即使守住状态被解除，连续使用上述招式的成功率依旧会下降。\n该招式不会被借助或挥指发动。",
    range: "自身"
  },
  "diamond-storm": {
    description: "掀起钻石风暴给予伤害。有时会大幅提高自己的防御。"
  },
  "dig": {
    intro: "挖洞（日文︰あなをほる，英文︰Dig）是第一世代引入的地面属性招式。",
    description: "第1回合钻入地底，第2回合攻击对手。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响", "可以在对战外使用"],
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "dire-claw": {
    description: "以破灭之爪进行攻击。有时还会让对手陷入中毒、麻痹、睡眠之中的一种状态。"
  },
  "disable": {
    intro: "定身法（日文︰かなしばり，英文︰Disable）是第一世代引入的一般属性招式。",
    description: "阻碍对手行动，之前使出的招式将在4回合内无法使用。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：定身法（状态）\n使目标陷入定身法状态，在此期间目标不能使用陷入定身法状态前最后使用的招式。\n如果目标尚未在本场对战中使用招式、最后使用的招式是挣扎，或目标已经陷入定身法状态，定身法使用失败。\n第五世代起，定身法状态持续 4 回合。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "disarming-voice": {
    description: "发出魅惑的叫声，给予对手精神上的伤害。攻击必定会命中。"
  },
  "discharge": {
    description: "用耀眼的电击攻击自己周围所有的宝可梦。有时会陷入麻痹状态。"
  },
  "dive": {
    intro: "潜水（日文︰ダイビング，英文︰Dive）是第三世代引入的水属性招式。",
    description: "第1回合潜入水中，第2回合浮上来进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响", "可以在对战外使用"],
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "dizzy-punch": {
    intro: "迷昏拳（日文︰ピヨピヨパンチ，英文︰Dizzy Punch）是第一世代引入的一般属性招式。",
    description: "有节奏地出拳攻击对手。有时会使对手混乱。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n迷昏拳有20%的几率使目标陷入混乱状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "doodle": {
    description: "把握并映射出对手的本质，让自己和同伴宝可梦的特性变得和对手相同。"
  },
  "doom-desire": {
    description: "使用招式2回合后，会用无数道光束攻击对手。"
  },
  "double-edge": {
    intro: "舍身冲撞（日文︰すてみタックル，英文︰Double-Edge）是第一世代引入的一般属性招式。",
    description: "拼命地猛撞向对手进行攻击。自己也会受到不小的伤害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。使用者承受对目标造成伤害的1⁄3的伤害。\n使用者具有坚硬脑袋或魔法防守特性时，不会承受伤害。\n使用者具有舍身特性时，该招式威力提升20%，因此承受的伤害也会提升。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "double-hit": {
    description: "使用尾巴等拍打对手进行攻击。连续2次给予伤害。"
  },
  "double-iron-bash": {
    description: "以胸口的螺帽为中心旋转，并连续2次挥动手臂打击对手。有时会使对手畏缩。"
  },
  "double-kick": {
    intro: "二连踢（日文︰にどげり，英文︰Double Kick）是第一世代引入的格斗属性招式。",
    description: "用2只脚踢飞对手进行攻击。连续2次给予伤害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，一回合内连续攻击2次。\n每一击击中要害的概率都相等。\n如果第一下触发了目标的气势披带、气势头带、结实特性或打破了替身，招式会继续攻击。\n忍耐、金属爆炸和双倍奉还只计算最后一次的伤害。\n如果使用者持有王者之证或锐利之牙，或具有恶臭特性，每一下攻击都有相同的概率造成对手畏缩。如果使用者具有毒手特性，每一下攻击都有相同的概率造成对手中毒。\n如果目标拥有咒术之躯、碎裂铠甲或与接触类招式相关的特性或持有凸凸头盔，每一下攻击都会触发效果。即使特性发动令攻击方陷入一些可能无法行动的状态（如麻痹、畏缩、着迷、定身法状态），也不会影响本次攻击，但陷入睡眠和昏厥时攻击即刻停止。\n目标的木乃伊、游魂或甩不掉的气味特性会在第一下攻击之后就发动。使用方的顺手牵羊特性或目标的变色特性在最后一下攻击完成后才发动。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "double-shock": {
    description: "将全身所有的电力放出，给予对手大大的伤害。自己的电属性将会消失。"
  },
  "double-slap": {
    intro: "连环巴掌（日文︰おうふくビンタ，英文︰Double Slap）是第一世代引入的一般属性招式。",
    description: "用连环巴掌拍打对手进行攻击。连续攻击2～5次。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，一回合内连续攻击2～5次。命中时，各有15%的几率攻击5或4次，35%的几率攻击3或2次，攻击次数的数学期望是3.1次，对应的威力的数学期望是46.5。\n携带机变骰子且命中时，各有1⁄2的几率攻击5或4次，攻击次数的数学期望是4.5次，对应的威力的数学期望是67.5。\n每一击击中要害的概率都相等。\n如果某一下触发了目标的气势披带、气势头带、结实特性或打破了替身，招式会继续攻击。\n忍耐、金属爆炸和双倍奉还只计算最后一次的伤害。\n如果使用者持有王者之证或锐利之牙，或具有恶臭特性，每一下攻击都有相同的概率造成对手畏缩。如果使用者具有毒手特性，每一下攻击都有相同的概率造成对手中毒。\n如果目标拥有咒术之躯、碎裂铠甲或与接触类招式相关的特性或持有凸凸头盔，每一下攻击都会触发效果。即使特性发动令攻击方陷入一些可能无法行动的状态（如麻痹、畏缩、着迷、定身法状态），也不会影响本次攻击，但陷入睡眠和昏厥时攻击即刻停止。\n目标的木乃伊、游魂或甩不掉的气味特性会在第一下攻击之后就发动。使用方的顺手牵羊特性或目标的变色特性在最后一下攻击完成后才发动。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "double-team": {
    intro: "这篇文章讲述的是一种一般属性的变化招式。如果您在寻找英文名同样为“Double Team”的训练家类型，请移步双打组合。",
    description: "通过快速移动来制造分身，扰乱对手，从而提高闪避率。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令使用者的闪避率提升1级。",
    range: "自身"
  },
  "draco-meteor": {
    description: "从天空中向对手落下陨石。使用之后因为反作用力，自己的特攻会大幅降低。"
  },
  "dragon-ascent": {
    description: "从天空中急速下降攻击对手。自己的防御和特防会降低。"
  },
  "dragon-breath": {
    intro: "龙息（日文︰りゅうのいぶき，英文︰Dragon Breath）是第二世代引入的龙属性招式。",
    description: "将强烈的气息吹向对手进行攻击。有时会让对手陷入麻痹状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n龙息有30%的几率使目标陷入麻痹状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "dragon-cheer": {
    description: "以龙之鼓舞提高士气，让我方的招式变得容易击中要害。对龙属性的鼓舞效果会更强。"
  },
  "dragon-claw": {
    intro: "龙爪（日文︰ドラゴンクロー，英文︰Dragon Claw）是第三世代引入的龙属性招式。",
    description: "用尖锐的巨爪劈开对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "dragon-dance": {
    intro: "龙之舞（日文︰りゅうのまい，英文︰Dragon Dance）是第三世代引入的龙属性招式。",
    description: "激烈地跳起神秘且强有力的舞蹈。从而提高自己的攻击和速度。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令使用者的攻击提升1级。\n令使用者的速度提升1级。",
    range: "自身"
  },
  "dragon-darts": {
    description: "让多龙梅西亚进行2次攻击。如果对手有2只宝可梦，则对它们各进行1次攻击。"
  },
  "dragon-energy": {
    description: "把生命力转换为力量攻击对手。自己的HP越少，招式的威力越小。"
  },
  "dragon-hammer": {
    description: "将身体当作锤子，向对手发动袭击，给予伤害。"
  },
  "dragon-pulse": {
    description: "从大大的口中掀起冲击波攻击对手。"
  },
  "dragon-rage": {
    intro: "龙之怒（日文︰りゅうのいかり，英文︰Dragon Rage）是第一世代引入的龙属性招式。",
    description: "将愤怒的冲击波撞向对手进行攻击。必定会给予40的伤害。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "对目标造成40伤害。该招式无法对没有效果的属性的宝可梦造成伤害，但忽略其它属性相克和属性一致加成。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "dragon-rush": {
    description: "释放出骇人的杀气，一边威慑一边撞击对手。有时会使对手畏缩。"
  },
  "dragon-tail": {
    description: "弹飞对手，强制拉后备宝可梦上场。如果对手为野生宝可梦，战斗将直接结束。"
  },
  "drain-punch": {
    description: "用拳头吸取对手的力量。可以回复给予对手伤害的一半HP。"
  },
  "draining-kiss": {
    description: "用一个吻吸取对手的HP。回复给予对手伤害的一半以上的HP。"
  },
  "dream-eater": {
    intro: "食梦（日文︰ゆめくい，英文︰Dream Eater）是第一世代引入的超能力属性招式。",
    description: "吃掉正在睡觉的对手的梦进行攻击。回复对手所受到伤害的一半HP。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，自身的HP恢复“造成的伤害×50%”。既未处于睡眠状态又没有特性绝对睡眠的宝可梦不受食梦影响。在攻击方携带大根茎时，攻击伤害不变，HP恢复量提高到“造成的伤害×65%”。\n如果攻击方处于回复封锁状态，招式使用失败。\n使用食梦攻击替身状态下的宝可梦可以恢复HP。在第四世代及之前，食梦可以无视污泥浆特性。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "drill-peck": {
    intro: "啄钻（日文︰ドリルくちばし，英文︰Drill Peck）是第一世代引入的飞行属性招式。",
    description: "一边旋转，一边将尖喙刺入对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响", "是远程招式"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只宝可梦"
  },
  "drill-run": {
    description: "像钢钻一样，一边旋转身体一边撞击对手。容易击中要害。"
  },
  "drum-beating": {
    description: "用鼓点来控制鼓的根部进行攻击，从而降低对手的速度。"
  },
  "dual-chop": {
    description: "用身体坚硬的部分拍打对手进行攻击。连续2次给予伤害。"
  },
  "dual-wingbeat": {
    description: "将翅膀撞向对手进行攻击。连续2次给予伤害。"
  },
  "dynamax-cannon": {
    description: "将凝缩在体内的能量从核心放出进行攻击。"
  },
  "dynamic-punch": {
    intro: "爆裂拳（日文︰ばくれつパンチ，英文︰Dynamic Punch）是第二世代引入的格斗属性招式。",
    description: "使出浑身力气出拳进行攻击。必定会使对手混乱。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n爆裂拳有100%的几率使目标陷入混乱状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "earth-power": {
    description: "向对手脚下释放出大地之力。有时会降低对手的特防。"
  },
  "earthquake": {
    intro: "地震（日文︰じしん，英文︰Earthquake）是第一世代引入的地面属性招式。",
    description: "利用地震的冲击，攻击自己周围所有的宝可梦。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n如果目标处于挖洞状态，威力翻倍。\n可以击中处于挖洞状态的宝可梦。\n场地处于青草场地时威力下降50%。",
    range: "除自身以外场上全部可以攻击到的宝可梦"
  },
  "echoed-voice": {
    description: "用回声攻击对手。如果每回合都有宝可梦接着使用该招式，威力就会提高。"
  },
  "eerie-impulse": {
    description: "从身体放射出怪异电波，让对手沐浴其中，从而大幅降低其特攻。"
  },
  "egg-bomb": {
    intro: "炸蛋（日文︰タマゴばくだん，英文︰Egg Bomb）是第一世代引入的一般属性招式。",
    description: "向对手用力投掷大大的蛋进行攻击。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n对防弹特性的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "electric-terrain": {
    description: "在5回合内变成电气场地。地面上的宝可梦将无法入眠。电属性的招式威力还会提高。"
  },
  "electrify": {
    description: "对手使出招式前，如果输电，则该回合对手的招式变成电属性。"
  },
  "electro-ball": {
    description: "用电气团撞向对手。自己比对手速度越快，威力越大。"
  },
  "electro-drift": {
    description: "边变形边高速奔走，并以未知的电击贯穿对手。若针对到弱点，威力会进一步。"
  },
  "electro-shot": {
    description: "第1回合收集电力提高特攻，第2回合将高压的电力发射出去。下雨天气时能立刻发射。"
  },
  "electroweb": {
    description: "用电网捉住对手进行攻击。会降低对手的速度。"
  },
  "embargo": {
    description: "让对手在5回合内不能使用宝可梦携带的道具。训练家也不能给那只宝可梦使用道具。"
  },
  "ember": {
    intro: "火花（日文︰ひのこ，英文︰Ember）是第一世代引入的火属性招式。",
    description: "向对手发射小型火焰进行攻击。有时会让对手陷入灼伤状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n火花有10%的几率使目标陷入灼伤状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "encore": {
    intro: "再来一次（日文︰アンコール，英文︰Encore）是第二世代引入的一般属性招式。",
    description: "让对手接受再来一次，连续3次使出最后使用的招式。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：再来一次（状态）\n令目标接下来的 3 回合，只能使用其最后使用的招式。\n以下情况会导致招式使用失败：\n目标在进入对战后尚未使用招式；\n目标最后使用的招式的PP为0；\n目标最后使用的招式为再来一次、模仿、写生、挣扎、变身；\n目标最后使用的招式为调用其他招式的招式，包括借助、仿效、抢先一步、挥指、鹦鹉学舌、自然之力、梦话；\n目标最后使用的招式为Ｚ招式；\n目标最后使用的招式为极巨炮；\n极巨化宝可梦使用的招式；\n天星队车使用的专属招式。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "endeavor": {
    intro: "蛮干（日文︰がむしゃら，英文︰Endeavor）是第三世代引入的一般属性招式。",
    description: "给予伤害，使对手的HP变得和自己的HP一样。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "对目标造成相当于目标HP－使用者HP的伤害。该招式无法对没有效果的属性的宝可梦造成伤害，但忽略其它属性相克和属性一致加成。\n目标HP不高于使用者HP时招式使用失败。\n如果目标处于替身状态，蛮干以目标本体的HP计算伤害。\n当目标是极巨化宝可梦的伤害方式计算如下：\n对极巨化宝可梦造成的伤害＝（当前极巨化宝可梦的HP÷HP提升倍数）－当前攻击方HP\nHP提升倍数与极巨化等级对应，介于1.5与2之间；\n如果伤害≤0，则招式无效；\n最后计算出的伤害数值向上取整。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "endure": {
    intro: "挺住（日文︰こらえる，英文︰Endure）是第二世代引入的一般属性招式。",
    description: "即使受到攻击，也至少会留下1HP。连续使出则容易失败。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "在本回合结束前使自身保留至少1点HP，即使受到一击必杀的招式的攻击也会保留1点HP。\n无法阻止招式的附加效果。\n无法阻止异常状态或状态变化造成的伤害。\n如果在本回合使用者最后行动，则招式会失败。\n若成功使用看穿、挺住、守住、王者盾牌、尖刺防守、碉堡、拦堵、极巨防壁、线阱、火焰守护、掀榻榻米、广域防守或快速防守，则连续使用挺住的成功率降低至上一次的1⁄3（最低至1⁄729）。\n若成功使用挺住，则连续使用看穿、挺住、守住、王者盾牌、尖刺防守、碉堡、拦堵、极巨防壁、线阱或火焰守护的成功率降低至上一次的1⁄3（最低至1⁄729）。\n该招式不会被借助或挥指触发。",
    range: "自身"
  },
  "energy-ball": {
    description: "发射从自然收集的生命力量。有时会降低对手的特防。"
  },
  "entrainment": {
    description: "用神奇的节奏跳舞。使对手模仿自己的动作，从而将特性变成一样。"
  },
  "eruption": {
    intro: "这篇文章讲述的是威力随HP变化的火属性招式，不是威力固定的喷射火焰。",
    description: "爆发怒火攻击对手。自己的HP越少，招式的威力越小。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。威力随自身剩余HP减少而减少。\n威力 = 150 × （当前HP / 全部HP）。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "eternabeam": {
    description: "无极汰那变回原来的样子后，发动的最强攻击。下一回合自己将无法动弹。"
  },
  "expanding-force": {
    description: "利用精神力量攻击对手。在精神场地上威力会有所提高，能对所有对手造成伤害。"
  },
  "explosion": {
    intro: "这篇文章讲述的是威力为250的招式，不是玉石俱碎。",
    description: "引发大爆炸，攻击自己周围所有的宝可梦。使用后自己会陷入昏厥。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "自身陷入昏厥状态并攻击目标造成伤害。\n气势头带、气势披带、结实特性不能阻止使用者陷入昏厥状态。\n即使招式未命中、被守住状态阻挡，或因为属性相性而没有产生效果，使用者仍然会陷入昏厥状态。\n有湿气特性的宝可梦在场时，大爆炸使用失败，使用者不会陷入昏厥状态。",
    range: "除自身以外场上全部可以攻击到的宝可梦"
  },
  "extrasensory": {
    intro: "神通力（日文︰じんつうりき，英文︰Extrasensory）是第三世代引入的超能力属性招式。",
    description: "发出看不见的神奇力量进行攻击。有时会使对手畏缩。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n神通力有10%的几率使尚未行动的目标陷入畏缩状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "extreme-speed": {
    intro: "神速（日文︰しんそく，英文︰Extreme Speed）是第二世代引入的一般属性招式。",
    description: "以迅雷不及掩耳之势猛撞向对手进行攻击。必定能够先制攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "facade": {
    intro: "硬撑（日文︰からげんき，英文︰Facade）是第三世代引入的一般属性招式。",
    description: "当自己处于中毒、麻痹、灼伤状态时，向对手使出此招式的话，威力会变成2倍。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n如果自身处于灼伤、麻痹或中毒的异常状态下，威力翻倍。\n无视灼伤导致的攻击减半效果。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "fairy-lock": {
    description: "通过封锁，下一回合所有的宝可梦都无法逃走。"
  },
  "fairy-wind": {
    description: "刮起妖精之风，吹向对手进行攻击。"
  },
  "fake-out": {
    intro: "击掌奇袭（日文︰ねこだまし，英文︰Fake Out）是第三世代引入的一般属性招式。",
    description: "进行先制攻击，使对手畏缩。要在出场后立刻使出才能成功。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n出场后立刻使出才能成功，否则招式会失败。\n击掌奇袭会使尚未行动的目标陷入畏缩状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "fake-tears": {
    intro: "假哭（日文︰うそなき，英文︰Fake Tears）是第三世代引入的恶属性招式。",
    description: "装哭流泪。使对手不知所措，从而大幅降低对手的特防。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令目标的特防降低2级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "false-surrender": {
    description: "装作低头认错的样子，用凌乱的头发进行突刺。攻击必定会命中。"
  },
  "false-swipe": {
    intro: "点到为止（日文︰みねうち，英文︰False Swipe）是第二世代引入的一般属性招式。",
    description: "对手的HP至少会留下1HP，如此般手下留情地攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。目标宝可梦HP至少会保留1点。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "feather-dance": {
    intro: "羽毛舞（日文︰フェザーダンス，英文︰Feather Dance）是第三世代引入的飞行属性招式。",
    description: "撒出羽毛，笼罩在对手的周围。大幅降低对手的攻击。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令目标的攻击降低2级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "feint": {
    description: "能够攻击正在使用守住或看穿等招式的对手。解除其守护效果。"
  },
  "feint-attack": {
    intro: "出奇一击（日文︰だましうち，英文︰Feint Attack）是第二世代引入的恶属性招式。",
    description: "悄悄地靠近对手，趁其不备进行殴打。攻击必定会命中。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n出奇一击一定会命中，除非目标正在使用蓄力的招式并不在场地上。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "fell-stinger": {
    description: "如果使用此招式打倒对手，攻击会巨幅提高。"
  },
  "fickle-beam": {
    description: "发射光线进行攻击。有时其他的头也会合力发射镭射，让招式威力变成2倍。"
  },
  "fiery-dance": {
    description: "让火焰覆盖全身，振翅攻击对手。有时会提高自己的特攻。"
  },
  "fillet-away": {
    description: "削减自己的HP，大幅提高攻击和特攻以及速度。"
  },
  "final-gambit": {
    description: "拼命攻击对手。虽然自己陷入昏厥，但会给予对手和自己目前HP等量的伤害。"
  },
  "fire-blast": {
    intro: "大字爆炎（日文︰だいもんじ，英文︰Fire Blast）是第一世代引入的火属性招式。",
    description: "用大字形状的火焰烧尽对手。有时会让对手陷入灼伤状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n大字爆炎有10%的几率使目标陷入灼伤状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "fire-fang": {
    description: "用覆盖着火焰的牙齿咬住对手。有时会使对手畏缩或陷入灼伤状态。"
  },
  "fire-lash": {
    description: "用燃烧的鞭子抽打对手。受到攻击的对手防御会降低。"
  },
  "fire-pledge": {
    description: "用火柱进行攻击。如果和草组合，威力就会提高，周围会变成火海。"
  },
  "fire-punch": {
    intro: "火焰拳（日文︰ほのおのパンチ，英文︰Fire Punch）是第一世代引入的火属性招式。",
    description: "用充满火焰的拳头攻击对手。有时会让对手陷入灼伤状态。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n火焰拳有10%的几率使目标陷入灼伤状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "fire-spin": {
    intro: "火焰旋涡（日文︰ほのおのうず，英文︰Fire Spin）是第一世代引入的火属性招式。",
    description: "将对手困在激烈的火焰旋涡中，在4～5回合内进行攻击。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "主页面：束缚（状态）\n攻击目标造成伤害。使目标陷入束缚状态。束缚状态持续4～5回合，处于束缚状态的宝可梦会持续受到伤害并不能换下。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "first-impression": {
    description: "威力很高的招式，但只有在出场战斗时，立刻使出才能成功。"
  },
  "fishious-rend": {
    description: "用坚硬的腮咬住对手。如果比对手先出手攻击，招式的威力会变成2倍。"
  },
  "fissure": {
    intro: "地裂（日文︰じわれ，英文︰Fissure）是第一世代引入的地面属性招式。",
    description: "让对手掉落于地裂的裂缝中进行攻击。只要命中就会一击昏厥。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "地裂造成与对手的最大HP相同的固定伤害。只要属性相性不为0倍，就能一击造成昏厥。\n如果自身等级低于目标，招式使用失败。\n此招式不使用通常命中判定：\n招式的命中等于：(30 + 使用者等级 - 目标等级)%。\n命中的概率不会受到命中率和闪避率影响。\n锁定状态和无防守特性能够使此招式变成必定命中。\n此招式对结实特性的宝可梦无效。\n此招式对飘浮及食土特性的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "flail": {
    intro: "抓狂（日文︰じたばた，英文︰Flail）是第二世代引入的一般属性招式。",
    description: "抓狂般乱打进行攻击。自己的HP越少，招式的威力越大。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。招式威力和自身剩下的HP有关。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "flame-burst": {
    description: "如果击中，爆裂的火焰会攻击到对手。爆裂出的火焰还会飞溅到旁边的对手。"
  },
  "flame-charge": {
    description: "让火焰覆盖全身，攻击对手。积蓄力量来提高自己的速度。"
  },
  "flame-wheel": {
    intro: "火焰轮（日文︰かえんぐるま，英文︰Flame Wheel）是第二世代引入的火属性招式。",
    description: "让火焰覆盖全身，猛撞向对手进行攻击。有时会让对手陷入灼伤状态。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n火焰轮有10%的几率使目标陷入灼伤状态。\n处于冰冻状态的宝可梦，无论是否命中，只要成功使用该招式，就可以解除冰冻。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "flamethrower": {
    intro: "喷射火焰（日文︰かえんほうしゃ，英文︰Flamethrower）是第一世代引入的火属性招式。",
    description: "向对手发射烈焰进行攻击。有时会让对手陷入灼伤状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n喷射火焰有10%的几率使目标陷入灼伤状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "flare-blitz": {
    description: "让火焰覆盖全身猛撞向对手。自己也会受到不小的伤害。有时会让对手陷入灼伤状态。"
  },
  "flash": {
    intro: "闪光（日文︰フラッシュ，英文︰Flash）是第一世代引入的一般属性招式。",
    description: "使出光芒，从而降低对手的命中率。也可在阴暗的洞窟里照亮四周。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响", "可以在对战外使用"],
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "flash-cannon": {
    description: "将身体的光芒聚集在一点释放出去。有时会降低对手的特防。"
  },
  "flatter": {
    intro: "吹捧（日文︰おだてる，英文︰Flatter）是第三世代引入的恶属性招式。",
    description: "吹捧对手，使其混乱。同时还会提高对手的特攻。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "吹捧会使目标陷入混乱状态，同时目标的特攻提升1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "fleur-cannon": {
    description: "放出强力光束后，自己的特攻会大幅降低。"
  },
  "fling": {
    description: "快速投掷携带的道具进行攻击。根据道具不同，威力和效果会改变。"
  },
  "flip-turn": {
    description: "在攻击之后急速返回，和后备宝可梦进行替换。"
  },
  "floral-healing": {
    description: "回复对手最大HP的一半。在青草场地时，效果会提高。"
  },
  "flower-shield": {
    description: "使用神奇的力量提高在场的所有草属性宝可梦的防御。"
  },
  "flower-trick": {
    description: "将做了手脚的花束扔向对手进行攻击。必定会命中，且会击中要害。"
  },
  "fly": {
    intro: "飞翔（日文︰そらをとぶ，英文︰Fly）是第一世代引入的飞行属性招式。",
    description: "第1回合飞上天空，第2回合攻击对手。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响", "可以在对战外使用", "是远程招式"],
    range: "除自身以外场上一只宝可梦"
  },
  "flying-press": {
    description: "从空中俯冲向对手。此招式同时带有格斗属性和飞行属性。"
  },
  "focus-blast": {
    description: "提高气势，释放出全部力量。有时会降低对手的特防。"
  },
  "focus-energy": {
    intro: "聚气（日文︰きあいだめ，英文︰Focus Energy）是第一世代引入的一般属性招式。",
    description: "深深地吸口气，集中精神。自己的攻击会变得容易击中要害。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：易中要害（状态）\n使自身进入易中要害状态。处于易中要害状态的宝可梦的击中要害率上升2级。",
    range: "自身"
  },
  "focus-punch": {
    intro: "真气拳（日文︰きあいパンチ，英文︰Focus Punch）是第三世代引入的格斗属性招式。",
    description: "集中精神出拳。在招式使出前若受到攻击则会失败。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "在一回合内先聚气再攻击目标造成伤害。\n聚气优先度为+5，攻击优先度为-3。聚气后如果在发动攻击前受到伤害，则招式会失败。\n该招式不会被借助、挥指或梦话发动。\n极巨化的野生宝可梦使用此招式时，即使在发动攻击前收到伤害，也能够正常使出该招式。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "follow-me": {
    intro: "看我嘛（日文︰このゆびとまれ，英文︰Follow Me）是第三世代引入的一般属性招式。",
    description: "引起对手的注意，将对手的攻击全部转移到自己身上。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：万众瞩目（状态）\n本回合内自身进入万众瞩目状态。直到这回合结束，所有对方使用的作用范围为单体选择的招式都会攻向自己。如果我方有多只宝可梦都进入万众瞩目状态，则速度最高的宝可梦生效。\n该招式不会被借助或挥指发动。",
    range: "自身"
  },
  "force-palm": {
    description: "向对手的身体发出冲击波进行攻击。有时会让对手陷入麻痹状态。"
  },
  "foresight": {
    intro: "这篇文章讲述的是一种一般属性招式，不是格斗属性招式看穿。",
    description: "使出后对幽灵属性宝可梦没有效果的招式以及闪避率高的对手，变得能够打中。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：被识破（状态）\n使目标陷入被识破状态。处于被识破状态的宝可梦闪避率提升无效，可以受到一般属性和格斗属性招式的攻击。\n识破一定会命中，除非目标正在使用蓄力的招式并不在场地上。\n如果目标已经处于被识破状态，招式使用失败。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "foul-play": {
    description: "利用对手的力量进行攻击。正和自己战斗的对手，其攻击越高，伤害越大。"
  },
  "freeze-dry": {
    description: "急剧冷冻对手，有时会让对手陷入冰冻状态。对于水属性宝可梦也是效果绝佳。"
  },
  "frenzy-plant": {
    intro: "疯狂植物（日文︰ハードプラント，英文︰Frenzy Plant）是第三世代引入的草属性招式。",
    description: "用大树摔打对手进行攻击。下一回合自己将无法动弹。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n下一回合无法使用招式、使用道具、逃走或替换宝可梦。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "frost-breath": {
    description: "将冰冷的气息吹向对手进行攻击。必定会击中要害。"
  },
  "frustration": {
    intro: "迁怒（日文︰やつあたり，英文︰Frustration）是第二世代引入的一般属性招式。",
    description: "为了发泄不满而全力攻击对手。亲密度越低，威力越大。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。威力随着亲密度增加而减弱，为（255 - 亲密度）÷2.5；最大102，最小1。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "fury-attack": {
    intro: "乱击（日文︰みだれづき，英文︰Fury Attack）是第一世代引入的一般属性招式。",
    description: "用角或喙刺向对手进行攻击。连续攻击2～5次。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，一回合内连续攻击2～5次。命中时，各有15%的几率攻击5或4次，35%的几率攻击3或2次，攻击次数的数学期望是3.1次，对应的威力的数学期望是46.5。\n携带机变骰子且命中时，各有1⁄2的几率攻击5或4次，攻击次数的数学期望是4.5次，对应的威力的数学期望是67.5。\n每一击击中要害的概率都相等。\n如果某一下触发了目标的气势披带、气势头带、结实特性或打破了替身，招式会继续攻击。\n忍耐、金属爆炸和双倍奉还只计算最后一次的伤害。\n如果使用者持有王者之证或锐利之牙，或具有恶臭特性，每一下攻击都有相同的概率造成对手畏缩。如果使用者具有毒手特性，每一下攻击都有相同的概率造成对手中毒。\n如果目标拥有咒术之躯、碎裂铠甲或与接触类招式相关的特性或持有凸凸头盔，每一下攻击都会触发效果。即使特性发动令攻击方陷入一些可能无法行动的状态（如麻痹、畏缩、着迷、定身法状态），也不会影响本次攻击，但陷入睡眠和昏厥时攻击即刻停止。\n目标的木乃伊、游魂或甩不掉的气味特性会在第一下攻击之后就发动。使用方的顺手牵羊特性或目标的变色特性在最后一下攻击完成后才发动。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "fury-cutter": {
    intro: "连斩（日文︰れんぞくぎり，英文︰Fury Cutter）是第二世代引入的虫属性招式。",
    description: "用镰刀或爪子等切斩对手进行攻击。连续击中，威力就会提高。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。每次连斩成功命中对手，则下次攻击时招式威力翻倍。如果招式未命中或自身离开对战或使用了其它招式，则威力重置为基础威力。\n最大威力为160。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "fury-swipes": {
    intro: "乱抓（日文︰みだれひっかき，英文︰Fury Swipes）是第一世代引入的一般属性招式。",
    description: "用爪子或镰刀等抓对手进行攻击。连续攻击2～5次。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，一回合内连续攻击2～5次。命中时，各有15%的几率攻击5或4次，35%的几率攻击3或2次，攻击次数的数学期望是3.1次，对应的威力的数学期望是55.8。\n携带机变骰子且命中时，各有1⁄2的几率攻击5或4次，攻击次数的数学期望是4.5次，对应的威力的数学期望是81。\n每一击击中要害的概率都相等。\n如果某一下触发了目标的气势披带、气势头带、结实特性或打破了替身，招式会继续攻击。\n忍耐、金属爆炸和双倍奉还只计算最后一次的伤害。\n如果使用者持有王者之证或锐利之牙，或具有恶臭特性，每一下攻击都有相同的概率造成对手畏缩。如果使用者具有毒手特性，每一下攻击都有相同的概率造成对手中毒。\n如果目标拥有咒术之躯、碎裂铠甲或与接触类招式相关的特性或持有凸凸头盔，每一下攻击都会触发效果。即使特性发动令攻击方陷入一些可能无法行动的状态（如麻痹、畏缩、着迷、定身法状态），也不会影响本次攻击，但陷入睡眠和昏厥时攻击即刻停止。\n目标的木乃伊、游魂或甩不掉的气味特性会在第一下攻击之后就发动。使用方的顺手牵羊特性或目标的变色特性在最后一下攻击完成后才发动。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "fusion-bolt": {
    description: "释放出巨大的闪电。受到巨大的火焰影响时，招式威力会提高。"
  },
  "fusion-flare": {
    description: "释放出巨大的火焰。受到巨大的闪电影响时，招式威力会提高。"
  },
  "future-sight": {
    intro: "预知未来（日文︰みらいよち，英文︰Future Sight）是第二世代引入的超能力属性招式。",
    description: "在使用招式2回合后，向对手发送一团念力进行攻击。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：未来攻击（状态）\n使对方宝可梦所在的位置陷入未来攻击状态。\n对已经陷入未来攻击状态的位置使用则会失败。\n2回合后，未来攻击状态解除，所在位置的宝可梦受到超能力属性的伤害。此时：\n若预知未来的使用者在场上，未来攻击的伤害按照双方当前能力值进行计算。若使用者携带的道具有效，其效果也会发动（除贝壳之铃和节拍器）。\n例如，携带生命宝珠会提高未来攻击的伤害，使用者也会扣除HP。\n若预知未来的使用者不在场上，未来攻击的伤害按照使用者原本的能力值进行计算，且不受使用者携带道具的影响。\n精神场地会提高超能力属性未来攻击的伤害，无论使用者此时是否在场上。\n未来攻击的伤害不能被守住抵挡。\n该招式不能被鹦鹉学舌学习。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "gastro-acid": {
    description: "将胃液吐向对手的身体。沾上的胃液会消除对手的特性效果。"
  },
  "gear-grind": {
    description: "向对手投掷钢铁齿轮进行攻击。连续2次给予伤害。"
  },
  "gear-up": {
    description: "启动齿轮，提高特性为正电和负电的宝可梦的攻击和特攻。"
  },
  "geomancy": {
    description: "第1回合吸收能量，第2回合大幅提高特攻、特防和速度。"
  },
  "giga-drain": {
    intro: "终极吸取（日文︰ギガドレイン，英文︰Giga Drain）是第二世代引入的草属性招式。",
    description: "吸取对手的养分进行攻击。可以回复给予对手伤害的一半HP。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，自身的HP恢复“造成的伤害×50%”。在攻击方携带大根茎时，攻击伤害不变，HP恢复量提高到“造成的伤害×65%”。\n如果攻击方处于回复封锁状态，招式使用失败。\n使用终极吸取攻击替身状态下的宝可梦可以恢复HP。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "giga-impact": {
    description: "使出自己浑身力量突击对手。下一回合自己将无法动弹。"
  },
  "gigaton-hammer": {
    description: "连同身体转起巨大的锤子进行攻击。这个招式无法连续使出2次。"
  },
  "glaciate": {
    description: "将冰冻的冷气吹向对手进行攻击。会降低对手的速度。"
  },
  "glaive-rush": {
    description: "有勇无谋的舍身突击。使出招式后，对手的攻击必定会命中，且伤害会变成2倍。"
  },
  "glare": {
    intro: "大蛇瞪眼（日文︰へびにらみ，英文︰Glare）是第一世代引入的一般属性招式。",
    description: "用腹部的花纹使对手害怕，从而让其陷入麻痹状态。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "大蛇瞪眼会使目标陷入麻痹状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "grass-knot": {
    description: "用草缠住并绊倒对手。对手越重，威力越大。"
  },
  "grass-pledge": {
    description: "用草柱进行攻击。如果和水组合，威力就会提高，周围会变成湿地。"
  },
  "grass-whistle": {
    intro: "草笛（日文︰くさぶえ，英文︰Grass Whistle）是第三世代引入的草属性招式。",
    description: "让对手听舒适的笛声，从而陷入睡眠状态。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "草笛会使目标陷入睡眠状态。\n对隔音特性的宝可梦无效。\n该招式无视目标的替身状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "grassy-glide": {
    description: "仿佛在地面上滑行般地攻击对手。在青草场地上，必定能够先制攻击。"
  },
  "grassy-terrain": {
    description: "在5回合内变成青草场地。地面上的宝可梦每回合都能回复。草属性的招式威力还会提高。"
  },
  "grav-apple": {
    description: "从高处落下苹果，给予对手伤害。可降低对手的防御。"
  },
  "gravity": {
    description: "在5回合内，飘浮特性和飞行属性的宝可梦会被地面属性的招式击中。飞向空中的招式也将无法使用。"
  },
  "growl": {
    intro: "这篇文章讲述的是令目标的攻击降低1级的招式。如果您在寻找宝可梦鸣叫的声音，请移步叫声。",
    description: "让对手听可爱的叫声，引开注意力使其疏忽，从而降低对手的攻击。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令目标的攻击降低1级。\n对隔音特性的宝可梦无效。\n该招式无视目标的替身状态。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "growth": {
    intro: "生长（日文︰せいちょう，英文︰Growth）是第一世代引入的一般属性招式。",
    description: "让身体一下子长大，从而提高攻击和特攻。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令使用者的攻击提升1级。\n令使用者的特攻提升1级。\n在大晴天或大日照天气下等级提升数量翻倍。",
    range: "自身"
  },
  "grudge": {
    intro: "怨念（日文︰おんねん，英文︰Grudge）是第三世代引入的幽灵属性招式。",
    description: "因对手的招式而陷入昏厥时给对手施加怨念，让该招式的PP变成0。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：怨念（状态）\n如果自身在下次行动前被招式直接造成的伤害击倒，击倒自己的宝可梦用于击倒自身的招式的PP归0。",
    range: "自身"
  },
  "guard-split": {
    description: "利用超能力将自己和对手的防御和特防相加，再进行平分。"
  },
  "guard-swap": {
    description: "利用超能力互换自己和对手的防御以及特防的能力变化。"
  },
  "guillotine": {
    intro: "极落钳（日文︰ハサミギロチン，英文︰Guillotine）是第一世代引入的一般属性招式。",
    description: "用大钳子或剪刀等夹断对手进行攻击。只要命中就会一击昏厥。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "极落钳造成与对手的最大HP相同的固定伤害。只要属性相性不为0倍，就能一击造成昏厥。\n如果自身等级低于目标，招式使用失败。\n此招式不使用通常命中判定：\n招式的命中等于：(30 + 使用者等级 - 目标等级)%。\n命中的概率不会受到命中率和闪避率影响。\n锁定状态和无防守特性能够使此招式变成必定命中。\n此招式对结实特性的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "gunk-shot": {
    description: "用肮脏的垃圾撞向对手进行攻击。有时会让对手陷入中毒状态。"
  },
  "gust": {
    intro: "起风（日文︰かぜおこし，英文︰Gust）是第一世代引入的飞行属性招式。",
    description: "用翅膀将刮起的狂风袭向对手进行攻击。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响", "是远程招式"],
    additionalEffect: "攻击目标造成伤害。\n如果目标处于飞翔状态，威力翻倍。\n可以击中处于飞翔状态的宝可梦。",
    range: "除自身以外场上一只宝可梦"
  },
  "gyro-ball": {
    description: "让身体高速旋转并撞击对手。速度比对手越慢，威力越大。"
  },
  "hail": {
    intro: "冰雹（日文︰あられ，英文︰Hail）是第三世代引入的冰属性招式。",
    description: "在5回合内一直降冰雹，除冰属性的宝可梦以外，给予全体宝可梦伤害。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：冰雹（状态）\n包括使用的回合在内，接下来5回合的天气变更为冰雹。如果使用者携带了冰冷岩石，持续时间延长为8回合。\n使用该招式会覆盖原本的天气。无论原本的天气是否永续，该招式的效果结束之后天气都会恢复为晴朗。如果当前天气为大雨、大日照、乱流或已经为冰雹，招式使用失败。",
    range: "全部场地"
  },
  "hammer-arm": {
    description: "挥舞强力而沉重的拳头，给予对手伤害。自己的速度会降低。"
  },
  "hard-press": {
    description: "用手臂或钳子压迫对手。对手剩余的HP越多，威力越大。"
  },
  "harden": {
    intro: "变硬（日文︰かたくなる，英文︰Harden）是第一世代引入的一般属性招式。",
    description: "全身使劲，让身体变硬，从而提高自己的防御。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令使用者的防御提升1级。",
    range: "自身"
  },
  "haze": {
    intro: "黑雾（日文︰くろいきり，英文︰Haze）是第一世代引入的冰属性招式。",
    description: "升起黑雾，将正在场上战斗的全体宝可梦的能力变回原点。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "场上全部宝可梦的能力变化（包括命中率、闪避率）的修正消除。\n使用该招式不会被恒净之躯、白色烟雾、金属防护、花幕、怪力钳、健壮胸肌、锐利目光、白雾、清净坠饰视作降低能力。",
    range: "全部场地"
  },
  "head-charge": {
    description: "用厉害的爆炸头猛撞向对手进行攻击。自己也会受到少许伤害。"
  },
  "head-smash": {
    description: "拼命使出浑身力气，向对手进行头锤攻击。自己也会受到非常大的伤害。"
  },
  "headbutt": {
    intro: "这篇文章讲述的是第一世代曾译“铁头功”的一般属性招式。如果您在寻找第四世代的钢属性招式，请移步铁头（招式）。",
    description: "将头伸出，笔直地扑向对手进行攻击。有时会使对手畏缩。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "headlong-rush": {
    description: "向对手使出灌注了全心全力的撞击。自己的防御和特防会降低。"
  },
  "heal-bell": {
    intro: "治愈铃声（日文︰いやしのすず，英文︰Heal Bell）是第二世代引入的一般属性招式。",
    description: "让同伴听舒适的铃音，从而治愈我方全员的异常状态。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "治愈己方同行中全部宝可梦的异常状态。\n隔音特性的宝可梦可以正常使用治愈铃声且可以正常治愈自己的异常状态。\n可以治愈未上场的隔音特性的宝可梦。\n在多人对战中，可以治愈在场的同伴。\n在双打对战中，不能治愈在场上的具有隔音特性的宝可梦。",
    range: "全部我方宝可梦"
  },
  "heal-block": {
    description: "在5回合内无法通过招式、特性或携带的道具来回复HP。"
  },
  "heal-order": {
    description: "召唤手下疗伤。回复自己最大HP的一半。"
  },
  "heal-pulse": {
    description: "放出治愈波动，从而回复对手最大HP的一半。"
  },
  "healing-wish": {
    description: "虽然自己陷入昏厥，但可以治愈后备上场的宝可梦的异常状态以及回复HP。"
  },
  "heart-stamp": {
    description: "以可爱的动作使对手疏忽，乘机给出强烈的一击。有时会使对手畏缩。"
  },
  "heart-swap": {
    description: "利用超能力互换自己和对手之间的能力变化。"
  },
  "heat-crash": {
    description: "用燃烧的身体撞向对手进行攻击。自己比对手越重，威力越大。"
  },
  "heat-wave": {
    intro: "热风（日文︰ねっぷう，英文︰Heat Wave）是第三世代引入的火属性招式。",
    description: "将炎热的气息吹向对手进行攻击。有时会让对手陷入灼伤状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n热风有10%的几率使目标陷入灼伤状态。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "heavy-slam": {
    description: "用沉重的身体撞向对手进行攻击。自己比对手越重，威力越大。"
  },
  "helping-hand": {
    intro: "这篇文章讲述的是一种提升己方其他宝可梦招式威力的招式。如果您在寻找随机使用同行其它1只宝可梦的一个招式，请移步借助。",
    description: "帮助伙伴。被帮助的宝可梦，其招式威力变得比平时大。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：帮助（状态）\n使目标进入帮助状态。处于帮助状态的宝可梦在本回合结束前招式的威力提升50%。\n该招式不会被鹦鹉学舌或模仿学习，也不会被借助或挥指发动。\n即使目标不在场地上（例如飞翔）或者目标处于替身后，也能成功使用。\n双打对战中场上没有其他同伴时RSEFRLGPtHGSSBWB2W2、在单打对战时使用该招式必定失败。\n在双打对战中场上没有其他同伴时不能选择这个招式。如果没有其它可以使用的招式，即使该招式还有PP，也只能使用挣扎DP。\n如果目标已经使用过招式，招式使用失败。\n在三打对战中，帮助状态可以叠加，因此当两边的宝可梦同时使用帮助时，中间的宝可梦攻击伤害增加到225％（1.5×1.5倍）。\n在太晶团体战中，帮助状态不能叠加。对一只宝可梦一个回合内多次使用帮助只会提升50%伤害。",
    range: "除自身以外场上任意一只我方宝可梦"
  },
  "hex": {
    description: "接二连三地进行攻击。对处于异常状态的对手给予较大的伤害。"
  },
  "hidden-power": {
    intro: "觉醒力量（日文︰めざめるパワー，英文︰Hidden Power）是第二世代引入的一般属性招式。",
    description: "招式的属性会随着使用此招式的宝可梦而改变。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。属性会在攻击前变为能够造成效果绝佳的属性。使用者不是未知图腾时，使用失败。\n在宝可梦的属性和觉醒力量的实际属性一致的情况下，可以具有属性一致加成效果。\n不存在一般属性的觉醒力量。在发动Ｚ招式时被视为一般属性。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "high-horsepower": {
    description: "使出全身力量，猛攻对手。"
  },
  "high-jump-kick": {
    intro: "这篇文章讲述的是威力130的格斗招式，不是飞踢。",
    description: "跳起后用膝盖撞对手进行攻击。如果撞偏则自己会受到伤害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n如果招式未命中、被守住状态阻挡，因为属性相性或特性而没有产生效果，自身承受最大HP的1⁄2（向下取整）的反作用力伤害。\n使用者具有魔法防守特性时，招式没有产生效果时使用者不会承受伤害。\n使用者具有舍身特性时，该招式威力提升20%。\n\n如果场上存在重力作用，则无法使用该招式。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "hone-claws": {
    description: "将爪子磨得更加锋利。提高自己的攻击和命中率。"
  },
  "horn-attack": {
    intro: "角撞（日文︰つのでつく，英文︰Horn Attack）是第一世代引入的一般属性招式。",
    description: "用尖锐的角攻击对手。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "horn-drill": {
    intro: "角钻（日文︰つのドリル，英文︰Horn Drill）是第一世代引入的一般属性招式。",
    description: "用旋转的角刺入对手进行攻击。只要命中就会一击昏厥。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "角钻造成与对手的最大HP相同的固定伤害。只要属性相性不为0倍，就能一击造成昏厥。\n如果自身等级低于目标，招式使用失败。\n此招式不使用通常命中判定：\n招式的命中等于：(30 + 使用者等级 - 目标等级)%。\n命中的概率不会受到命中率和闪避率影响。\n锁定状态和无防守特性能够使此招式变成必定命中。\n此招式对结实特性的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "horn-leech": {
    description: "将角刺入，吸取对手的养分。可以回复给予对手伤害的一半HP。"
  },
  "howl": {
    intro: "长嚎（日文︰とおぼえ，英文︰Howl）是第三世代引入的一般属性招式。",
    description: "大声吼叫提高气势，从而提高自己和同伴的攻击。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令使用者和同伴的攻击提升1级。\n对特性为隔音的同伴无效，但使用者自身特性为隔音时可以正常使用，也能够触发自身携带的爽喉喷雾。",
    range: "全部我方宝可梦"
  },
  "hurricane": {
    description: "用强烈的风席卷对手进行攻击。有时会使对手混乱。"
  },
  "hydro-cannon": {
    intro: "加农水炮（日文︰ハイドロカノン，英文︰Hydro Cannon）是第三世代引入的水属性招式。",
    description: "向对手喷射水炮进行攻击。下一回合自己将无法动弹。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n下一回合无法使用招式、使用道具、逃走或替换宝可梦。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "hydro-pump": {
    intro: "这篇文章讲述的是水属性的招式。如果您在寻找名称相仿的特性，请移步水泡（特性）。",
    description: "向对手猛烈地喷射大量水流进行攻击。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "hydro-steam": {
    description: "将煮得翻滚的开水猛烈地喷向对手。日照强烈时，招式威力不但不会降低，还会变成1．5倍。"
  },
  "hyper-beam": {
    intro: "破坏光线（日文︰はかいこうせん，英文︰Hyper Beam）是第一世代引入的一般属性招式。",
    description: "向对手发射强烈的光线进行攻击。下一回合自己将无法动弹。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n下一回合无法使用招式、使用道具、逃走或替换宝可梦。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "hyper-drill": {
    description: "急速旋转尖锐的身体部位贯穿对手。可以无视守住和看穿等招式。"
  },
  "hyper-fang": {
    intro: "终结门牙（日文︰ひっさつまえば，英文︰Hyper Fang）是第一世代引入的一般属性招式。",
    description: "用锋利的门牙牢牢地咬住对手进行攻击。有时会使对手畏缩。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n终结门牙有20%的几率使尚未行动的目标陷入畏缩状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "hyper-voice": {
    intro: "巨声（日文︰ハイパーボイス，英文︰Hyper Voice）是第三世代引入的一般属性招式。",
    description: "给予对手又吵又响的巨大震动进行攻击。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n对隔音特性的宝可梦无效。\n该招式无视目标的替身状态。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "hyperspace-hole": {
    description: "通过异次元洞，突然出现在对手的侧面进行攻击。还可以无视守住和看穿等招式。"
  },
  "hypnosis": {
    intro: "催眠术（日文︰さいみんじゅつ，英文︰Hypnosis）是第一世代引入的超能力属性招式。",
    description: "施以诱导睡意的暗示，让对手陷入睡眠状态。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "催眠术会使目标陷入睡眠状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "ice-ball": {
    intro: "冰球（日文︰アイスボール，英文︰Ice Ball）是第三世代引入的冰属性招式。",
    description: "在5回合内攻击对手。招式每次击中，威力就会提高。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n使用者在接下来的4回合会继续使用冰球进行攻击，无法使用其他招式、使用道具、替换宝可梦或逃走。\n后续的4次攻击的威力分别提升为2倍、4倍、8倍和16倍。\n因梦话而使用时，不会继续攻击，也不会提升后续攻击的威力。\n因守住状态、未命中、属性相性无效等原因而没有产生效果时，不再继续攻击，威力提升效果消失。\n使用者进入飞翔状态时，仅在当回合中断攻击。飞翔状态解除后，若尚未经过4回合，会继续使用冰球进行攻击。\n因飞翔状态中断攻击导致后续4回合中没有攻击4次时，威力提升效果保留，会增加后续使出的任何攻击招式的威力。这是一个游戏漏洞。\n如果在对战中自身曾使用变圆，则该招式威力还会再次翻倍。\n后续回合的攻击不消耗PP。\n对防弹特性的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "ice-beam": {
    intro: "冰冻光束（日文︰れいとうビーム，英文︰Ice Beam）是第一世代引入的冰属性招式。",
    description: "向对手发射冰冻光束进行攻击。有时会让对手陷入冰冻状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n冰冻光束有10%的几率使目标陷入冰冻状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "ice-fang": {
    description: "用藏有冷气的牙齿咬住对手。有时会使对手畏缩或陷入冰冻状态。"
  },
  "ice-hammer": {
    description: "挥舞强力而沉重的拳头，给予对手伤害。自己的速度会降低。"
  },
  "ice-punch": {
    intro: "冰冻拳（日文︰れいとうパンチ，英文︰Ice Punch）是第一世代引入的冰属性招式。",
    description: "用充满寒气的拳头攻击对手。有时会让对手陷入冰冻状态。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n冰冻拳有10%的几率使目标陷入冰冻状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "ice-shard": {
    description: "瞬间制作冰块，快速地扔向对手。必定能够先制攻击。"
  },
  "ice-spinner": {
    description: "脚上覆盖薄冰，旋转着撞击对手。通过旋转的动作破坏场地。"
  },
  "icicle-crash": {
    description: "用大冰柱激烈地撞向对手进行攻击。有时会使对手畏缩。"
  },
  "icicle-spear": {
    intro: "冰锥（日文︰つららばり，英文︰Icicle Spear）是第三世代引入的冰属性招式。",
    description: "向对手发射锋利的冰柱进行攻击。连续攻击2～5次。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，一回合内连续攻击2～5次。命中时，各有15%的几率攻击5或4次，35%的几率攻击3或2次，攻击次数的数学期望是3.1次，对应的威力的数学期望是77.5。\n携带机变骰子且命中时，各有1⁄2的几率攻击5或4次，攻击次数的数学期望是4.5次，对应的威力的数学期望是112.5。\n每一击击中要害的概率都相等。\n如果某一下触发了目标的气势披带、气势头带、结实特性或打破了替身，招式会继续攻击。\n忍耐、金属爆炸和双倍奉还只计算最后一次的伤害。\n如果使用者持有王者之证或锐利之牙，或具有恶臭特性，每一下攻击都有相同的概率造成对手畏缩。\n如果目标拥有咒术之躯、碎裂铠甲特性，每一下攻击都会触发效果。即使特性发动令攻击方陷入一些可能无法行动的状态（如麻痹、畏缩、着迷、定身法状态），也不会影响本次攻击，但陷入睡眠和昏厥时攻击即刻停止。\n目标的变色特性在最后一下攻击完成后才发动。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "icy-wind": {
    intro: "冰冻之风（日文︰こごえるかぜ，英文︰Icy Wind）是第二世代引入的冰属性招式。",
    description: "将结冰的冷气吹向对手进行攻击。会降低对手的速度。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n令目标的速度降低1级。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "imprison": {
    intro: "封印（日文︰ふういん，英文︰Imprison）是第三世代引入的超能力属性招式。",
    description: "如果对手有和自己相同的招式，那么只有对手无法使用该招式。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：封印（状态）\n使自身陷入封印状态。\n自身处于封印状态期间，对手的任何宝可梦不能使出与自身学会的任一招式相同的招式。",
    range: "自身"
  },
  "incinerate": {
    description: "用火焰攻击对手。对手携带树果等时，会烧掉，使其不能使用。"
  },
  "inferno": {
    description: "用烈焰包裹住对手进行攻击。让对手陷入灼伤状态。"
  },
  "infestation": {
    description: "在4～5回合内死缠烂打地进行攻击。在此期间对手将无法逃走。"
  },
  "ingrain": {
    intro: "扎根（日文︰ねをはる，英文︰Ingrain）是第三世代引入的草属性招式。",
    description: "在大地上扎根，每回合回复自己的HP。因为扎根了，所以不能替换宝可梦。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：扎根（状态）\n主页面：地面上的宝可梦\n使自己进入扎根状态。处于扎根状态下的宝可梦无法替换下场，在回合结束时会回复满HP的1⁄16，同时会被视为地面上的宝可梦。",
    range: "自身"
  },
  "instruct": {
    description: "向对手下达指示，让其再次使出刚才的招式。"
  },
  "ion-deluge": {
    description: "将带电粒子扩散开来，使一般属性的招式变成电属性。"
  },
  "iron-defense": {
    intro: "铁壁（日文︰てっぺき，英文︰Iron Defense）是第三世代引入的钢属性招式。",
    description: "将皮肤变得坚硬如铁，从而大幅提高自己的防御。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令使用者的防御提升2级。",
    range: "自身"
  },
  "iron-head": {
    description: "用钢铁般坚硬的头部进行攻击。有时会使对手畏缩。"
  },
  "iron-tail": {
    intro: "铁尾（日文︰アイアンテール，英文︰Iron Tail）是第二世代引入的钢属性招式。",
    description: "使用坚硬的尾巴摔打对手进行攻击。有时会降低对手的防御。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n30%几率令目标的防御降低1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "ivy-cudgel": {
    description: "用缠有藤蔓的棍棒殴打。属性会随所戴的面具而改变。容易击中要害。"
  },
  "jaw-lock": {
    description: "使双方直到一方昏厥为止无法替换宝可梦。其中一方退场则可以解除效果。"
  },
  "jet-punch": {
    description: "将激流覆盖于拳头，以肉眼无法辨识的速度打出拳击。必定能够先制攻击。"
  },
  "judgment": {
    description: "向对手放出无数的光弹。属性会根据自己携带的石板不同而改变。"
  },
  "jump-kick": {
    intro: "这篇文章讲述的是威力100的格斗招式，不是飞膝踢。",
    description: "使出高高的腾空踢攻击对手。如果踢偏则自己会受到伤害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n如果招式未命中、被守住状态阻挡，因为属性相性或特性而没有产生效果，自身承受最大HP的1⁄2（向下取整）的反作用力伤害。\n使用者具有魔法防守特性时，招式没有产生效果时使用者不会承受伤害。\n使用者具有舍身特性时，该招式威力提升20%。\n\n如果场上存在重力作用，则无法使用该招式。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "jungle-healing": {
    description: "与丛林融为一体，回复自己和场上同伴的HP和状态。"
  },
  "karate-chop": {
    intro: "空手劈（日文︰からてチョップ，英文︰Karate Chop）是第一世代引入的格斗属性招式。",
    description: "用锋利的手刀劈向对手进行攻击。容易击中要害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。击中要害率比大部分招式高1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "kinesis": {
    intro: "这篇文章讲述的是一种招式。如果您在寻找一种道具，请移步弯曲的汤匙（道具）。\n这篇文章讲述的是一种招式。如果您在寻找宝可梦特别篇一种原创的特殊道具，请移步命运的折弯汤匙。",
    description: "折弯汤匙引开注意，从而降低对手的命中率。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令目标的命中率降低1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "knock-off": {
    intro: "这篇文章讲述的是第三世代引入的恶属性招式。如果您在寻找第五世代引入的岩石属性招式，请移步击落（招式）。",
    description: "拍落对手的持有物，直到战斗结束都不能使用。对手携带道具时会增加伤害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "主页面：拍落（状态）\n攻击目标造成伤害。\n如果目标持有可被拍落的携带物品，则目标在战斗结束前失去其携带物品，且本次攻击的威力×1.5。\n以下携带物品不可被拍落：\n特性为多属性的宝可梦携带的物品第四世代\n可使携带者进行超级进化的超级石\n固拉多携带的朱红色宝珠\n盖欧卡携带的靛蓝色宝珠\n帝牙卢卡携带的大金刚宝玉\n帕路奇亚携带的大白宝玉\n骑拉帝纳携带的大白金宝玉\n阿尔宙斯携带的石板\n盖诺赛克特携带的卡带\nＺ纯晶\n银伴战兽携带的存储碟\n苍响携带的腐朽的剑\n藏玛然特携带的腐朽的盾\n大部分悖谬宝可梦携带的驱劲能量\n乐园守护龙除外。\n破空焰、猛雷鼓、铁头壳和铁磐岩携带的驱劲能量也可以被拍落。\n厄诡椪携带的面具\n如果目标携带以上不可被拍落的道具，则威力加成不适用。\n当目标宝可梦携带以下道具时，招式令目标失去携带道具的效果会先于道具效果触发：\n文柚果、勿花果、枝荔果等HP低于一定比例后触发的树果，亚开果\n树果汁\n红牌、逃脱按键、白色香草、模仿香草、避难背包\n谜芝果、嘉珍果第四世代及以前\n如果目标携带以上道具，招式攻击时这些道具的效果不会发动。\n当目标宝可梦携带以下道具时，道具效果会先于招式令目标失去携带道具的效果触发：\n直接参与伤害计算的道具：\n进化奇石、金属粉、奇妙空间下的突击背心等改变目标防御的道具。\n当恶属性招式对目标效果绝佳时的刺耳果\n当招式受使用者一般皮肤特性下变为一般属性时的灯浆果\n当招式受使用者一般皮肤特性下变为一般属性后，受等离子浴或输电效果变为电属性对目标效果绝佳时的烛木果\n气势披带\n若招式未能触发道具效果，目标会因招式效果失去携带物品。\n气势头带\n道具判定触发后，目标会因招式效果失去携带物品。\n谜芝果第五世代后、弱点保险\n如果攻击造成目标陷入昏厥状态，目标会因招式效果失去携带物品。\n若招式对目标并非效果绝佳，目标会因招式效果失去携带物品。\n嘉珍果第五世代后\n如果使用者拥有魔法防守特性，嘉珍果的效果不会触发，目标会因招式效果失去携带物品。\n凸凸头盔\n道具效果触发后，目标会因招式效果失去携带物品。\n如果攻击造成目标陷入昏厥状态，目标不会因招式效果失去携带物品。\n附着针\n如果因使用者拥有道具等情况附着针无法转移到使用者上，目标会因招式效果失去携带物品。\n气球\n目标受到招式伤害后，气球就会爆炸消失。目标无法因招式效果失去携带物品。\n充电电池\n招式变为电属性后，目标的充电电池会触发效果而消耗掉。目标无法因招式效果失去携带物品。\n即使由于这些道具被消耗等原因而未能令目标失去携带道具，威力加成仍然适用。\n招式的效果不是追加效果。\n招式命中拥有鳞粉特性或携带密探斗篷的目标，目标会正常失去其携带物品。\n如果使用者拥有强行特性，特性不会发动效果，招式命中的目标会正常失去其携带物品。\n如果拍落命中目标的替身或拥有黏着特性的目标，则招式只会造成伤害，目标不会失去其携带物品，但威力加成仍然适用。\n如果攻击造成拥有黏着特性的目标陷入昏厥状态，目标会正常失去其携带物品。\n如果目标拥有轻装特性，招式令目标失去其携带物品后，目标的轻装特性会发动。\n目标发动特性后交换下场后再次上场，再次受到拍落目标的轻装特性也不会发动。\n如果招式伤害被目标的画皮、结冻头所防住，目标也会失去其携带物品。\n如果使用者因目标的铁刺特性、粗糙皮肤特性或凸凸头盔而陷入昏厥状态，则目标不会失去其携带物品，但威力加成仍然适用。\n如果使用者因自身携带的生命宝珠而陷入昏厥状态，目标会正常失去其携带物品。\n如果使用者拥有魔术师特性，则目标首先失去其携带物品，魔术师特性因而不会发动。\n如果目标拥有笨拙特性，或受到查封、魔法空间状态影响，目标会正常失去其携带物品，威力加成仍然适用。\n目标失去的携带物品在战斗结束后还原。\n野生宝可梦无法通过拍落使玩家的宝可梦失去携带物品。\n拍落在极巨团体战中会使用失败，既无法拍落道具，又无法造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "kowtow-cleave": {
    description: "下跪让对手大意后发起袭击劈向对手。攻击必定会命中。"
  },
  "laser-focus": {
    description: "集中精神，下次攻击必定会击中要害。"
  },
  "lash-out": {
    description: "攻击对手以发泄对其感到的恼怒情绪。如果在该回合内自身能力遭到降低，招式的威力会变成2倍。"
  },
  "last-resort": {
    description: "当战斗中已学会的招式全部使用过后，才能开始使出珍藏的招式。"
  },
  "last-respects": {
    description: "为了化解伙伴的悔恨而进行攻击。被打倒的我方宝可梦越多，招式的威力越高。"
  },
  "lava-plume": {
    description: "用熊熊烈火攻击自己周围所有的宝可梦。有时会陷入灼伤状态。"
  },
  "leaf-blade": {
    intro: "叶刃（日文︰リーフブレード，英文︰Leaf Blade）是第三世代引入的草属性招式。",
    description: "像用剑一般操纵叶片切斩对手进行攻击。容易击中要害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。击中要害率比大部分招式高1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "leaf-storm": {
    description: "用尖尖的叶片向对手卷起风暴。使用之后因为反作用力自己的特攻会大幅降低。"
  },
  "leaf-tornado": {
    description: "用锋利的叶片包裹住对手进行攻击。有时会降低对手的命中率。"
  },
  "leafage": {
    description: "将叶片打向对手，进行攻击。"
  },
  "leech-life": {
    intro: "汲取（日文︰きゅうけつ，英文︰Leech Life）是第一世代引入的虫属性招式。",
    description: "吸取血液攻击对手。可以回复给予对手伤害的一半HP。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，自身的HP恢复“造成的伤害×50%”。在攻击方携带大根茎时，攻击伤害不变，HP恢复量提高到“造成的伤害×65%”。\n如果攻击方处于回复封锁状态，招式使用失败。\n使用汲取攻击替身状态下的宝可梦可以恢复HP。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "leech-seed": {
    intro: "寄生种子（日文︰やどりぎのタネ，英文︰Leech Seed）是第一世代引入的草属性招式。",
    description: "植入寄生种子后，将在每回合一点一点吸取对手的HP，从而用来回复自己的HP。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：寄生种子（状态）\n使目标宝可梦陷入寄生种子状态，对草属性宝可梦及拥有食草特性的宝可梦无效。处于寄生种子状态的宝可梦每回合结束时损失1⁄8的最大HP，同时该状态的施放者恢复等量的HP。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "leer": {
    intro: "瞪眼（日文︰にらみつける，英文︰Leer）是第一世代引入的一般属性招式。",
    description: "用犀利的眼神使其害怕，从而降低对手的防御。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令目标的防御降低1级。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "lick": {
    intro: "舌舔（日文︰したでなめる，英文︰Lick）是第一世代引入的幽灵属性招式。",
    description: "用长长的舌头，舔遍对手进行攻击。有时会让对手陷入麻痹状态。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n舌舔有30%的几率使目标陷入麻痹状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "life-dew": {
    description: "喷洒出神奇的水，回复自己和场上同伴的HP。"
  },
  "light-screen": {
    intro: "光墙（日文︰ひかりのかべ，英文︰Light Screen）是第一世代引入的超能力属性招式。",
    description: "利用神奇的墙壁，在5回合内减弱从对手那里受到的特殊攻击的伤害。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：光墙（状态）\n在己方队伍筑起光墙，5回合内处于光墙保护下的宝可梦受到的特殊招式伤害减半。如果己方场上存在多只宝可梦则减轻三分之一。",
    range: "我方场地"
  },
  "liquidation": {
    description: "用水之力量撞向对手进行攻击。有时会降低对手的防御。"
  },
  "lock-on": {
    intro: "锁定（日文︰ロックオン，英文︰Lock-On）是第二世代引入的一般属性招式。",
    description: "紧紧瞄准对手，下次攻击必定会打中。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：锁定（状态）\n使目标陷入锁定状态，下回合对目标的攻击必定命中。\n锁定一定会命中，除非目标正在使用蓄力的招式并不在场地上。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "lovely-kiss": {
    intro: "恶魔之吻（日文︰あくまのキッス，英文︰Lovely Kiss）是第一世代引入的一般属性招式。",
    description: "用恐怖的脸强吻对手。让对手陷入睡眠状态。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "恶魔之吻会使目标陷入睡眠状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "low-kick": {
    intro: "这篇文章讲述的是第一世代引入的招式，不是下盘踢。",
    description: "用力踢对手的脚，使其摔倒进行攻击。对手越重，威力越大。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。对手的体重越高，招式威力越高。\n对极巨化的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "low-sweep": {
    description: "以敏捷的动作瞄准对手的脚进行攻击。会降低对手的速度。"
  },
  "lucky-chant": {
    description: "向天许愿，从而在5回合内不会被对手的攻击打中要害。"
  },
  "lumina-crash": {
    description: "放出连精神都能影响到的奇妙怪光进行攻击。会大幅降低对方的特防。"
  },
  "lunar-blessing": {
    description: "向新月献上祈祷，回复自己和场上同伴的HP和状态。"
  },
  "lunar-dance": {
    description: "虽然自己陷入昏厥，但可以治愈后备上场的宝可梦的全部状态。"
  },
  "lunge": {
    description: "全力猛扑对手进行攻击。从而降低对手的攻击。"
  },
  "luster-purge": {
    intro: "洁净光芒（日文︰ラスターパージ，英文︰Luster Purge）是第三世代引入的超能力属性招式。",
    description: "释放耀眼的光芒进行攻击。有时会降低对手的特防。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n50%几率令目标的特防降低1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "mach-punch": {
    intro: "音速拳（日文︰マッハパンチ，英文︰Mach Punch）是第二世代引入的格斗属性招式。",
    description: "以迅雷不及掩耳之势出拳。必定能够先制攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "magic-coat": {
    intro: "魔法反射（日文︰マジックコート，英文︰Magic Coat）是第三世代引入的超能力属性招式。",
    description: "当对手使出会变成异常状态的招式或寄生种子等时，会将对手的招式反射回去。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：魔法反射（状态）\n当回合内进入魔法反射状态，将对方以自身为目标的部分变化招式无效化，并反弹给招式的使用者。\n如果本回合内自身最后行动并选择使用此招式，则招式会失败。",
    range: "自身"
  },
  "magic-powder": {
    description: "向对手喷洒魔法粉，使对手变为超能力属性。"
  },
  "magic-room": {
    description: "制造出离奇的空间。在5回合内所有宝可梦携带道具的效果都会消失。"
  },
  "magical-leaf": {
    intro: "魔法叶（日文︰マジカルリーフ，英文︰Magical Leaf）是第三世代引入的草属性招式。",
    description: "散落可以追踪对手的神奇叶片。攻击必定会命中。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n魔法叶一定会命中，除非目标正在使用蓄力的招式并不在场地上。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "magma-storm": {
    description: "将对手困在熊熊燃烧的火焰中，在4～5回合内进行攻击。"
  },
  "magnet-bomb": {
    description: "发射吸住对手的钢铁炸弹。攻击必定会命中。"
  },
  "magnet-rise": {
    description: "利用电气产生的磁力浮在空中。在5回合内可以飘浮。"
  },
  "magnetic-flux": {
    description: "通过操控磁场，会提高特性为正电和负电的宝可梦的防御和特防。"
  },
  "magnitude": {
    intro: "震级（日文︰マグニチュード，英文︰Magnitude）是第二世代引入的地面属性招式。",
    description: "晃动地面，攻击自己周围所有的宝可梦。招式的威力会有各种变化。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n如果目标处于挖洞状态，威力翻倍。\n招式威力在10～150中随机变化，数学期望为71。\n可以击中处于挖洞状态的宝可梦。\n场地处于青草场地时威力下降50%。",
    range: "除自身以外场上全部可以攻击到的宝可梦"
  },
  "make-it-rain": {
    description: "扔出大量硬币攻击。自己的特攻会降低，战斗后还可以拿到钱。"
  },
  "malignant-chain": {
    description: "用由毒形成的锁链缠住对手注入毒素加以侵蚀。有时会让对手陷入剧毒状态。"
  },
  "mat-block": {
    description: "将掀起来的榻榻米当作盾牌，防住自己和同伴免受招式伤害。变化招式无法防住。"
  },
  "matcha-gotcha": {
    description: "发射经搅拌的茶的大炮，可以回复给予对手伤害的一半HP，有时会让对手陷入灼伤状态。"
  },
  "me-first": {
    description: "提高威力，抢先使出对手想要使出的招式。如果不先使出则会失败。"
  },
  "mean-look": {
    intro: "黑色目光（日文︰くろいまなざし，英文︰Mean Look）是第二世代引入的一般属性招式。",
    description: "用好似要勾人心魂的黑色目光一动不动地凝视对手，使其不能从战斗中逃走。",
    effect: ["不是接触类招式", "不受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：无法逃走（状态）\n使目标陷入无法逃走状态。处于无法逃走状态的宝可梦不能换下。\n黑色目光一定会命中，除非目标正在使用蓄力的招式并不在场地上。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "meditate": {
    intro: "瑜伽姿势（日文︰ヨガのポーズ，英文︰Meditate）是第一世代引入的超能力属性招式。",
    description: "唤醒身体深处沉睡的力量，从而提高自己的攻击。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令使用者的攻击提升1级。",
    range: "自身"
  },
  "mega-drain": {
    intro: "超级吸取（日文︰メガドレイン，英文︰Mega Drain）是第一世代引入的草属性招式。",
    description: "吸取对手的养分进行攻击。可以回复给予对手伤害的一半HP。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，自身的HP恢复“造成的伤害×50%”。在攻击方携带大根茎时，攻击伤害不变，HP恢复量提高到“造成的伤害×65%”。\n如果攻击方处于回复封锁状态，招式使用失败。\n使用超级吸取攻击替身状态下的宝可梦可以恢复HP。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "mega-kick": {
    intro: "百万吨重踢（日文︰メガトンキック，英文︰Mega Kick）是第一世代引入的一般属性招式。",
    description: "使出力大无穷的重踢踢飞对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "mega-punch": {
    intro: "百万吨重拳（日文︰メガトンパンチ，英文︰Mega Punch）是第一世代引入的一般属性招式。",
    description: "用充满力量的拳头攻击对手。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "megahorn": {
    intro: "超级角击（日文︰メガホーン，英文︰Megahorn）是第二世代引入的虫属性招式。",
    description: "用坚硬且华丽的角狠狠地刺入对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "memento": {
    intro: "临别礼物（日文︰おきみやげ，英文︰Memento）是第三世代引入的恶属性招式。",
    description: "虽然会使自己陷入昏厥，但是能够大幅降低对手的攻击和特攻。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令目标的攻击降低2级。\n令目标的特攻降低2级。\n使用者陷入昏厥状态，除非此招式没有命中、使用失败或被防住类招式阻挡。\n如果目标处于替身状态，或者对手对该招式免疫（例如恶作剧之心特性的宝可梦对恶系使用该招式），此招式使用失败。但即使该招式无法对对手的能力变化产生效果（例如对手特性为恒净之躯或者对手的攻击与特攻能力变化为-6），招式仍然能够使用成功，使用者陷入昏厥状态。\n对具有魔法镜特性的宝可梦使用的话，此招式不会被反弹。这与抛下狠话的情况不同。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "metal-burst": {
    description: "使出招式前，将最后受到的招式的伤害大力返还给对手。"
  },
  "metal-claw": {
    intro: "金属爪（日文︰メタルクロー，英文︰Metal Claw）是第二世代引入的钢属性招式。",
    description: "用钢铁之爪劈开对手进行攻击。有时会提高自己的攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n10%几率令使用者的攻击提升1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "metal-sound": {
    intro: "金属音（日文︰きんぞくおん，英文︰Metal Sound）是第三世代引入的钢属性招式。",
    description: "让对手听摩擦金属般讨厌的声音。大幅降低对手的特防。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令目标的特防降低2级。\n对隔音特性的宝可梦无效。\n该招式无视目标的替身状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "meteor-assault": {
    description: "大力挥舞粗壮的茎进行攻击。但同时自己也会被晃晕，下一回合自己将无法动弹。"
  },
  "meteor-beam": {
    description: "第1回合聚集宇宙之力提高特攻，第2回合攻击对手。"
  },
  "meteor-mash": {
    intro: "彗星拳（日文︰コメットパンチ，英文︰Meteor Mash）是第三世代引入的钢属性招式。",
    description: "使出彗星般的拳头攻击对手。有时会提高自己的攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n20%几率令使用者的攻击提升1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "metronome": {
    intro: "挥指（日文︰ゆびをふる，英文︰Metronome）是第一世代引入的一般属性招式。",
    description: "挥动手指刺激自己的大脑，从许多的招式中随机使出1个。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "在几乎所有招式中随机选择1个招式并使用。\n第一世代，会从除了挥指本身和挣扎外的所有招式中以均等概率选择1个招式并使用；\n第二至第八世代，会先排除掉以下所有不能被选择的招式后，从剩下的招式中以均等的概率随机选择1个并使用；\n第九世代起，会循环从所有招式中以均等概率选择1个招式，直到选择到可被使用的招式为止。如果循环次数超过500次，将使用拍击。\n该招式不可以被模仿复制，也不会被借助或梦话发动。\n己方最后使用的招式是挥指时，以自己为目标的再来一次使用失败。\n使用挥指使出恢复HP的招式时，将无视回复封锁的影响恢复HP。\n携带节拍器的宝可梦使用挥指，若连续选择到相同的招式，威力提升。\n当将挥指变为Ｚ招式后，如果是攻击招式，则将攻击招式变为对应的Ｚ招式；若为变化招式，则将出现的变化招式变为对应的Ｚ招式，但没有任何效果。",
    range: "自身"
  },
  "mighty-cleave": {
    description: "用积蓄在头部的光来斩切对手。可以无视守护进行攻击。"
  },
  "milk-drink": {
    intro: "喝牛奶（日文︰ミルクのみ，英文︰Milk Drink）是第二世代引入的一般属性招式。",
    description: "回复自己最大HP的一半。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响", "可以在对战外使用"],
    range: "自身"
  },
  "mimic": {
    intro: "这篇文章讲述的是第一世代引入的招式。如果您在寻找第四世代引入的招式，请移步仿效。",
    description: "可以将对手最后使用的招式，在战斗内变成自己的招式。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "mind-blown": {
    description: "让自己的头爆炸，来攻击周围的一切。自己也会受到伤害。"
  },
  "mind-reader": {
    intro: "心之眼（日文︰こころのめ，英文︰Mind Reader）是第二世代引入的一般属性招式。",
    description: "用心感受对手的行动，下次攻击必定会击中对手。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：锁定（状态）\n使目标陷入锁定状态，下回合对目标的攻击必定命中。\n心之眼一定会命中，除非目标正在使用蓄力的招式并不在场地上。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "minimize": {
    intro: "变小（日文︰ちいさくなる，英文︰Minimize）是第一世代引入的一般属性招式。",
    description: "蜷缩身体显得很小，从而大幅提高自己的闪避率。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：变小（状态）\n令使用者的闪避率提升2级。同时令使用者进入变小状态。",
    range: "自身"
  },
  "miracle-eye": {
    description: "使出后对恶属性宝可梦没有效果的招式以及闪避率高的对手，变得能够打中。"
  },
  "mirror-coat": {
    intro: "镜面反射（日文︰ミラーコート，英文︰Mirror Coat）是第二世代引入的超能力属性招式。",
    description: "从对手那里受到特殊攻击的伤害将以2倍返还给同一个对手。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "对最后造成自身伤害对应位置的宝可梦为目标，造成受到的特殊招式×2倍固定伤害。该招式无法对没有效果的属性的宝可梦造成伤害，但忽略其它属性相克和属性一致加成。\n对于多次攻击类招式，仅使用最后一击的伤害计算镜面反射的伤害。\n镜面反射的攻击目标会受万众瞩目状态的影响。\n在三打对战中，镜面反射可以攻击到对侧的宝可梦，但它不算是远程招式，因为在使用招式时只能选择自己作为目标。\n当回合所有对手都没有使用过特殊招式攻击到使用者时，招式使用失败。\n该招式不会被借助或挥指发动。",
    range: "取决于招式的具体效果"
  },
  "mirror-move": {
    intro: "鹦鹉学舌（日文︰オウムがえし，英文︰Mirror Move）是第一世代引入的飞行属性招式。",
    description: "模仿对手使用的招式，自己也使用相同招式。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "使用目标最后使用过的招式。\n这个招式无法被梦话、借助和挥指使出。\n无法使出以下招式：\n挣扎\n喷出\n真气拳\n模仿、写生、变身和鹦鹉学舌\n自我暗示\n扮演、纹理2和镜面属性\n力量平分和防守平分\n预知未来和破灭之愿\n双倍奉还、镜面反射和忍耐\n搏命\n治愈波动\n替身\n击掌奇袭\n使出的招式目标为单体选择时，目标为鹦鹉学舌的招式目标。\n作用范围为自身的招式、作用范围为自身和同伴的招式、作用范围为对手场地的招式、作用范围为全部场地的招式除了戏法空间、奇妙空间和魔法空间外无法被使出。\n自身最后使用的招式是鹦鹉学舌时，以自身为目标的再来一次使用失败。\n如果使用该招式的宝可梦的特性为恶作剧之心，招式本身会使用成功，但调用的招式会受到以下影响：\n若对方场上存在拥有女王的威严、鲜艳之躯的宝可梦，调用的招式会使用失败。\n调用的招式会受到快速防守、精神场地的影响。\n在第七世代，调用的招式对对方的恶属性宝可梦无效，无论调用的招式是变化招式、物理招式还是特殊招式。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "mirror-shot": {
    description: "抛光自己的身体，向对手释放出闪光之力。有时会降低对手的命中率。"
  },
  "mist": {
    intro: "白雾（日文︰しろいきり，英文︰Mist）是第一世代引入的冰属性招式。",
    description: "用白雾覆盖身体。在5回合内不会让对手降低自己的能力。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：白雾（状态）\n使己方场地在5回合内处于白雾状态。处于白雾状态的场地上的宝可梦的能力变化不会被其他宝可梦下降。",
    range: "我方场地"
  },
  "mist-ball": {
    intro: "薄雾球（日文︰ミストボール，英文︰Mist Ball）是第三世代引入的超能力属性招式。",
    description: "用围绕着雾状羽毛的球进行攻击。有时会降低对手的特攻。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n50%几率令目标的特攻降低1级。\n对防弹特性的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "misty-explosion": {
    description: "对自己周围的所有宝可梦进行攻击，但使出后，自己会陷入昏厥。在薄雾场地上，招式威力会提高。"
  },
  "misty-terrain": {
    description: "在5回合内，地面上的宝可梦不会陷入异常状态。龙属性招式的伤害也会减半。"
  },
  "moonblast": {
    description: "借用月亮的力量攻击对手。有时会降低对手的特攻。"
  },
  "moongeist-beam": {
    description: "放出奇怪的光线攻击对手。可以无视对手的特性进行攻击。"
  },
  "moonlight": {
    intro: "月光（日文︰つきのひかり，英文︰Moonlight）是第二世代引入的妖精属性招式。",
    description: "回复自己的HP。根据天气的不同，回复量也会有所变化。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "月光能够回复使用者HP。回复量由当前天气型状态决定。\n在大晴天和大日照状态下，回复使用者最大HP的2⁄3。\n在没有或其他天气型状态时，回复使用者最大HP的1⁄2。在下雨、大雨、沙暴、冰雹、下雪或起雾状态下，回复使用者最大HP的1⁄4。在使用者处于回复封锁状态时无法使用。",
    range: "自身"
  },
  "morning-sun": {
    intro: "晨光（日文︰あさのひざし，英文︰Morning Sun）是第二世代引入的一般属性招式。",
    description: "回复自己的HP。根据天气的不同，回复量也会有所变化。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "晨光能够回复使用者HP。回复量由当前天气型状态决定。\n在大晴天和大日照状态下，回复使用者最大HP的2⁄3。\n在没有或其他天气型状态时，回复使用者最大HP的1⁄2。在下雨、大雨、沙暴、冰雹、下雪或起雾状态下，回复使用者最大HP的1⁄4。在使用者处于回复封锁状态时无法使用。",
    range: "自身"
  },
  "mortal-spin": {
    description: "通过旋转来攻击对手。可以摆脱绑紧、紧束、寄生种子等招式。还能让对手陷入中毒状态。"
  },
  "mud-bomb": {
    description: "向对手发射坚硬的泥弹进行攻击。有时会降低对手的命中率。"
  },
  "mud-shot": {
    intro: "泥巴射击（日文︰マッドショット，英文︰Mud Shot）是第三世代引入的地面属性招式。",
    description: "向对手投掷泥块进行攻击。同时降低对手的速度。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n100%几率令目标的速度降低1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "mud-slap": {
    intro: "掷泥（日文︰どろかけ，英文︰Mud-Slap）是第二世代引入的地面属性招式。",
    description: "向对手的脸等投掷泥块进行攻击。会降低对手的命中率。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n令目标的命中率降低1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "mud-sport": {
    intro: "玩泥巴（日文︰どろあそび，英文︰Mud Sport）是第三世代引入的地面属性招式。",
    description: "一旦使用此招式，周围就会弄得到处是泥。在5回合内减弱电属性的招式。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：玩泥巴（状态）\n使场地进入玩泥巴状态，降低电属性招式的威力。",
    range: "全部场地"
  },
  "muddy-water": {
    intro: "浊流（日文︰だくりゅう，英文︰Muddy Water）是第三世代引入的水属性招式。",
    description: "向对手喷射浑浊的水进行攻击。有时会降低对手的命中率。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n30%几率令目标的命中率降低1级。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "multi-attack": {
    description: "一边覆盖高能量，一边撞向对手进行攻击。根据存储碟不同，属性会改变。"
  },
  "mystical-fire": {
    description: "从口中喷出特别灼热的火焰进行攻击。降低对手的特攻。"
  },
  "mystical-power": {
    description: "放出不可思议的力量攻击。会提高自己的特攻。"
  },
  "nasty-plot": {
    description: "谋划诡计，激活头脑。大幅提高自己的特攻。"
  },
  "natural-gift": {
    description: "从树果上获得力量进行攻击。根据携带的树果，招式属性和威力会改变。"
  },
  "nature-power": {
    intro: "自然之力（日文︰しぜんのちから，英文︰Nature Power）是第三世代引入的一般属性招式。",
    description: "用自然之力进行攻击。根据所使用场所的不同，使出的招式也会有所变化。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：战斗场所\n根据使用场所的不同使用另一个招式。\n当场上有场地型状态时，场地型状态的效果覆盖战斗场所的效果，对应使出的招式变化如下：",
    range: "取决于招式的具体效果"
  },
  "needle-arm": {
    intro: "尖刺臂（日文︰ニードルアーム，英文︰Needle Arm）是第三世代引入的草属性招式。",
    description: "用带刺的手臂猛烈地挥舞进行攻击。有时会使对手畏缩。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n尖刺臂有30%的几率使尚未行动的目标陷入畏缩状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "night-daze": {
    description: "放出黑暗的冲击波攻击对手。有时会降低对手的命中率。"
  },
  "night-shade": {
    intro: "黑夜魔影（日文︰ナイトヘッド，英文︰Night Shade）是第一世代引入的幽灵属性招式。",
    description: "显示恐怖幻影，只给予对手和自己等级相同的伤害。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "对目标造成与使用者等级相同的伤害。该招式无法对没有效果的属性的宝可梦造成伤害，但忽略其它属性相克和属性一致加成。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "night-slash": {
    description: "抓住瞬间的空隙切斩对手。容易击中要害。"
  },
  "nightmare": {
    intro: "这篇文章讲述的是曾译为梦魇的幽灵属性招式。如果您在寻找中文译名相同的宝可梦特性，请移步梦魇（特性）。\nNightmare重定向至此。如果您在寻找英文译名相同的不可思议迷宫，请移步恶梦之中。",
    description: "让在睡眠状态下的对手做恶梦，每回合会缓缓减少HP。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：恶梦（状态）\n使目标陷入恶梦状态。如果目标没有处于睡眠状态，则招式使用失败。处于恶梦状态的宝可梦在每个回合结束时损失最大HP的1⁄4。\n该招式不受属性相性影响。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "no-retreat": {
    description: "提高自己的所有能力，但无法替换或逃走。"
  },
  "noble-roar": {
    description: "发出战吼威吓对手，从而降低对手的攻击和特攻。"
  },
  "nuzzle": {
    description: "将带电的脸颊蹭蹭对手进行攻击。让对手陷入麻痹状态。"
  },
  "oblivion-wing": {
    description: "从锁定的对手身上吸取HP。回复给予对手伤害的一半以上的HP。"
  },
  "obstruct": {
    description: "完全抵挡对手的攻击。连续使出则容易失败。一旦触碰，防御就会大幅降低。"
  },
  "octazooka": {
    intro: "章鱼桶炮（日文︰オクタンほう，英文︰Octazooka）是第二世代引入的水属性招式。",
    description: "向对手的脸等喷出墨汁进行攻击。有时会降低对手的命中率。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n50%几率令目标的命中率降低1级。\n对防弹特性的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "octolock": {
    description: "让对手无法逃走。对手被固定后，每回合都会降低防御和特防。"
  },
  "odor-sleuth": {
    intro: "气味侦测（日文︰かぎわける，英文︰Odor Sleuth）是第三世代引入的一般属性招式。",
    description: "使出后对幽灵属性宝可梦没有效果的招式以及闪避率高的对手，变得能够打中。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：被识破（状态）\n使目标陷入被识破状态。处于被识破状态的宝可梦闪避率提升无效，可以受到一般属性和格斗属性招式的攻击。\n气味侦测一定会命中，除非目标正在使用蓄力的招式并不在场地上。\n如果目标已经处于被识破状态，招式使用失败。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "ominous-wind": {
    description: "突然刮起毛骨悚然的暴风攻击对手。有时会提高自己的全部能力。"
  },
  "order-up": {
    description: "以潇洒的身手进行攻击。若口中有米立龙，会按其样子提高能力。"
  },
  "origin-pulse": {
    description: "用无数青白色且闪耀的光线攻击对手。"
  },
  "outrage": {
    intro: "逆鳞（日文︰げきりん，英文︰Outrage）是第二世代引入的龙属性招式。",
    description: "在2～3回合内，乱打一气地进行攻击。大闹一番后自己会陷入混乱。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击随机一位对手造成伤害。\n使用者进入2～3回合逆鳞状态，期间会继续使用逆鳞进行攻击，无法使用其他招式、使用道具、替换宝可梦或逃走。\n因梦话而使用时，不进入逆鳞状态。\n因守住状态、未命中、属性相性无效等原因而没有产生效果，则解除逆鳞状态。\n逆鳞状态因回合经过解除时，使用者陷入混乱状态。\n神秘守护不会避免该招式带来的混乱。\n后续回合的攻击不消耗PP。",
    range: "随机一只对手"
  },
  "overdrive": {
    description: "奏响吉他和贝斯，释放出发出巨响的剧烈震动攻击对手。"
  },
  "overheat": {
    intro: "这篇文章讲述的是第三世代引入的招式，不是烧净或燃尽。",
    description: "使出全部力量攻击对手。使用之后会因为反作用力，自己的特攻大幅降低。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n令使用者的特攻降低2级。\n如果攻击无效或没有命中，不会产生该效果。\n使用者的白雾、替身或白色烟雾等无法阻止过热的该副作用。\n强行、不服输、好胜对过热的该副作用无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "pain-split": {
    intro: "分担痛楚（日文︰いたみわけ，英文︰Pain Split）是第二世代引入的一般属性招式。",
    description: "将自己的HP和对手的HP相加，然后自己和对手友好地平分。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "将使用者的HP与目标的HP相加之后取其算术平均数，相加时不计算极巨化的影响。\nHP较高的一方HP降低超过平均数的部分，HP较低的一方HP增加不足平均数的部分。\n分担痛楚一定会命中，除非目标正在使用蓄力的招式并不在场地上。\n如果目标为替身状态，招式使用失败。\n分担痛楚不造成伤害，因此不会触发任何与伤害有关的判定。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "parabolic-charge": {
    description: "给周围全体宝可梦造成伤害。可以回复给予伤害的一半HP。"
  },
  "parting-shot": {
    description: "抛下狠话威吓对手，降低攻击和特攻后，和后备宝可梦进行替换。"
  },
  "pay-day": {
    intro: "聚宝功（日文︰ネコにこばん，英文︰Pay Day）是第一世代引入的一般属性招式。",
    description: "向对手的身体投掷小金币进行攻击。战斗后可以拿到钱。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。每使用一次这个招式，向地上投掷5×使用者等级的金币。\n如果己方在对战中获胜，拾取这些金币（单次对战中最多拾取$99999）。\n己方使用强制拉对手的后备宝可梦上场的招式（如龙尾、吼叫）结束野生宝可梦战斗后也会拾取金币。\n下列情况无法拾取金币：\n野生宝可梦逃跑或瞬间移动。\n野生宝可梦使用强制拉对手的后备宝可梦上场的招式结束战斗。\n野生宝可梦被捕捉。\n连接对战、对战设施、极巨团体战、太晶团体战。\n护符金币和幸运薰香、欢乐时光、零花钱之力对聚宝功收集的金币有效，对战后会和奖金一起增加。\n零花钱碰碰对聚宝功收集的金币没有效果。\n双方使用的聚宝功分开计算。己方的多只宝可梦使用的聚宝功投掷的金币最后全部会被己方捡起。如果己方在对战中失败，对方不会拾取己方投掷的金币。\n使用者特性为亲子爱时，只会在第一次攻击后投掷金币。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "payback": {
    description: "蓄力攻击。如果能在对手之后攻击，招式的威力会变成2倍。"
  },
  "peck": {
    intro: "啄（日文︰つつく，英文︰Peck）是第一世代引入的飞行属性招式。",
    description: "用尖锐的喙或角刺向对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响", "是远程招式"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只宝可梦"
  },
  "perish-song": {
    intro: "终焉之歌（日文︰ほろびのうた，英文︰Perish Song）是第二世代引入的一般属性招式。",
    description: "倾听歌声的宝可梦经过3回合陷入昏厥。替换后效果消失。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响", "是远程招式"],
    additionalEffect: "主页面：终焉之歌（状态）\n使场上所有的宝可梦陷入终焉之歌状态。陷入终焉之歌状态的3回合之后，处于终焉之歌状态的宝可梦陷入昏厥状态。替换后效果消失。\n终焉之歌一定会命中，除非目标正在使用蓄力的招式并不在场地上。",
    range: "全部宝可梦"
  },
  "petal-blizzard": {
    description: "猛烈地刮起飞雪般的落花，攻击周围所有的宝可梦，并给予伤害。"
  },
  "petal-dance": {
    intro: "花瓣舞（日文︰はなびらのまい，英文︰Petal Dance）是第一世代引入的草属性招式。",
    description: "在2～3回合内，散落花瓣攻击对手。之后自己会陷入混乱。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击随机一位对手造成伤害。\n使用者进入2～3回合花瓣舞状态，期间会继续使用花瓣舞进行攻击，无法使用其他招式、使用道具、替换宝可梦或逃走。\n因梦话而使用时，不进入花瓣舞状态。\n因守住状态、未命中、属性相性无效等原因而没有产生效果，则解除花瓣舞状态。\n花瓣舞状态因回合经过解除时，使用者陷入混乱状态。\n神秘守护不会避免该招式带来的混乱。\n后续回合的攻击不消耗PP。",
    range: "随机一只对手"
  },
  "phantom-force": {
    description: "第1回合消失在某处，第2回合攻击对手。可以无视守护进行攻击。"
  },
  "photon-geyser": {
    description: "用光柱来进行攻击。比较自己的攻击和特攻，用数值相对较高的一项给予对方伤害。"
  },
  "pin-missile": {
    intro: "飞弹针（日文︰ミサイルばり，英文︰Pin Missile）是第一世代引入的虫属性招式。",
    description: "向对手发射锐针进行攻击。连续攻击2～5次。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，一回合内连续攻击2～5次。命中时，各有15%的几率攻击5或4次，35%的几率攻击3或2次，攻击次数的数学期望是3.1次，对应的威力的数学期望是77.5。\n携带机变骰子且命中时，各有1⁄2的几率攻击5或4次，攻击次数的数学期望是4.5次，对应的威力的数学期望是112.5。\n每一击击中要害的概率都相等。\n如果某一下触发了目标的气势披带、气势头带、结实特性或打破了替身，招式会继续攻击。\n忍耐、金属爆炸和双倍奉还只计算最后一次的伤害。\n如果使用者持有王者之证或锐利之牙，或具有恶臭特性，每一下攻击都有相同的概率造成对手畏缩。\n如果目标拥有咒术之躯、碎裂铠甲特性，每一下攻击都会触发效果。即使特性发动令攻击方陷入一些可能无法行动的状态（如麻痹、畏缩、着迷、定身法状态），也不会影响本次攻击，但陷入睡眠和昏厥时攻击即刻停止。\n目标的变色特性在最后一下攻击完成后才发动。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "plasma-fists": {
    description: "用覆盖着电流的拳头进行攻击。使一般属性的招式变成电属性。"
  },
  "play-nice": {
    description: "和对手和睦相处，使其失去战斗的气力，从而降低对手的攻击。"
  },
  "play-rough": {
    description: "与对手嬉闹并攻击。有时会降低对手的攻击。"
  },
  "pluck": {
    description: "用喙进行攻击。当对手携带树果时，可以食用并获得其效果。"
  },
  "poison-fang": {
    intro: "剧毒牙（日文︰どくどくのキバ，英文︰Poison Fang）是第三世代引入的毒属性招式。",
    description: "用有毒的牙齿咬住对手进行攻击。有时会使对手中剧毒。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n剧毒牙有50%的几率使目标陷入剧毒状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "poison-gas": {
    intro: "毒瓦斯（日文︰どくガス，英文︰Poison Gas）是第一世代引入的毒属性招式。",
    description: "将毒瓦斯吹到对手的脸上，从而让对手陷入中毒状态。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "毒瓦斯会使目标陷入中毒状态。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "poison-jab": {
    description: "用带毒的触手或手臂刺入对手。有时会让对手陷入中毒状态。"
  },
  "poison-powder": {
    intro: "毒粉（日文︰どくのこな，英文︰Poison Powder）是第一世代引入的毒属性招式。",
    description: "撒出毒粉，从而让对手陷入中毒状态。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "毒粉会使目标陷入中毒状态。\n对草属性、防尘特性、携带防尘护目镜的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "poison-sting": {
    intro: "这篇文章讲述的是一种招式，不是毒针（道具）或毒刺（特性）。",
    description: "将有毒的针刺入对手进行攻击。有时会让对手陷入中毒状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n毒针有30%的几率使目标陷入中毒状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "poison-tail": {
    intro: "毒尾（日文︰ポイズンテール，英文︰Poison Tail）是第三世代引入的毒属性招式。",
    description: "用尾巴拍打。有时会让对手陷入中毒状态，也容易击中要害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。击中要害率比大部分招式高1级。\n毒尾有10%的几率使目标陷入中毒状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "pollen-puff": {
    description: "对敌人使用是会爆炸的团子。对我方使用则是给予回复的团子。"
  },
  "poltergeist": {
    description: "操纵对手的持有物进行攻击。当对手没有携带道具时，使出此招式时便会失败。"
  },
  "population-bomb": {
    description: "伙伴们会纷纷赶来集合，以群体行动给予对手攻击。连续命中1～10次。"
  },
  "pounce": {
    description: "飞扑向对手攻击。会降低对手的速度。"
  },
  "pound": {
    intro: "拍击（日文︰はたく，英文︰Pound）是第一世代引入的一般属性招式。",
    description: "使用长长的尾巴或手等拍打对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "powder": {
    description: "如果被撒到粉尘的对手使用火招式，则会爆炸并给予伤害。"
  },
  "powder-snow": {
    intro: "细雪（日文︰こなゆき，英文︰Powder Snow）是第二世代引入的冰属性招式。",
    description: "将冰冷的细雪吹向对手进行攻击。有时会让对手陷入冰冻状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n细雪有10%的几率使目标陷入冰冻状态。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "power-gem": {
    description: "发射如宝石般闪耀的光芒攻击对手。"
  },
  "power-split": {
    description: "利用超能力将自己和对手的攻击和特攻相加，再进行平分。"
  },
  "power-swap": {
    description: "利用超能力互换自己和对手的攻击以及特攻的能力变化。"
  },
  "power-trick": {
    description: "利用超能力交换自己的攻击和防御的力量。"
  },
  "power-trip": {
    description: "耀武扬威地攻击对手，自己的能力提高得越多，威力就越大。"
  },
  "power-up-punch": {
    description: "通过反复击打对手，使自己的拳头慢慢变硬。打中对手攻击就会提高。"
  },
  "power-whip": {
    description: "激烈地挥舞青藤或触手摔打对手进行攻击。"
  },
  "precipice-blades": {
    description: "将大地的力量变化为利刃攻击对手。"
  },
  "present": {
    intro: "礼物（日文︰プレゼント，英文︰Present）是第二世代引入的一般属性招式。",
    description: "递给对手设有圈套的盒子进行攻击。也有可能回复对手HP。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "随机选择如下效果。\n平均计算，该招式可以以52点威力攻击对手的同时，治愈其满HP的1⁄20。\n在《金／银》中，有一个相关的漏洞。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "prismatic-laser": {
    description: "用棱镜的力量发射强烈光线。下一回合自己将无法动弹。"
  },
  "protect": {
    intro: "这篇文章讲述的是宝可梦游戏中的招式。如果您在寻找其他关于守住的页面，请移步守住。",
    description: "完全抵挡对手的攻击。连续使出则容易失败。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：守住（状态）\n在当回合内，使自身进入守住状态，保护自身不受到来自其他宝可梦的大部分招式的影响。\n如果在本回合使用者最后行动，则招式会失败。\n若成功使用看穿、挺住、守住、王者盾牌、尖刺防守、碉堡、拦堵、极巨防壁、线阱、火焰守护、掀榻榻米、广域防守或快速防守，则连续使用守住的成功率降低至上一次的1⁄3（最低至1⁄729）。\n若成功使用守住，则连续使用看穿、挺住、守住、王者盾牌、尖刺防守、碉堡、拦堵、极巨防壁、线阱或火焰守护的成功率降低至上一次的1⁄3（最低至1⁄729）。\n即使守住状态被解除，连续使用上述招式的成功率依旧会下降。\n该招式不会被借助或挥指发动。",
    range: "自身"
  },
  "psybeam": {
    intro: "幻象光线（日文︰サイケこうせん，英文︰Psybeam）是第一世代引入的超能力属性招式。",
    description: "向对手发射神奇的光线进行攻击。有时会使对手混乱。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n幻象光线有10%的几率使目标陷入混乱状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "psyblade": {
    description: "用无形的利刃劈开对手。处于电气场地时，招式威力会变成1．5倍。"
  },
  "psych-up": {
    intro: "自我暗示（日文︰じこあんじ，英文︰Psych Up）是第二世代引入的一般属性招式。",
    description: "向自己施以自我暗示，将能力变化的状态变得和对手一样。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "取消自身能力的变化，并复制对手的能力变化。\n自我暗示不受尖刺防守和碉堡影响，但受戏法防守影响。\n自我暗示一定会命中，除非目标正在使用蓄力的招式并不在场地上。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "psychic": {
    intro: "精神强念（日文︰サイコキネシス，英文︰Psychic）是第一世代引入的超能力属性招式。",
    description: "向对手发送强大的念力进行攻击。有时会降低对手的特防。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n10%几率令目标的特防降低1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "psychic-fangs": {
    description: "利用精神力量咬住对手进行攻击。还可以破坏光墙和反射壁等。"
  },
  "psychic-noise": {
    description: "用令对手不舒服的音波进行攻击。让对手在2回合内无法通过招式、特性或携带的道具回复HP。"
  },
  "psychic-terrain": {
    description: "在5回合内，地面上的宝可梦不会受到先制招式的攻击。超能力属性的招式威力会提高。"
  },
  "psycho-boost": {
    description: "使出全部力量攻击对手。使用之后会因为反作用力，自己的特攻大幅降低。"
  },
  "psycho-cut": {
    description: "用实体化的心之利刃劈开对手。容易击中要害。"
  },
  "psycho-shift": {
    description: "利用超能力施以暗示，从而将自己受到的异常状态转移给对手。"
  },
  "psyshield-bash": {
    description: "让意念的能量覆盖全身，撞向对手进行攻击。会提高自己的防御。"
  },
  "psyshock": {
    description: "将神奇的念波实体化攻击对手。给予物理伤害。"
  },
  "psystrike": {
    description: "将神奇的念波实体化攻击对手。给予物理伤害。"
  },
  "psywave": {
    intro: "精神波（日文︰サイコウェーブ，英文︰Psywave）是第一世代引入的超能力属性招式。",
    description: "向对手发射神奇的念波进行攻击。每次使用，伤害都会改变。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "对目标造成使用者等级×（0.5～1.5之间随机值）的伤害。该招式无法对没有效果的属性的宝可梦造成伤害，但忽略其它属性相克和属性一致加成。\n特性为亲子爱的宝可梦使用此招式，两次攻击的随机值判定独立进行，第二次攻击的伤害不会降低。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "punishment": {
    description: "根据能力变化，对手提高的力量越大，招式的威力越大。"
  },
  "purify": {
    description: "治愈对手的异常状态。治愈后可以回复自己的HP。"
  },
  "pursuit": {
    intro: "这篇文章讲述的是对准备替换的目标使用威力会变成2倍的招式。如果您在寻找若此回合内对方受到伤害威力会变成2倍的招式，请移步恶意追击。",
    description: "当对手替换宝可梦上场时使出此招式的话，能够以2倍的威力进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。如果目标在本回合内准备替换下场，则该招式会立刻攻击准备离场的宝可梦（优先于优先度+5的招式），并且威力翻倍：\n即使目标宝可梦具有替身，效果依然会发动，但伤害由替身承担；\n发动特效时无视目标同伴的万众瞩目状态；\n在双打对战及三打对战中，如果追打的攻击范围内对手有多只宝可梦进行替换，则追打无视当前目标，改为攻击要替换的速度最快的宝可梦；\n发动特效时，使用者的生命宝珠、贝壳之铃依旧发动；目标的静电、孢子、毒刺、火焰之躯、迷人之躯、诱爆、咒术之躯、粗糙皮肤、铁刺、木乃伊、碎裂铠甲特性依旧发动；目标的凸凸头盔、进化奇石等道具依旧生效；\n发动特效时，追打一定会命中；但使用者如果处于麻痹、着迷等状态，依旧需要判定是否能够成功使用招式；\n如果追打将一只宝可梦击倒，对方需要在回合结束时重新选择上场的宝可梦；\n对先手使用急速折返、伏特替换、快速折返、抛下狠话离场宝可梦发动特效；\n对使用逃脱按键离场的宝可梦发动特效。\n该招式无法发动特效的情况包括：\n攻击同伴时不发动特效。\n对使用接棒离场的宝可梦不发动特效；\n对触发跃跃欲逃或危险回避特性而离场的宝可梦不发动特效。\n对因为红牌的效果离场的宝可梦不发动特效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "pyro-ball": {
    description: "点燃小石子，形成火球攻击对手。有时会使对手陷入灼伤状态。"
  },
  "quash": {
    description: "压制对手，从而将其行动顺序放到最后。"
  },
  "quick-attack": {
    intro: "电光一闪（日文︰でんこうせっか，英文︰Quick Attack）是第一世代引入的一般属性招式。",
    description: "以迅雷不及掩耳之势扑向对手。必定能够先制攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "quick-guard": {
    description: "守护自己和同伴，以防对手的先制攻击。"
  },
  "quiver-dance": {
    description: "轻巧地跳起神秘而又美丽的舞蹈。提高自己的特攻、特防和速度。"
  },
  "rage": {
    intro: "愤怒（日文︰いかり，英文︰Rage）是第一世代引入的一般属性招式。",
    description: "如果在使出招式后受到攻击的话，会因愤怒的力量而提高攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "主页面：愤怒（状态）\n攻击目标造成伤害。\n在使用该招式后到下次使用者使用招式之前，每受到一次攻击造成的伤害，使用者的攻击能力提升1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "rage-fist": {
    description: "将愤怒化为力量攻击。受到攻击的次数越多，招式的威力越高。"
  },
  "rage-powder": {
    description: "将令人烦躁的粉末撒在自己身上，用以吸引对手的注意。使对手的攻击全部指向自己。"
  },
  "raging-bull": {
    description: "狂怒暴牛的猛烈冲撞。招式的属性随形态改变，光墙和反射壁等招式也能破坏。"
  },
  "raging-fury": {
    description: "在2～3回合内，一边放出火焰，一边疯狂乱打。大闹一番后自己会陷入混乱。"
  },
  "rain-dance": {
    intro: "求雨（日文︰あまごい，英文︰Rain Dance）是第二世代引入的水属性招式。",
    description: "在5回合内一直降雨，从而提高水属性的招式威力。火属性的招式威力则降低。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：下雨（状态）\n包括使用的回合在内，接下来5回合的天气变更为下雨。如果使用者携带了潮湿岩石，持续时间延长为8回合。\n使用该招式会覆盖原本的天气。无论原本的天气是否永续，该招式的效果结束之后天气都会恢复为晴朗。如果当前天气为大雨、大日照、乱流或已经为下雨，招式使用失败。",
    range: "全部场地"
  },
  "rapid-spin": {
    intro: "高速旋转（日文︰こうそくスピン，英文︰Rapid Spin）是第二世代引入的一般属性招式。",
    description: "通过旋转来攻击对手。可以摆脱绑紧、紧束、寄生种子等招式。还能提高自己的速度。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n令使用者的速度提升1级。\n只要此招式成功使出，会移除己方场地上的入场可生效的状态；摆脱自身束缚、寄生种子状态。\n如果招式使用失败，或使用者因目标的凸凸头盔、铁刺、粗糙皮肤等而昏厥，则无法移除和摆脱。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "razor-leaf": {
    intro: "飞叶快刀（日文︰はっぱカッター，英文︰Razor Leaf）是第一世代引入的草属性招式。",
    description: "飞出叶片，切斩对手进行攻击。容易击中要害。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。击中要害率比大部分招式高1级。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "razor-shell": {
    description: "用锋利的贝壳切斩对手进行攻击。有时会降低对手的防御。"
  },
  "razor-wind": {
    intro: "旋风刀（日文︰かまいたち，英文︰Razor Wind）是第一世代引入的一般属性招式。",
    description: "制造风之刃，于第2回合攻击对手。容易击中要害。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "使用旋风刀的宝可梦在第一回合进行蓄力。进行蓄力时的提示为：“[宝可梦的名字]周围的空气产生了旋涡！！”。进行蓄力时不能下达指令。\n在第二回合发动招式。攻击目标造成伤害。击中要害率比大部分招式高1级。\n蓄力的回合会进行行动判定，成功进行蓄力则消耗PP。\n攻击的回合也会进行行动判定，出现不能行动的情况则招式失败。\n在蓄力的回合，消耗携带的强力香草，可以立刻结束蓄力，在当回合发动招式。\n对使用旋风刀的宝可梦（无论当回合是在进行蓄力或进行攻击）使用突袭可以成功。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "recover": {
    intro: "自我再生（日文︰じこさいせい，英文︰Recover）是第一世代引入的一般属性招式。",
    description: "让细胞再生，从而回复自己最大HP的一半。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "自我再生能够回复使用者1⁄2的HP。在使用者处于回复封锁状态时无法使用。",
    range: "自身"
  },
  "recycle": {
    intro: "回收利用（日文︰リサイクル，英文︰Recycle）是第三世代引入的一般属性招式。",
    description: "使战斗中已经消耗掉的自己的持有物再生，并可以再次使用。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "回收在对战中最后消耗的道具。\n如果自身携带有道具，则招式使用失败。\n被替换下场之前消耗的道具，在再次上场之后仍可以被回收。\n因受到攻击而破裂的气球无法被回收。\n通过烧净、啄食、虫咬、渴望、拍落、掉包、小偷或戏法失去的道具无法被回收。\n消耗的道具被同伴或对手捡拾后无法被回收。\n通过投掷消耗的道具可以被回收（除非被捡拾）。",
    range: "自身"
  },
  "reflect": {
    intro: "反射壁（日文︰リフレクター，英文︰Reflect）是第一世代引入的超能力属性招式。",
    description: "利用神奇的墙壁，在5回合内减弱从对手那里受到的物理攻击的伤害。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：反射壁（状态）\n在己方队伍筑起防护墙，5回合内处于反射壁保护下的宝可梦受到的物理招式伤害减半。如果己方场上存在多只宝可梦则减轻三分之一。",
    range: "我方场地"
  },
  "reflect-type": {
    description: "反射对手的属性，让自己也变成一样的属性。"
  },
  "refresh": {
    intro: "焕然一新（日文︰リフレッシュ，英文︰Refresh）是第三世代引入的一般属性招式。",
    description: "让身体休息，治愈自己身上所中的毒、麻痹、灼伤的异常状态。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "消除自身的灼伤、麻痹或中毒状态。",
    range: "自身"
  },
  "relic-song": {
    description: "让对手听古老之歌，打动对手的内心进行攻击。有时会让对手陷入睡眠状态。"
  },
  "rest": {
    intro: "这篇文章讲述的是一个招式。如果您在寻找一种异常状态，请移步睡眠（状态）。",
    description: "连续睡上2回合。回复自己的全部HP以及治愈所有异常状态。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "睡觉能够回复使用者全部的HP。睡觉会使目标陷入睡眠状态。\n如果自身处于睡眠状态（如使用梦话使出），或者具有特性绝对睡眠或洁净之盐之类的让自己无法入睡的特性，睡觉会使用失败。\nHP为全满时使用会失败。",
    range: "自身"
  },
  "retaliate": {
    description: "为倒下的同伴报仇。如果上一回合有同伴倒下，威力就会提高。"
  },
  "return": {
    intro: "报恩（日文︰おんがえし，英文︰Return）是第二世代引入的一般属性招式。",
    description: "为了训练家而全力攻击对手。亲密度越高，威力越大。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。威力随着亲密度增加，为亲密度÷2.5；最大102，最小1。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "revelation-dance": {
    description: "全力跳舞进行攻击。此招式的属性将变得和自己的属性相同。"
  },
  "revenge": {
    intro: "这篇文章讲述的是一种格斗属性招式，不是恶属性招式以牙还牙、一般属性招式报仇或恶属性招式复仇。",
    description: "如果受到对手的招式攻击，就能给予对手2倍的伤害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n如果目标本回合内攻击过自身并造成伤害，威力翻倍。\n分担痛楚不视作伤害招式。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "reversal": {
    intro: "绝处逢生（日文︰きしかいせい，英文︰Reversal）是第二世代引入的格斗属性招式。",
    description: "竭尽全力进行攻击。自己的HP越少，招式的威力越大。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。招式威力和自身剩下的HP有关。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "revival-blessing": {
    description: "通过以慈爱之心祈祷，让陷入昏厥的后备宝可梦以回复一半HP的状态复活。"
  },
  "rising-voltage": {
    description: "用从地面升腾而起的电击进行攻击。当对手处于电气场地上时，招式威力会变成2倍。"
  },
  "roar": {
    intro: "吼叫（日文︰ほえる，英文︰Roar）是第一世代引入的一般属性招式。",
    description: "放走对手，强制拉后备宝可梦上场。如果对手为野生宝可梦，战斗将直接结束。",
    effect: ["不是接触类招式", "不受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "roar-of-time": {
    description: "释放出扭曲时间般的强大力量攻击对手。下一回合自己将无法动弹。"
  },
  "rock-blast": {
    description: "向对手发射坚硬的岩石进行攻击。连续攻击2～5次。"
  },
  "rock-climb": {
    description: "发动猛撞攻击，有时会使对手混乱。是宝可表的秘传招式之一。"
  },
  "rock-polish": {
    description: "打磨自己的身体，减少空气阻力。可以大幅提高自己的速度。"
  },
  "rock-slide": {
    intro: "岩崩（日文︰いわなだれ，英文︰Rock Slide）是第一世代引入的岩石属性招式。",
    description: "将大岩石猛烈地撞向对手进行攻击。有时会使对手畏缩。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n岩崩有30%的几率使尚未行动的目标陷入畏缩状态。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "rock-smash": {
    intro: "碎岩（日文︰いわくだき，英文︰Rock Smash）是第二世代引入的格斗属性招式。",
    description: "用拳头进行攻击。有时会降低对手的防御。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响", "可以在对战外使用"],
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "rock-throw": {
    intro: "落石（日文︰いわおとし，英文︰Rock Throw）是第一世代引入的岩石属性招式。",
    description: "拿起小岩石，投掷对手进行攻击。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "rock-tomb": {
    intro: "岩石封锁（日文︰がんせきふうじ，英文︰Rock Tomb）是第三世代引入的岩石属性招式。",
    description: "投掷岩石进行攻击。封住对手的行动，从而降低速度。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n100%几率令目标的速度降低1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "rock-wrecker": {
    description: "向对手发射巨大的岩石进行攻击。下一回合自己将无法动弹。"
  },
  "role-play": {
    intro: "扮演（日文︰なりきり，英文︰Role Play）是第三世代引入的超能力属性招式。",
    description: "扮演对手，让自己的特性变得和对手相同。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "把自身特性转变为目标的特性，直至自身离场后恢复。\n以下情况时，招式使用失败：\n使用者与目标特性相同；\n目标特性为神奇守护；\n目标特性为无法被复制的特性，包括：\n复制、接球手、化学之力、阴晴不定、花之礼、多属性、变身者、幻觉、达摩模式、战斗切换、群聚变形、牵绊变身、画皮、鱼群、界限盾壳、ＡＲ系统、饱了又饿、结冻头、人马一体、绝对睡眠、化学变化气体、全能变身、发号施令、古代活性、夸克充能、面影辉映、太晶甲壳、归零化境、毒傀儡；\n使用者特性为无法被覆盖的特性，包括：\n多属性、达摩模式、战斗切换、群聚变形、牵绊变身、画皮、鱼群、界限盾壳、ＡＲ系统、一口导弹、结冻头、人马一体、绝对睡眠、全能变身、发号施令。\n扮演一定会命中，除非目标正在使用蓄力的招式并不在场地上。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "rolling-kick": {
    intro: "回旋踢（日文︰まわしげり，英文︰Rolling Kick）是第一世代引入的格斗属性招式。",
    description: "一边使身体快速旋转，一边踢飞对手进行攻击。有时会使对手畏缩。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n回旋踢有30%的几率使尚未行动的目标陷入畏缩状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "rollout": {
    intro: "滚动（日文︰ころがる，英文︰Rollout）是第二世代引入的岩石属性招式。",
    description: "在5回合内连续滚动攻击对手。招式每次击中，威力就会提高。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "roost": {
    description: "降到地面，使身体休息。回复自己最大HP的一半。"
  },
  "rototiller": {
    description: "翻耕土地，使草木更容易成长。会提高草属性宝可梦的攻击和特攻。"
  },
  "round": {
    description: "用歌声攻击对手。大家一起轮唱便可以接连使出，威力也会提高。"
  },
  "ruination": {
    description: "引发毁灭性的灾厄，使对手的HP减半。"
  },
  "sacred-fire": {
    intro: "神圣之火（日文︰せいなるほのお，英文︰Sacred Fire）是第二世代引入的火属性招式。",
    description: "用神秘的火焰烧尽对手进行攻击。有时会让对手陷入灼伤状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n神圣之火有50%的几率使目标陷入灼伤状态。\n处于冰冻状态的宝可梦，无论是否命中，只要成功使用该招式，就可以解除冰冻。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "sacred-sword": {
    description: "用剑切斩对手进行攻击。无视对手的能力变化，直接给予伤害。"
  },
  "safeguard": {
    intro: "这篇文章讲述的是一种招式。如果您在寻找一种特性，请移步神奇守护（特性）。",
    description: "在5回合内被神奇的力量守护，从而不会陷入异常状态。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：神秘守护（状态）\n使己方场地进入神秘守护状态，5回合内保护己方宝可梦不会陷入异常状态、混乱状态、瞌睡状态。",
    range: "我方场地"
  },
  "salt-cure": {
    description: "使对手陷入盐腌状态，每回合给予对手伤害。对手为钢或水属性时会更痛苦。"
  },
  "sand-attack": {
    intro: "泼沙（日文︰すなかけ，英文︰Sand Attack）是第一世代引入的地面属性招式。",
    description: "向对手脸上泼沙子，从而降低命中率。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令目标的命中率降低1级。\n无视属性相性，可以命中飞行属性和飘浮宝可梦。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "sand-tomb": {
    intro: "流沙深渊（日文︰すなじごく，英文︰Sand Tomb）是第三世代引入的地面属性招式。",
    description: "将对手困在铺天盖地的沙暴中，在4～5回合内进行攻击。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "主页面：束缚（状态）\n攻击目标造成伤害并使其陷入束缚状态。束缚状态持续4～5回合，处于束缚状态的宝可梦会持续受到伤害并不能换下。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "sandsear-storm": {
    description: "用灼热的沙子和强烈的风席卷对手进行攻击。有时会让对手陷入灼伤状态。"
  },
  "sandstorm": {
    intro: "沙暴（日文︰すなあらし，英文︰Sandstorm）是第二世代引入的岩石属性招式。",
    description: "在5回合内扬起沙暴，除岩石、地面和钢属性以外的宝可梦，都会受到伤害。岩石属性的特防还会提高。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：沙暴（状态）\n包括使用的回合在内，接下来5回合的天气变更为沙暴。如果使用者携带了沙沙岩石，持续时间延长为8回合。\n使用该招式会覆盖原本的天气。无论原本的天气是否永续，该招式的效果结束之后天气都会恢复为晴朗。如果当前天气为大雨、大日照、乱流或已经为沙暴，招式使用失败。",
    range: "全部场地"
  },
  "scald": {
    description: "向对手喷射煮得翻滚的开水进行攻击。有时会让对手陷入灼伤状态。"
  },
  "scale-shot": {
    description: "发射鳞片进行攻击。连续攻击2～5次。速度会提高但防御会降低。"
  },
  "scary-face": {
    intro: "可怕面孔（日文︰こわいかお，英文︰Scary Face）是第二世代引入的一般属性招式。",
    description: "用恐怖的表情瞪着对手，使其害怕，从而大幅降低对手的速度。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令目标的速度降低2级。\n酋雷姆转换为焰白形态/暗黑形态后，招式会转换成交错火焰/交错闪电。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "scorching-sands": {
    description: "将滚烫的沙子砸向对手进行攻击。有时会让对手陷入灼伤状态。"
  },
  "scratch": {
    intro: "抓（日文︰ひっかく，英文︰Scratch）是第一世代引入的一般属性招式。",
    description: "用坚硬且无比锋利的爪子抓对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "screech": {
    intro: "刺耳声（日文︰いやなおと，英文︰Screech）是第一世代引入的一般属性招式。",
    description: "发出不由自主想要捂起耳朵的刺耳声，从而大幅降低对手的防御。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令目标的防御降低2级。\n对隔音特性的宝可梦无效。\n该招式无视目标的替身状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "searing-shot": {
    description: "用熊熊烈火攻击自己周围所有的宝可梦。有时会陷入灼伤状态。"
  },
  "secret-power": {
    intro: "秘密之力（日文︰ひみつのちから，英文︰Secret Power）是第三世代引入的一般属性招式。",
    description: "根据使用场所不同，该招式的追加效果也会有所变化。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响", "可以在对战外使用"],
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "secret-sword": {
    description: "用长角切斩对手进行攻击。角上拥有的神奇力量将给予物理伤害。"
  },
  "seed-bomb": {
    description: "将外壳坚硬的大种子，从上方砸下攻击对手。"
  },
  "seed-flare": {
    description: "从身体里产生冲击波。有时会大幅降低对手的特防。"
  },
  "seismic-toss": {
    intro: "地球上投（日文︰ちきゅうなげ，英文︰Seismic Toss）是第一世代引入的格斗属性招式。",
    description: "利用引力将对手甩飞出去。给予对手和自己等级相同的伤害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "对目标造成与使用者等级相等的伤害。该招式无法对没有效果的属性的宝可梦造成伤害，但忽略其它属性相克和属性一致加成。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "self-destruct": {
    intro: "这篇文章讲述的是威力为200的招式，不是大爆炸。",
    description: "引发爆炸，攻击自己周围所有的宝可梦。使用后陷入昏厥。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "自身陷入昏厥状态并攻击目标造成伤害。\n气势头带、气势披带、结实特性不能阻止使用者陷入昏厥状态。\n即使招式未命中、被守住状态阻挡，或因为属性相性而没有产生效果，使用者仍然会陷入昏厥状态。\n有湿气特性的宝可梦在场时，玉石俱碎使用失败，使用者不会陷入昏厥状态。",
    range: "除自身以外场上全部可以攻击到的宝可梦"
  },
  "shadow-ball": {
    intro: "这篇文章讲述的是一种招式。如果您在寻找一种精灵球，请移步黑暗球（道具）。",
    description: "投掷一团黑影进行攻击。有时会降低对手的特防。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n20%几率令目标的特防降低1级。\n对防弹特性的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "shadow-claw": {
    description: "以影子做成的锐爪，劈开对手。容易击中要害。"
  },
  "shadow-force": {
    description: "第1回合消失踪影，第2回合攻击对手。即使对手正受保护，也能击中。"
  },
  "shadow-punch": {
    intro: "暗影拳（日文︰シャドーパンチ，英文︰Shadow Punch）是第三世代引入的幽灵属性招式。",
    description: "使出混影之拳。攻击必定会命中。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n暗影拳一定会命中，除非目标正在使用蓄力的招式并不在场地上。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "shadow-sneak": {
    description: "伸长影子，从对手的背后进行攻击。必定能够先制攻击。"
  },
  "sharpen": {
    intro: "棱角化（日文︰かくばる，英文︰Sharpen）是第一世代引入的一般属性招式。",
    description: "增加身体的角，变得棱棱角角，从而提高自己的攻击。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令使用者的攻击提升1级。",
    range: "自身"
  },
  "shed-tail": {
    description: "削减自己的HP，制造分身后会返回，并和后备宝可梦进行替换。"
  },
  "sheer-cold": {
    intro: "绝对零度（日文︰ぜったいれいど，英文︰Sheer Cold）是第三世代引入的冰属性招式。",
    description: "给对手一击昏厥。如果是冰属性以外的宝可梦使用，就会难以打中。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "绝对零度造成与对手的最大HP相同的固定伤害。只要属性相性不为0倍，就能一击造成昏厥。\n如果自身等级低于目标，招式使用失败。\n此招式不使用通常命中判定：\n招式的命中等于：(20 + 10使用者具有冰属性时 + 使用者等级 - 目标等级)%。\n命中的概率不会受到命中率和闪避率影响。\n锁定状态和无防守特性能够使此招式变成必定命中。\n此招式对结实特性的宝可梦无效。\n此招式对冰属性的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "shell-smash": {
    description: "打破外壳，降低自己的防御和特防，但大幅提高攻击、特攻和速度。"
  },
  "shell-trap": {
    description: "设下甲壳陷阱。如果对手使出物理招式，陷阱就会爆炸并给予对手伤害。"
  },
  "shelter": {
    description: "将皮肤变得坚硬如铁盾，从而大幅提高自己的防御。"
  },
  "shift-gear": {
    description: "转动齿轮，不仅提高自己的攻击，还会大幅提高速度。"
  },
  "shock-wave": {
    description: "向对手快速发出电击。攻击必定会命中。"
  },
  "shore-up": {
    description: "回复自己最大HP的一半。在沙暴中回复得更多。"
  },
  "signal-beam": {
    intro: "信号光束（日文︰シグナルビーム，英文︰Signal Beam）是第三世代引入的虫属性招式。",
    description: "发射神奇的光线进行攻击。有时会使对手混乱。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n信号光束有10%的几率使目标陷入混乱状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "silk-trap": {
    description: "用丝设置陷阱。防住对方攻击的同时，能够降低所接触到的对手的速度。"
  },
  "silver-wind": {
    intro: "银色旋风（日文︰ぎんいろのかぜ，英文︰Silver Wind）是第三世代引入的虫属性招式。",
    description: "在风中掺入鳞粉攻击对手。有时会提高自己的全部能力。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n10%几率令使用者的攻击、防御、特攻、特防和速度提升1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "simple-beam": {
    description: "向对手发送谜之念波。接收到念波的对手，其特性会变为单纯。"
  },
  "sing": {
    intro: "唱歌（日文︰うたう，英文︰Sing）是第一世代引入的一般属性招式。",
    description: "让对手听舒适、美妙的歌声，从而陷入睡眠状态。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "唱歌会使目标陷入睡眠状态。\n对隔音特性的宝可梦无效。\n该招式无视目标的替身状态。",
    range: "未知"
  },
  "sketch": {
    intro: "这篇文章讲述的是一种招式。如果您在寻找第二世代的游戏漏洞，请移步写生（漏洞）。",
    description: "将对手使用的招式变成自己的招式。使用1次后写生消失。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "将写生永久替换为目标最后使用过的招式。使用后写生消失，但可以找招式教学狂回忆。\n它不会被仿效、鹦鹉学舌、借助、挥指或梦话发动，不会受再来一次影响，也不会被模仿和它本身学习。\n自第三世代起，如果目标处于替身状态或变身状态，或是在连接对战中使用写生会失败。\n在《红宝石／蓝宝石》中，如果目标本回合可能使用招式，但因为睡眠等状态不能成功使用，写生可以复制将要使出的招式。在第三世代中写生变身或挥指等招式可以用到这个方法。\n以下招式无法被写生：\n已经学会的招式\n写生\n挣扎\n喋喋不休\n暗黑洞*\n异次元猛攻*\n复生祈祷\n晶光星群\nＺ招式\n黑暗招式\n天星队车使用的专属招式\n以下招式曾经无法被写生：\n变身、梦话、挥指、鹦鹉学舌、玉石俱碎、大爆炸（第二世代中）\n模仿（第二世代、《火红／叶绿》、《绿宝石》中）\n临别礼物（《火红／叶绿》、《绿宝石》中）",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "skill-swap": {
    intro: "特性互换（日文︰スキルスワップ，英文︰Skill Swap）是第三世代引入的超能力属性招式。",
    description: "利用超能力互换自己和对手的特性。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "自身和目标交换特性。因替换宝可梦或陷入昏厥状态而退场后，恢复自身原本持有的特性。\n以下情况时，招式使用失败：\n自身或目标为无法被交换的特性，包括：\n神奇守护、多属性、幻觉、达摩模式、战斗切换、群聚变形、 牵绊变身、画皮、鱼群、界限盾壳、ＡＲ系统、饱了又饿、一口导弹、结冻头、人马一体、绝对睡眠、化学变化气体、全能变身、发号施令、古代活性和夸克充能；\n目标为极巨化的宝可梦。\n部分入场时发动的特性如威吓、日照、破格等，在被交换后会立即发动一次。\n处于无特性状态时可以使出该招式，但交换后不会解除无特性状态。\n该招式无视目标的替身状态。\n目标为对方的宝可梦时会将双方原本的特性显示出来，目标为同伴时则不会显示。\n特性互换一定会命中，除非目标正在使用蓄力的招式并不在场地上。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "skitter-smack": {
    description: "从对手背后爬近后进行攻击。会降低对手的特攻。"
  },
  "skull-bash": {
    intro: "火箭头锤（日文︰ロケットずつき，英文︰Skull Bash）是第一世代引入的一般属性招式。",
    description: "第1回合把头缩进去，从而提高防御。第2回合攻击对手。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "使用火箭头锤的宝可梦在第一回合进行蓄力，同时令使用者的防御提升1级。进行蓄力时的提示为：“[宝可梦的名字]把头缩了进去！”。进行蓄力时不能下达指令。\n在第二回合发动招式。攻击目标造成伤害。\n蓄力的回合会进行行动判定，成功进行蓄力则消耗PP。\n攻击的回合也会进行行动判定，出现不能行动的情况则招式失败。\n在蓄力的回合，消耗携带的强力香草，可以立刻结束蓄力，在当回合发动招式。\n对使用火箭头锤的宝可梦（无论当回合是在进行蓄力或进行攻击）使用突袭可以成功。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "sky-attack": {
    intro: "这篇文章讲述的是第一世代引入的飞行属性招式。如果您在寻找第四世代引入的飞行属性招式，请移步勇鸟猛攻（招式）。",
    description: "第2回合攻击对手。偶尔使对手畏缩。也容易击中要害。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响", "是远程招式"],
    additionalEffect: "使用神鸟猛击的宝可梦在第一回合进行蓄力。进行蓄力时的提示为：“强光包围了[宝可梦的名字]！”。进行蓄力时不能下达指令。\n在第二回合发动招式。攻击目标造成伤害。击中要害率比大部分招式高1级。神鸟猛击有30%的几率使尚未行动的目标陷入畏缩状态。\n蓄力的回合会进行行动判定，成功进行蓄力则消耗PP。\n攻击的回合也会进行行动判定，出现不能行动的情况则招式失败。\n在蓄力的回合，消耗携带的强力香草，可以立刻结束蓄力，在当回合发动招式。\n对使用神鸟猛击的宝可梦（无论当回合是在进行蓄力或进行攻击）使用突袭可以成功。\n该招式不能被梦话发动。",
    range: "除自身以外场上一只宝可梦"
  },
  "sky-drop": {
    description: "第1回合将对手带到空中，第2回合将其摔下进行攻击。被带到空中的对手不能动弹。"
  },
  "sky-uppercut": {
    intro: "冲天拳（日文︰スカイアッパー，英文︰Sky Uppercut）是第三世代引入的格斗属性招式。",
    description: "用冲向天空般高高的上勾拳顶起对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n可以击中处于飞翔状态的宝可梦。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "slack-off": {
    intro: "偷懒（日文︰なまける，英文︰Slack Off）是第三世代引入的一般属性招式。",
    description: "偷懒休息。回复自己最大HP的一半。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "偷懒能够回复使用者1⁄2的HP。在使用者处于回复封锁状态时无法使用。",
    range: "自身"
  },
  "slam": {
    intro: "摔打（日文︰たたきつける，英文︰Slam）是第一世代引入的一般属性招式。",
    description: "使用长长的尾巴或藤蔓等摔打对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "slash": {
    intro: "劈开（日文︰きりさく，英文︰Slash）是第一世代引入的一般属性招式。",
    description: "用爪子或镰刀等劈开对手进行攻击。容易击中要害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。击中要害率比大部分招式高1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "sleep-powder": {
    intro: "催眠粉（日文︰ねむりごな，英文︰Sleep Powder）是第一世代引入的草属性招式。",
    description: "撒出催眠粉，从而让对手陷入睡眠状态。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "催眠粉会使目标陷入睡眠状态。\n对草属性、防尘特性、携带防尘护目镜的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "sleep-talk": {
    intro: "梦话（日文︰ねごと，英文︰Sleep Talk）是第二世代引入的一般属性招式。",
    description: "从自己已学会的招式中任意使出1个。只能在自己睡觉时使用。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "当使用者处于睡眠状态，或者具有特性绝对睡眠，会随机使用1个自身学会的其它招式，不会消耗所选择的招式的PP，否则招式使用失败。当随机使用的招式PP为0时，该招式仍可被梦话使用。\n该招式不能被鹦鹉学舌学习，也不会被借助、挥指或梦话发动。\n梦话选择到睡觉的情况下招式会使用失败。\n梦话选择到王牌的情况下按梦话的PP计算威力。\n己方最后使用的招式是梦话时，目标为自己的再来一次使用失败。\n以下招式不会被梦话发动。如果没有可供选择的招式，使用失败。\n被定身法、无理取闹、封印状态封锁的招式*；\n调用其他招式的招式，包括梦话本身、挥指、鹦鹉学舌、自然之力、借助、抢先一步、仿效；\n模仿、写生；\n蓄力的招式；\n真气拳、鸟嘴加农炮、陷阱甲壳；\n忍耐；\n吵闹；\n喋喋不休；\n打嗝；\n庆祝、牵手；\n极巨炮；\n当前世代无法在战斗中使用的招式*。\n梦话使出的招式为多回合攻击类招式时，不会造成多回合攻击和混乱状态。",
    range: "自身"
  },
  "sludge": {
    intro: "污泥攻击（日文︰ヘドロこうげき，英文︰Sludge）是第一世代引入的毒属性招式。",
    description: "用污泥投掷对手进行攻击。有时会让对手陷入中毒状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n污泥攻击有30%的几率使目标陷入中毒状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "sludge-bomb": {
    intro: "这篇文章讲述的是第二世代引入的毒属性招式。如果您在寻找第四世代引入的地面属性招式，请移步泥巴炸弹（招式）。",
    description: "用污泥投掷对手进行攻击。有时会让对手陷入中毒状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n污泥炸弹有30%的几率使目标陷入中毒状态。\n对防弹特性的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "sludge-wave": {
    description: "用污泥波攻击自己周围所有的宝可梦。有时会陷入中毒状态。"
  },
  "smack-down": {
    description: "扔石头或炮弹，攻击飞行的对手。对手会被击落，掉到地面。"
  },
  "smart-strike": {
    description: "用尖尖的角刺入对手进行攻击。攻击必定会命中。"
  },
  "smelling-salts": {
    intro: "清醒（日文︰きつけ，英文︰Smelling Salts）是第三世代引入的一般属性招式。",
    description: "对于麻痹状态下的对手，威力会变成2倍。但相反对手的麻痹也会被治愈。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n如果目标处于麻痹状态，招式的威力加倍，并且解除目标的麻痹状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "smog": {
    intro: "浊雾（日文︰スモッグ，英文︰Smog）是第一世代引入的毒属性招式。",
    description: "将肮脏的浓雾吹向对手进行攻击。有时会让对手陷入中毒状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n浊雾有40%的几率使目标陷入中毒状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "smokescreen": {
    intro: "烟幕（日文︰えんまく，英文︰Smokescreen）是第一世代引入的一般属性招式。",
    description: "向对手喷出烟或墨汁等，从而降低对手的命中率。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令目标的命中率降低1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "snarl": {
    description: "没完没了地大声斥责，从而降低对手的特攻。"
  },
  "snatch": {
    intro: "这篇文章讲述的是夺取招式效果的招式。如果您在寻找夺取携带物品的招式，请移步小偷（招式）。",
    description: "将对手打算使用的回复招式或能力变化招式夺为己用。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "使用化为己用后，若当回合有其他宝可梦成功使出对其自身或其所在方场地有利的变化招式，会立刻将其效果夺为己用。\n该招式每次使用最多只能夺取1个招式的效果。\n只要化为己用使用成功，则夺取招式效果时不会受到麻痹、睡眠、冰冻、混乱或畏缩等状态的影响。\n若当回合有多只宝可梦使用化为己用，则按照行动顺序，由最先行动的宝可梦先进行夺取。之后其他宝可梦依次进行夺取，且不会化为己用本回合已被夺取过的招式。\n该招式不能被鹦鹉学舌学习，也不会被借助或挥指发动。\n无法化为己用Ｚ招式，即使其对应的原本招式可以被化为己用。\n可以被化为己用的招式如下：",
    range: "自身"
  },
  "snipe-shot": {
    description: "能无视具有吸引对手招式效果的特性或招式的影响。可以向选定的对手进行攻击。"
  },
  "snore": {
    intro: "打鼾（日文︰いびき，英文︰Snore）是第二世代引入的一般属性招式。",
    description: "在自己睡觉时，发出噪音进行攻击。有时会使对手畏缩。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "除非使用者处于睡眠状态，或者具有特性绝对睡眠，否则使用失败。\n攻击目标造成伤害。\n打鼾有30%的几率使尚未行动的目标陷入畏缩状态。\n对隔音特性的宝可梦无效。\n该招式无视目标的替身状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "snowscape": {
    description: "在5回合内会下雪。冰属性的防御会提高。"
  },
  "soak": {
    description: "将大量的水泼向对手，从而使其变成水属性。"
  },
  "soft-boiled": {
    intro: "这篇文章讲述的是名为生蛋的招式。如果您在寻找获得宝可梦的蛋的方法，请移步宝可梦培育#生蛋。",
    description: "回复自己最大HP的一半。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响", "可以在对战外使用"],
    range: "自身"
  },
  "solar-beam": {
    intro: "这篇文章讲述的是特殊招式，不是物理招式日光刃。",
    description: "第1回合收集满满的日光，第2回合发射光束进行攻击。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "使用日光束的宝可梦在第一回合进行蓄力。进行蓄力时的提示为：“[宝可梦的名字]吸收了光！”。进行蓄力时不能下达指令。\n在第二回合发动招式。攻击目标造成伤害。\n在天气为下雨、大雨、沙暴、冰雹、下雪或起雾状态时威力减半。\n蓄力的回合会进行行动判定，成功进行蓄力则消耗PP。\n攻击的回合也会进行行动判定，出现不能行动的情况则招式失败。\n在蓄力的回合，当天气为大晴天或大日照状态时，或者消耗携带的强力香草，可以立刻结束蓄力，在当回合发动招式。\n对使用日光束的宝可梦（无论当回合是在进行蓄力或进行攻击）使用突袭可以成功。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "solar-blade": {
    description: "第1回合收集满满的日光，第2回合将此力量集中在剑上进行攻击。"
  },
  "sonic-boom": {
    intro: "音爆（日文︰ソニックブーム，英文︰Sonic Boom）是第一世代引入的一般属性招式。",
    description: "将冲击波撞向对手进行攻击。必定会给予20的伤害。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "对目标造成20伤害。该招式无法对没有效果的属性的宝可梦造成伤害，但忽略其它属性相克和属性一致加成。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "spacial-rend": {
    description: "将对手连同周围的空间一起撕裂并给予伤害。容易击中要害。"
  },
  "spark": {
    intro: "电光（日文︰スパーク，英文︰Spark）是第二世代引入的电属性招式。",
    description: "让电流覆盖全身，猛撞向对手进行攻击。有时会让对手陷入麻痹状态。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n电光有30%的几率使目标陷入麻痹状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "sparkling-aria": {
    description: "随着唱歌会放出很多气球。受到此招式攻击时，灼伤会被治愈。"
  },
  "spectral-thief": {
    description: "潜入对手的影子进行攻击。会夺取对手的能力提升。"
  },
  "speed-swap": {
    description: "将对手和自己的速度进行互换。"
  },
  "spicy-extract": {
    description: "放出极为辛辣的精华。对手的攻击会大幅提高，防御会大幅降低。"
  },
  "spider-web": {
    intro: "蛛网（日文︰クモのす，英文︰Spider Web）是第二世代引入的虫属性招式。",
    description: "将黏糊糊的细丝一层一层缠住对手，使其不能从战斗中逃走。",
    effect: ["不是接触类招式", "不受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：无法逃走（状态）\n使目标陷入无法逃走状态。处于无法逃走状态的宝可梦不能换下。\n蛛网一定会命中，除非目标正在使用蓄力的招式并不在场地上。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "spike-cannon": {
    intro: "尖刺加农炮（日文︰とげキャノン，英文︰Spike Cannon）是第一世代引入的一般属性招式。",
    description: "向对手发射锐针进行攻击。连续攻击2～5次。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，一回合内连续攻击2～5次。命中时，各有15%的几率攻击5或4次，35%的几率攻击3或2次，攻击次数的数学期望是3.1次，对应的威力的数学期望是62。\n携带机变骰子且命中时，各有1⁄2的几率攻击5或4次，攻击次数的数学期望是4.5次，对应的威力的数学期望是90。\n每一击击中要害的概率都相等。\n如果某一下触发了目标的气势披带、气势头带、结实特性或打破了替身，招式会继续攻击。\n忍耐、金属爆炸和双倍奉还只计算最后一次的伤害。\n如果使用者持有王者之证或锐利之牙，或具有恶臭特性，每一下攻击都有相同的概率造成对手畏缩。\n如果目标拥有咒术之躯、碎裂铠甲特性，每一下攻击都会触发效果。即使特性发动令攻击方陷入一些可能无法行动的状态（如麻痹、畏缩、着迷、定身法状态），也不会影响本次攻击，但陷入睡眠和昏厥时攻击即刻停止。\n目标的变色特性在最后一下攻击完成后才发动。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "spikes": {
    intro: "撒菱（日文︰まきびし，英文︰Spikes）是第二世代引入的地面属性招式。",
    description: "在对手的脚下扔撒菱。对替换出场的对手的宝可梦给予伤害。",
    effect: ["不是接触类招式", "不受守住影响", "受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：撒菱（状态）\n向对手的场地撒菱，使替换上场的宝可梦受到满HP的1⁄8伤害。\n可以撒下多层菱，伤害会随之提高，最多撒下3层。",
    range: "对手场地"
  },
  "spiky-shield": {
    description: "防住对手攻击的同时，削减接触到自己的对手的体力。"
  },
  "spin-out": {
    description: "通过往腿上增加负荷，以激烈的旋转给予对手伤害。自己的速度会大幅降低。"
  },
  "spirit-break": {
    description: "用足以让对手一蹶不振的气势进行攻击。会降低对手的特攻。"
  },
  "spirit-shackle": {
    description: "攻击的同时，缝住对手的影子，使其无法逃走。"
  },
  "spit-up": {
    intro: "喷出（日文︰はきだす，英文︰Spit Up）是第三世代引入的一般属性招式。",
    description: "将积蓄的力量撞向对手进行攻击。积蓄得越多，威力越大。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。威力相当于蓄力的次数乘100。储存的力量会被喷出，且储存的防御和特防会被复原。如果自身没有储存力量，则招式使用失败。\n即使对方正在使用蓄力招式不在场上，使用此招式也会复原储存的力量，只是招式不会造成伤害。\n该招式不会被鹦鹉学舌学习。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "spite": {
    intro: "这篇文章讲述的是第二世代登场的幽灵属性招式。如果您在寻找因对手的招式而陷入昏厥时让该招式的PP变成0，请移步怨念（招式）。",
    description: "对对手最后使用的招式怀有怨恨，减少4PP该招式。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "对手最后使用的招式的PP降低4点。\n如果目标在对战中尚未使用招式，或上回合使用的招式PP为0，该招式使用失败。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "splash": {
    intro: "这篇文章讲述的是一般属性招式，不是飞行属性招式弹跳。",
    description: "也不攻击只是一蹦一蹦地跳，什么都不会发生……",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "无。\n当重力存在时该招式不可用。\n在《传说 阿尔宙斯》中，该招式不可被精通。",
    range: "自身"
  },
  "spore": {
    intro: "蘑菇孢子（日文︰キノコのほうし，英文︰Spore）是第一世代引入的草属性招式。",
    description: "沙沙沙地撒满具有催眠效果的孢子，从而让对手陷入睡眠状态。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "蘑菇孢子会使目标陷入睡眠状态。\n对草属性、防尘特性、携带防尘护目镜的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "spotlight": {
    description: "给宝可梦打上聚光灯，该回合只能瞄准该宝可梦。"
  },
  "springtide-storm": {
    description: "用交织着爱与恨的烈风席卷对手进行攻击。有时会降低对手的攻击。"
  },
  "stealth-rock": {
    description: "将无数岩石悬浮在对手的周围，从而对替换出场的对手的宝可梦给予伤害。"
  },
  "steam-eruption": {
    description: "将滚烫的蒸汽喷向对手。有时会让对手灼伤。"
  },
  "steamroller": {
    description: "旋转揉成团的身体压扁对手。有时会使对手畏缩。"
  },
  "steel-beam": {
    description: "将从全身聚集的钢铁化为光束，激烈地发射出去。自己也会受到伤害。"
  },
  "steel-roller": {
    description: "在破坏场地的同时攻击对手。如果脚下没有任何场地状态存在，使出此招式时便会失败。"
  },
  "steel-wing": {
    intro: "钢翼（日文︰はがねのつばさ，英文︰Steel Wing）是第二世代引入的钢属性招式。",
    description: "用坚硬的翅膀敲打对手进行攻击。有时会提高自己的防御。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n10%几率令使用者的防御提升1级。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "sticky-web": {
    description: "在对手周围围上黏黏的网，降低替换出场的对手的速度。"
  },
  "stockpile": {
    intro: "蓄力（日文︰たくわえる，英文︰Stockpile）是第三世代引入的一般属性招式。",
    description: "积蓄力量，提高自己的防御和特防。最多积蓄3次。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "陷入蓄力状态，在蓄力的时候，防御和特防会提高。\n令使用者的防御提升1级。\n令使用者的特防提升1级。\n储存的力量可以被喷出和吞下，这个情况下，通过储存招式提升的能力将恢复原状。最多可以储存3次力量，但若自身离开场地则储存的力量会消失。如果无法提升能力，依然可以储存力量。但如果已经储存了3次力量，则无法继续使用蓄力提升能力。\n如果使用接棒，能力提升可以传递，但储存的力量不会传递。",
    range: "自身"
  },
  "stomp": {
    intro: "踩踏（日文︰ふみつけ，英文︰Stomp）是第一世代引入的一般属性招式。",
    description: "用大脚踩踏对手进行攻击。有时会使对手畏缩。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n如果目标处于变小状态，伤害翻倍。同时在这种状况下，踩踏一定会命中，除非目标正在使用蓄力的招式并不在场地上。\n踩踏有30%的几率使尚未行动的目标陷入畏缩状态。甜舞妮学会踩踏后升级可以进化为甜冷美后。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "stomping-tantrum": {
    description: "化悔恨为力量进行攻击。如果上一回合招式没有打中，威力就会翻倍。"
  },
  "stone-axe": {
    description: "用岩石之斧进行攻击。散落的岩石碎片会飘浮在对手周围。"
  },
  "stone-edge": {
    description: "用尖尖的岩石刺入对手进行攻击。容易击中要害。"
  },
  "stored-power": {
    description: "用蓄积起来的力量攻击对手。自己的能力提高得越多，威力就越大。"
  },
  "storm-throw": {
    description: "向对手使出强烈的一击。攻击必定会击中要害。"
  },
  "strength": {
    intro: "这篇文章讲述的是一个一般属性招式。如果您在寻找一只格斗属性的宝可梦，请移步怪力。",
    description: "使出浑身力气殴打对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响", "可以在对战外使用"],
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "strength-sap": {
    description: "给自己回复和对手攻击力相同数值的HP，然后降低对手的攻击。"
  },
  "string-shot": {
    intro: "吐丝（日文︰いとをはく，英文︰String Shot）是第一世代引入的虫属性招式。",
    description: "用口中吐出的丝缠绕对手，从而大幅降低对手的速度。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令目标的速度降低2级。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "struggle-bug": {
    intro: "挣扎（日文︰わるあがき，英文︰Struggle）是第一世代引入的一般属性招式。",
    description: "当自己的PP耗尽时，努力挣扎攻击对手。自己也会受到少许伤害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击随机一位对手造成无属性的伤害。对使用者造成最大HP的1⁄4伤害。\n挣扎一定会命中，除非目标正在使用蓄力的招式并不在场地上。\n该招式不能被模仿或写生学习，也不能被仿效、鹦鹉学舌、借助或挥指发动，也不受再来一次、坚硬脑袋、舍身、神奇守护、魔法防守的影响。\n该招式不可被精通。",
    range: "随机一只对手"
  },
  "stuff-cheeks": {
    description: "吃掉携带的树果，大幅提高防御。"
  },
  "stun-spore": {
    intro: "麻痹粉（日文︰しびれごな，英文︰Stun Spore）是第一世代引入的草属性招式。",
    description: "撒出麻痹粉，从而让对手陷入麻痹状态。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "麻痹粉会使目标陷入麻痹状态。\n对草属性、防尘特性、携带防尘护目镜的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "submission": {
    intro: "深渊翻滚（日文︰じごくぐるま，英文︰Submission）是第一世代引入的格斗属性招式。",
    description: "将对手连同自己一起摔向地面进行攻击。自己也会受到少许伤害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。使用者承受对目标造成伤害的1⁄4的伤害。\n使用者具有坚硬脑袋或魔法防守特性时，不会承受伤害。\n使用者具有舍身特性时，该招式威力提升20%，因此承受的伤害也会提升。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "substitute": {
    intro: "替身（日文︰みがわり，英文︰Substitute）是第一世代引入的一般属性招式。",
    description: "削减少许自己的HP，制造分身。分身将成为自己的替身。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：替身（状态）\n使用自己最大HP的1⁄4制造出替身，相等于替身的HP。可以抵挡部分招式伤害和效果。如果自身离开对战，替身也会消失。如果自身HP不超过最大HP的1⁄4，此招式会失败。",
    range: "自身"
  },
  "sucker-punch": {
    description: "可以比对手先攻击。对手使出的招式如果不是攻击招式则会失败。"
  },
  "sunny-day": {
    intro: "大晴天（日文︰にほんばれ，英文︰Sunny Day）是第二世代引入的火属性招式。",
    description: "在5回合内让日照变得强烈，从而提高火属性的招式威力。水属性的招式威力则降低。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：大晴天（状态）\n包括使用的回合在内，接下来5回合的天气变更为大晴天。如果使用者携带了炽热岩石，持续时间延长为8回合。\n使用该招式会覆盖原本的天气。无论原本的天气是否永续，该招式的效果结束之后天气都会恢复为晴朗。如果当前天气为大雨、大日照、乱流或已经为大晴天，招式使用失败。",
    range: "全部场地"
  },
  "sunsteel-strike": {
    description: "以流星般的气势猛撞对手。可以无视对手的特性进行攻击。"
  },
  "super-fang": {
    intro: "愤怒门牙（日文︰いかりのまえば，英文︰Super Fang）是第一世代引入的一般属性招式。",
    description: "用锋利的门牙猛烈地咬住对手进行攻击。对手的HP减半。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "对目标造成目标当前HP1⁄2（向下取整）的伤害。该招式无法对没有效果的属性的宝可梦造成伤害，但忽略其它属性相克和属性一致加成。\n目标当前HP过低时，至少造成1伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "supercell-slam": {
    description: "让身体带电后压向对手。如果没有命中则自己会受到伤害。"
  },
  "superpower": {
    intro: "蛮力（日文︰ばかぢから，英文︰Superpower）是第三世代引入的格斗属性招式。",
    description: "发挥惊人的力量攻击对手。自己的攻击和防御会降低。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n令使用者的攻击降低1级。\n令使用者的防御降低1级。\n如果攻击无效或没有命中，不会产生该效果。\n使用者的白雾、替身或白色烟雾等无法阻止蛮力的该副作用。\n强行、不服输、好胜对蛮力的该副作用无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "supersonic": {
    intro: "超音波（日文︰ちょうおんぱ，英文︰Supersonic）是第一世代引入的一般属性招式。",
    description: "从身体发出特殊的音波，从而使对手混乱。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "超音波会使目标陷入混乱状态。\n对隔音特性的宝可梦无效。\n该招式无视目标的替身状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "surf": {
    intro: "冲浪（日文︰なみのり，英文︰Surf）是第一世代引入的水属性招式。",
    description: "利用大浪攻击自己周围所有的宝可梦。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响", "可以在对战外使用"],
    range: "除自身以外场上全部可以攻击到的宝可梦"
  },
  "swagger": {
    intro: "虚张声势（日文︰いばる，英文︰Swagger）是第二世代引入的一般属性招式。",
    description: "激怒对手，使其混乱。因为愤怒，对手的攻击会大幅提高。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "虚张声势会使目标陷入混乱状态，同时目标的攻击提升2级。\n即使目标已经混乱或无法混乱，攻击也会提升。\n即使目标攻击已经提升到最高，依然会陷入混乱状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "swallow": {
    intro: "吞下（日文︰のみこむ，英文︰Swallow）是第三世代引入的一般属性招式。",
    description: "将积蓄的力量吞下，从而回复自己的HP。积蓄得越多，回复越大。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "使用者蓄力1次时，吞下能够回复使用者1⁄4的HP。使用者蓄力2次时，吞下能够回复使用者1⁄2的HP。使用者蓄力3次时，吞下能够回复使用者全部的HP。在使用者处于回复封锁状态时无法使用。\n未处于蓄力状态时，则招式使用失败。\n使用后，解除蓄力状态，提升的防御和特防也会被复原。",
    range: "自身"
  },
  "sweet-kiss": {
    intro: "天使之吻（日文︰てんしのキッス，英文︰Sweet Kiss）是第二世代引入的妖精属性招式。",
    description: "像天使般可爱地亲吻对手，从而使对手混乱。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "天使之吻会使目标陷入混乱状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "sweet-scent": {
    intro: "甜甜香气（日文︰あまいかおり，英文︰Sweet Scent）是第二世代引入的一般属性招式。",
    description: "用香气大幅降低对手的闪避率。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响", "可以在对战外使用"],
    range: "全部可以攻击到的对手宝可梦"
  },
  "swift": {
    intro: "高速星星（日文︰スピードスター，英文︰Swift）是第一世代引入的一般属性招式。",
    description: "发射星形的光攻击对手。攻击必定会命中。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n高速星星一定会命中，除非目标正在使用蓄力的招式并不在场地上。",
