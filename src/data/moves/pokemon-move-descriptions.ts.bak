  "taunt": {
    intro: "挑衅（日文︰ちょうはつ，英文︰Taunt）是第三世代引入的恶属性招式。",
    description: "使对手愤怒。在3回合内让对手只能使出给予伤害的招式。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "tearful-look": {
    description: "变得泪眼汪汪，让对手丧失斗志。从而降低对手的攻击和特攻。"
  },
  "teatime": {
    description: "举办一场茶会，场上的所有宝可梦都会吃掉自己携带的树果。"
  },
  "techno-blast": {
    description: "向对手放出光弹。属性会根据自己携带的卡带不同而改变。"
  },
  "teeter-dance": {
    intro: "摇晃舞（日文︰フラフラダンス，英文︰Teeter Dance）是第三世代引入的一般属性招式。",
    description: "摇摇晃晃地跳起舞蹈，让自己周围的宝可梦陷入混乱状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "摇晃舞会使场上除自己以外的所有宝可梦陷入混乱状态。",
    range: "除自身以外场上全部可以攻击到的宝可梦"
  },
  "telekinesis": {
    description: "利用超能力使对手浮起来。在3回合内攻击会变得容易打中对手。"
  },
  "teleport": {
    intro: "瞬间移动（日文︰テレポート，英文︰Teleport）是第一世代引入的超能力属性招式。",
    description: "当有后备宝可梦时使用，就可以进行替换。野生的宝可梦使用则会逃走。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响", "可以在对战外使用"],
    range: "自身"
  },
  "temper-flare": {
    description: "以自暴自弃的气势进行攻击。如果上一回合招式没有命中，威力就会翻倍。"
  },
  "tera-blast": {
    description: "太晶化时，会放出太晶属性的能量攻击。比较自己的攻击和特攻，用数值相对较高的一项给予对方伤害。（其他属性）／用攻击和特攻数值较高的一项给予伤害。对正处于太晶化的对手效果绝佳。自己的攻击和特攻会降低。（星晶）"
  },
  "tera-starstorm": {
    description: "照射出结晶的力量来驱逐敌人。太乐巴戈斯在星晶形态下使出时，能对所有对手造成伤害。"
  },
  "terrain-pulse": {
    description: "借助场地的力量进行攻击。视使出招式时场地状态不同，招式的属性和威力会有所变化。"
  },
  "thief": {
    intro: "这篇文章讲述的是夺取携带物品的招式。如果您在寻找夺取招式效果的招式，请移步化为己用（招式）。",
    description: "攻击的同时盗取道具。当自己携带道具时，不会去盗取。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "主页面：拍落（状态）\n攻击目标造成伤害。\n如果攻击方没有或失去携带物品，则会在本次战斗中获得目标的携带物品。\n以下携带物品不可被偷取：\n谜芝果RSEFRLG\n特性为多属性的宝可梦携带的物品第四世代\n邮件第二世代、EFRLG、第四世代\n可使携带者进行超级进化的超级石\n固拉多携带的朱红色宝珠\n盖欧卡携带的靛蓝色宝珠\n帝牙卢卡携带的大金刚宝玉\n帕路奇亚携带的大白宝玉\n骑拉帝纳携带的大白金宝玉\n阿尔宙斯携带的石板\n盖诺赛克特携带的卡带\nＺ纯晶\n银伴战兽携带的存储碟\n苍响携带的腐朽的剑\n藏玛然特携带的腐朽的盾\n大部分悖谬宝可梦携带的驱劲能量\n乐园守护龙除外。\n破空焰、猛雷鼓、铁头壳和铁磐岩携带的驱劲能量也可以被拍落。\n厄诡椪携带的面具\n变身为这些宝可梦/道具组合的宝可梦的携带物品会被偷取。\n当目标宝可梦携带以下道具时，招式偷取目标携带道具的效果会先于道具效果触发：\n文柚果、勿花果、枝荔果等HP低于一定比例后触发的树果，亚开果\n树果汁\n红牌、逃脱按键、白色香草、模仿香草、避难背包\n谜芝果、嘉珍果（第四世代及以前）\n如果目标携带以上道具，招式攻击时这些道具的效果不会发动。\n当目标宝可梦携带以下道具时，道具效果会先于招式偷取目标携带道具的效果触发：\n直接参与伤害计算的道具：\n进化奇石、金属粉、奇妙空间下的突击背心等改变目标防御的道具。\n参与伤害计算后，招式能够偷取目标携带道具。\n当恶属性招式对目标效果绝佳时的刺耳果\n当招式受使用者一般皮肤特性下变为一般属性时的灯浆果\n当招式受使用者一般皮肤特性下变为一般属性后，受等离子浴或输电效果变为电属性对目标效果绝佳时的烛木果\n气势披带\n若招式未能触发道具效果，招式能够偷取目标携带道具。\n气势头带\n道具判定触发后，招式能够偷取目标携带道具。\n谜芝果（第五世代后）、弱点保险\n如果攻击造成目标陷入昏厥状态，招式能够偷取目标携带道具\n嘉珍果\n凸凸头盔\n道具效果触发后，招式能够偷取目标携带道具。\n附着针\n气球\n招式的效果不是追加效果。\n招式命中拥有鳞粉特性或携带密探斗篷的目标，目标会正常失去其携带物品。\n如果使用者拥有强行特性，特性不会发动效果，招式命中的目标会正常失去其携带物品。\n第四世代及以前，如果使用者已经因拍落状态失去携带物品，招式特效也无法令使用者获得物品；第五世代后，招式特效能令使用者获得物品。\n如果使用者因为目标的铁刺特性、粗糙皮肤特性或凸凸头盔而陷入昏厥状态，招式效果不会发动。\n如果目标具有黏着特性或替身状态，招式效果不会发动。\n第四世代及以前，如果目标具有黏着特性并因招式陷入昏厥状态，招式效果不会发动； 第五世代后，即使目标具有黏着特性，因招式陷入昏厥后，招式效果会发动。\n如果使用者或目标拥有笨拙特性，或受到查封、魔法空间状态影响，招式效果仍然正常发动，但获得的道具若受这些效果影响则无法使用。\n招式获得的道具不受回收利用、超极巨资源再生、收获的影响，也不会成为反刍的对象。\n如果目标拥有轻装特性，招式令目标失去其携带物品后，目标的轻装特性会发动。如果自身拥有轻装特性，招式令自身获得携带物品时，自身的轻装特性会失效。\n招式令目标失去携带物品后，不触发共生的效果。\n招式令目标失去携带物品后，不满足颊囊或吃饱食用树果的条件。\n如果偷取到对方的贝壳之铃，攻击结束后自身会回复HP。\n若招式偷取到黑色眼镜、力量头带等直接参与伤害计算的道具，本次招式伤害不受影响。\n如果偷取到对方的生命宝珠，本次招式伤害不会提升，但攻击结束后自身会损失HP。\n如果偷取到对方的部位护具，本次招式不受道具影响。\n第四世代及以前，如果偷取到对方的讲究道具（讲究头带、讲究围巾或讲究眼镜），下一回合开始只能选择小偷； 第五世代后，讲究道具将锁定下一回合选择的招式。\n在无法获取经验值的连接对战、对战设施等无法获取经验值的同训练家进行的宝可梦对战中，获得的道具在战斗结束后还原。\n第四世代及以前，在能够获取经验值的同训练家进行的宝可梦对战中，道具在战斗结束后会永久获得； 第五世代后，取得的道具在战斗结束后还原。\n同野生宝可梦的对战结束后，从野生宝可梦上获得的道具会永久获得。\n第二世代时，野生宝可梦使用该招式能够获得己方宝可梦的道具；第三世代后，野生宝可梦使用该招式只能造成伤害，不能获得道具。\n第八世代及以前，获得的道具会被招式使用者持有。\n第九世代后，同野生宝可梦的对战结束后，招式获得的道具会自动放入包包。若使用招式获得道具后逃走，获得的道具也会放入包包，再次进入对战后，野生宝可梦的状态会恢复到持有道具的状态。捕获野生宝可梦后，野生宝可梦持有的道具仍然持有，不会进入包包。\n这个招式不能被借助和挥指抽取到。\n这个招式不能被抢先一步和仿效使出。\n招式在极巨团体战中会使用失败，既无法获得道具，又无法造成伤害。\n招式在太晶团体战中能够成功使用并造成伤害，但无法获得道具。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "thousand-arrows": {
    description: "可以击中浮在空中的宝可梦。空中的对手被击落后，会掉到地面。"
  },
  "thousand-waves": {
    description: "从地面掀起波浪进行攻击。被掀入波浪中的对手，将无法从战斗中逃走。"
  },
  "thrash": {
    intro: "大闹一番（日文︰あばれる，英文︰Thrash）是第一世代引入的一般属性招式。",
    description: "在2～3回合内，乱打一气地攻击对手。大闹一番后自己会陷入混乱。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击随机一位对手造成伤害。\n使用者进入2～3回合大闹一番状态，期间会继续使用大闹一番进行攻击，无法使用其他招式、使用道具、替换宝可梦或逃走。\n因梦话而使用时，不进入大闹一番状态。\n因守住状态、未命中、属性相性无效等原因而没有产生效果，则解除大闹一番状态。\n大闹一番状态因回合经过解除时，使用者陷入混乱状态。\n神秘守护不会避免该招式带来的混乱。\n后续回合的攻击不消耗PP。",
    range: "随机一只对手"
  },
  "throat-chop": {
    description: "受到此招式攻击的对手，会因为地狱般的痛苦，在2回合内，变得无法使出声音类招式。"
  },
  "thunder": {
    intro: "打雷（日文︰かみなり，英文︰Thunder）是第一世代引入的电属性招式。",
    description: "向对手劈下暴雷进行攻击。有时会让对手陷入麻痹状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n打雷有30%的几率使目标陷入麻痹状态。\n在天气为大晴天或大日照状态下，打雷的命中降低至50。在天气为下雨或大雨状态下，打雷一定会命中，除非目标正在使用蓄力的招式并不在场地上。\n可以击中处于飞翔状态的宝可梦。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "thunder-cage": {
    description: "将对手困在电流四溅的囚笼中，在4～5回合内进行攻击。"
  },
  "thunder-fang": {
    description: "用蓄满电流的牙齿咬住对手。有时会使对手畏缩或陷入麻痹状态。"
  },
  "thunder-punch": {
    intro: "雷电拳（日文︰かみなりパンチ，英文︰Thunder Punch）是第一世代引入的电属性招式。",
    description: "用充满电流的拳头攻击对手。有时会让对手陷入麻痹状态。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n雷电拳有10%的几率使目标陷入麻痹状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "thunder-shock": {
    intro: "电击（日文︰でんきショック，英文︰Thunder Shock）是第一世代引入的电属性招式。",
    description: "发出电流刺激对手进行攻击。有时会让对手陷入麻痹状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n电击有10%的几率使目标陷入麻痹状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "thunder-wave": {
    intro: "电磁波（日文︰でんじは，英文︰Thunder Wave）是第一世代引入的电属性招式。",
    description: "向对手发出微弱的电击，从而让对手陷入麻痹状态。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "电磁波会使目标陷入麻痹状态。\n电磁波对于属性相性是0倍的目标无效。例如：\n电磁波（正常情况下）对地面属性宝可梦无效；\n电磁波（一般皮肤）对幽灵属性宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "thunderbolt": {
    intro: "十万伏特（日文︰10まんボルト，英文︰Thunderbolt）是第一世代引入的电属性招式。",
    description: "向对手发出强力电击进行攻击。有时会让对手陷入麻痹状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n十万伏特有10%的几率使目标陷入麻痹状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "thunderclap": {
    description: "可以比对手先使出电击进行攻击。对手使出的招式如果不是攻击招式则会失败。"
  },
  "tickle": {
    intro: "这篇文章讲述的是第三世代引入的变化招式。如果您在寻找早期动画中翻译为“挠痒”的物理招式，请移步抓（招式）。",
    description: "给对手挠痒，使其发笑，从而降低对手的攻击和防御。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令目标的攻击降低1级。\n令目标的防御降低1级。\n无视属性相性，可以命中幽灵属性宝可梦。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "tidy-up": {
    description: "将撒菱、隐形岩、黏黏网、毒菱、替身全部扫除掉。自己的攻击和速度会提高。"
  },
  "topsy-turvy": {
    description: "颠倒对手身上的所有能力变化，变成和原来相反的状态。"
  },
  "torch-song": {
    description: "如唱歌一样喷出熊熊燃烧的火焰烧焦对手。会提高自己的特攻。"
  },
  "torment": {
    intro: "无理取闹（日文︰いちゃもん，英文︰Torment）是第三世代引入的恶属性招式。",
    description: "向对手无理取闹，令其不能连续2次使出相同招式。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：无理取闹（状态）\n阻止对手连续使用相同的招式。当对手离开场地后该效果消失。\n如果对手被讲究头带、讲究围巾、讲究眼镜、定身法、再来一次或挑衅强制发动相同招式，或仅有上次使用的招式有PP，则对手会使用挣扎。如果自身没有继续使用无理取闹，目标在下回合可以使用其它招式。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "toxic": {
    intro: "剧毒（日文︰どくどく，英文︰Toxic）是第一世代引入的毒属性招式。",
    description: "让对手陷入剧毒状态。随着回合的推进，中毒伤害会增加。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "剧毒会使目标陷入剧毒状态。\n毒属性宝可梦使用这个招式必定命中，即使目标正在使用蓄力的招式并不在场地上。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "toxic-spikes": {
    description: "在对手的脚下撒毒菱。使对手替换出场的宝可梦中毒。"
  },
  "toxic-thread": {
    description: "将混有毒的丝吐向对手。使其中毒，从而降低对手的速度。"
  },
  "trailblaze": {
    description: "跳出草丛进行攻击。通过轻快的步伐会提高自己的速度。"
  },
  "transform": {
    intro: "变身（日文︰へんしん，英文︰Transform）是第一世代引入的一般属性招式。",
    description: "变身成对手宝可梦的样子，能够使用和对手完全相同的招式。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：变身（状态）\n使自身进入变身状态，复制目标的部分信息。复制的招式均只有5点PP。觉醒力量的属性和威力依照变身前的个体值计算。\n讲究头带、讲究围巾和讲究眼镜的效果依然有效，自身需要选择新的招式。\n该招式不能被鹦鹉学舌学习（第二世代起），也不能被再来一次强制发动。\n如果目标处于戏法防守、替身、变身或幻觉的保护下，招式使用失败。\n变身对具有黄金之躯特性的宝可梦无效。\n如果目标是太晶化的厄诡椪、太乐巴戈斯，或是自身已太晶化且目标是厄诡椪、太乐巴戈斯，招式使用失败。\n自身已太晶化且太晶属性为星晶时，招式使用失败。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "tri-attack": {
    intro: "三重攻击（日文︰トライアタック，英文︰Tri Attack）是第一世代引入的一般属性招式。",
    description: "用3种光线进行攻击。有时会让对手陷入麻痹、灼伤或冰冻的状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n三重攻击有20%的几率使目标陷入灼伤状态、麻痹状态或冰冻状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "trick": {
    intro: "戏法（日文︰トリック，英文︰Trick）是第三世代引入的超能力属性招式。",
    description: "抓住对手的空隙，交换自己和对手的持有物。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：拍落（状态）\n自身和目标交换携带物品，进入携带物品丢失或改变的状态。\n即使只有一方有携带物品，招式也能生效。如果双方都没有携带物品，则招式使用失败。\n如果其中一方携带以下物品，则招式使用失败：\n携带后无法进行连接交换的道具\n第三世代时，谜芝果、金南果、无青果、子茄果、青豌果、灯浆果、生花果、葱首果、葵秋果、苦凉果、热椒果、蒜蒜果或铃薯果\n第四世代时，白金宝珠\n邮件*\nＺ纯晶\n如果使用者发动携带的超能力Ｚ使出戏法Ｚ，则仅会发动Ｚ力量效果。\n超级石（如果其中一方可使用其进行超级进化）\n石板（如果其中一方为阿尔宙斯）\n卡带（如果其中一方为盖诺赛克特）\n存储碟（如果其中一方为银伴战兽）\n面具（如果其中一方为厄诡椪）\n朱红色宝珠（如果其中一方为固拉多）\n靛蓝色宝珠（如果其中一方为盖欧卡）\n大金刚宝玉（如果其中一方为帝牙卢卡）\n大白宝玉（如果其中一方为帕路奇亚）\n大白金宝玉（如果其中一方为骑拉帝纳）\n腐朽的剑（如果其中一方为苍响）\n腐朽的盾（如果其中一方为藏玛然特）\n驱劲能量（如果其中一方为以下宝可梦）\n雄伟牙、吼叫尾、猛恶菇、振翼发、爬地翅、沙铁皮、铁辙迹、铁包袱、铁臂膀、铁脖颈、铁毒蛾、铁荆棘、轰鸣月、铁武者、波荡水、铁斑叶\n如果其中一方具有黏着特性，或者目标具有替身状态，则招式使用失败。\n在训练家塔、训练家之丘、极巨团体战或太晶团体战中使用会失败。\n与野生宝可梦对战时：\n野生宝可梦使用该招式会失败。\n交换给野生宝可梦的道具，会在逃走或将它击败时返回包包。\n再次与同一只宝可梦对战时，该道具又会从包包中回到它的身上，同样会在逃走或将它击败时再次返回包包。\n从野生宝可梦处取得的道具会留在自己的宝可梦身上。\n与可获取经验值的训练家对战时：\n交换给对手的树果若被消耗，则对战结束后丢失。\n交换给对手的树果若未被消耗，则对战结束后回到原本持有者身上。\n交换给对手的其他道具无论是否被消耗，对战结束后均会回到原本持有者身上。\n从对手处取得的道具会消失。\n这个招式不能被借助和挥指抽到。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "trick-or-treat": {
    description: "邀请对手参加万圣夜。使对手被追加幽灵属性。"
  },
  "trick-room": {
    description: "制造出离奇的空间。在5回合内速度慢的宝可梦可以先行动。"
  },
  "triple-axel": {
    description: "连续3次踢对手进行攻击。每踢中一次，威力就会提高。"
  },
  "triple-dive": {
    description: "以默契的跳跃溅起水花击向对手。连续3次给予伤害。"
  },
  "triple-kick": {
    intro: "三连踢（日文︰トリプルキック，英文︰Triple Kick）是第二世代引入的格斗属性招式。",
    description: "连续3次踢对手进行攻击。每踢中一次，威力就会提高。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，一回合内连续攻击1～3次。第二次攻击有两倍威力，第三次攻击有三倍威力，每一次攻击是否命中分别计算，打空则停止攻击。次数、概率和期望威力如下表：\n\n连续攻击特性或携带机变骰子的宝可梦使用三连踢只计算一次命中率。\n每一击击中要害的概率都相等。\n如果某一下触发了目标的气势披带、气势头带、结实特性或打破了替身，招式会继续攻击。\n忍耐、金属爆炸和双倍奉还只计算最后一次的伤害。\n如果使用者持有王者之证或锐利之牙，或具有恶臭特性，每一下攻击都有相同的概率造成对手畏缩。如果使用者具有毒手特性，每一下攻击都有相同的概率造成对手中毒。\n如果目标拥有咒术之躯、碎裂铠甲或与接触类招式相关的特性或持有凸凸头盔，每一下攻击都会触发效果。即使特性发动令攻击方陷入一些可能无法行动的状态（如麻痹、畏缩、着迷、定身法状态），也不会影响本次攻击，但陷入睡眠和昏厥时攻击即刻停止。\n目标的木乃伊、游魂或甩不掉的气味特性会在第一下攻击之后就发动。使用方的顺手牵羊特性或目标的变色特性在最后一下攻击完成后才发动。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "trop-kick": {
    description: "向对手使出来自南国的火热脚踢。从而降低对手的攻击。"
  },
  "trump-card": {
    description: "王牌招式的剩余PP越少，招式的威力越大。"
  },
  "twin-beam": {
    description: "从两眼发射出神奇的光线攻击。连续2次给予伤害。"
  },
  "twineedle": {
    intro: "双针（日文︰ダブルニードル，英文︰Twineedle）是第一世代引入的虫属性招式。",
    description: "将2根针刺入对手，连续2次给予伤害。有时会让对手陷入中毒状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害，一回合内连续攻击2次。\n每一击击中要害的概率都相等。\n如果第一下触发了目标的气势披带、气势头带、结实特性或打破了替身，招式会继续攻击。\n忍耐、金属爆炸和双倍奉还只计算最后一次的伤害。\n如果使用者持有王者之证或锐利之牙，或具有恶臭特性，每一下攻击都有相同的概率造成对手畏缩。\n如果目标拥有咒术之躯、胆怯、碎裂铠甲特性，每一下攻击都会触发效果。即使特性发动令攻击方陷入一些可能无法行动的状态（如麻痹、畏缩、着迷、定身法状态），也不会影响本次攻击，但陷入睡眠和昏厥时攻击即刻停止。\n目标的变色特性在最后一下攻击完成后才发动。\n双针的每次攻击有20%的几率使目标陷入中毒状态。\n使目标陷入中毒状态的期望几率为1-（1-20%）2=36%。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "twister": {
    intro: "龙卷风（日文︰たつまき，英文︰Twister）是第二世代引入的龙属性招式。",
    description: "兴起龙卷风，将对手卷入进行攻击。有时会使对手畏缩。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n如果目标处于飞翔状态，威力翻倍。\n龙卷风有20%的几率使尚未行动的目标陷入畏缩状态。\n可以击中处于飞翔状态的宝可梦。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "u-turn": {
    description: "在攻击之后急速返回，和后备宝可梦进行替换。"
  },
  "upper-hand": {
    description: "察觉到对手的动作后用掌根攻击，让对手畏缩。如果对手使出的招式不是先制攻击，则会失败。"
  },
  "uproar": {
    intro: "吵闹（日文︰さわぐ，英文︰Uproar）是第三世代引入的一般属性招式。",
    description: "在3回合内大吵大闹攻击对手。在此期间谁都不能入眠。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "主页面：吵闹（状态）\n攻击随机一位对手造成伤害。\n使用者进入3回合吵闹状态，期间会继续使用吵闹进行攻击，无法使用其他招式、使用道具、替换宝可梦或逃走。\n吵闹不会被梦话发动。\n因守住状态、未命中、属性相性无效等原因而没有产生效果，则解除吵闹状态。\n后续回合的攻击不消耗PP。\n该招式无视目标的替身状态。\n吵闹状态的宝可梦在场时，所有宝可梦都不会陷入睡眠状态，已经陷入睡眠状态的宝可梦也会醒来。",
    range: "随机一只对手"
  },
  "v-create": {
    description: "从前额产生灼热的火焰，舍身撞击对手。防御、特防和速度会降低。"
  },
  "vacuum-wave": {
    description: "挥动拳头，掀起真空波。必定能够先制攻击。"
  },
  "venom-drench": {
    description: "将特殊的毒液泼向对手。对处于中毒状态的对手，其攻击、特攻和速度都会降低。"
  },
  "venoshock": {
    description: "将特殊的毒液泼向对手。对处于中毒状态的对手，威力会变成2倍。"
  },
  "vice-grip": {
    intro: "夹住（日文︰はさむ，英文︰Vise Grip）是第一世代引入的一般属性招式。",
    description: "将对手从两侧夹住，给予伤害。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "vine-whip": {
    intro: "藤鞭（日文︰つるのムチ，英文︰Vine Whip）是第一世代引入的草属性招式。",
    description: "用如同鞭子般弯曲而细长的藤蔓摔打对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "vital-throw": {
    intro: "借力摔（日文︰あてみなげ，英文︰Vital Throw）是第二世代引入的格斗属性招式。",
    description: "会在对手之后进行攻击。但是自己的攻击必定会命中。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n借力摔一定会命中，除非目标正在使用蓄力的招式并不在场地上。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "volt-switch": {
    description: "在攻击之后急速返回，和后备宝可梦进行替换。"
  },
  "volt-tackle": {
    intro: "伏特攻击（日文︰ボルテッカー，英文︰Volt Tackle）是第三世代引入的电属性招式。",
    description: "让电流覆盖全身猛撞向对手。自己也会受到不小的伤害。有时会让对手陷入麻痹状态。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。使用者承受对目标造成伤害的1⁄3的伤害。\n使用者具有坚硬脑袋或魔法防守特性时，不会承受伤害。\n使用者具有舍身特性时，该招式威力提升20%，因此承受的伤害也会提升。\n伏特攻击有10%的几率使目标陷入麻痹状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "wake-up-slap": {
    description: "给予睡眠状态下的对手较大的伤害。但相反对手会从睡眠中醒过来。"
  },
  "water-gun": {
    intro: "水枪（日文︰みずでっぽう，英文︰Water Gun）是第一世代引入的水属性招式。",
    description: "向对手猛烈地喷射水流进行攻击。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "water-pledge": {
    description: "用水柱进行攻击。如果和火组合，威力就会提高，天空中会挂上彩虹。"
  },
  "water-pulse": {
    description: "用水的震动攻击对手。有时会使对手混乱。"
  },
  "water-shuriken": {
    description: "用粘液制成的手里剑，连续攻击2～5次。必定能够先制攻击。"
  },
  "water-sport": {
    intro: "玩水（日文︰みずあそび，英文︰Water Sport）是第三世代引入的水属性招式。",
    description: "用水湿透周围。在5回合内减弱火属性的招式。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：玩水（状态）\n使场地进入玩水状态，降低火属性招式的威力。",
    range: "全部场地"
  },
  "water-spout": {
    intro: "这篇文章讲述的是威力随HP变化的水属性招式，不是威力固定的水流喷射。",
    description: "掀起潮水进行攻击。自己的HP越少，招式的威力越小。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。威力随自身剩余HP减少而减少。\n威力 = 150 × （当前HP / 全部HP）。",
    range: "全部可以攻击到的对手宝可梦"
  },
  "waterfall": {
    intro: "攀瀑（日文︰たきのぼり，英文︰Waterfall）是第一世代引入的水属性招式。",
    description: "以惊人的气势扑向对手。有时会使对手畏缩。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响", "可以在对战外使用"],
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "wave-crash": {
    description: "让水覆盖全身后撞向对手。自己也会受到不少伤害。"
  },
  "weather-ball": {
    intro: "气象球（日文︰ウェザーボール，英文︰Weather Ball）是第三世代引入的一般属性招式。",
    description: "根据使用时的天气，招式属性和威力会改变。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。如果有除了乱流外的天气，则该招式的属性为天气对应属性，且威力加倍。\n招式属性和威力变化：\n气象球在变为极巨招式时，虽然在菜单中仅显示为极巨攻击，但是实际使出时会根据当时的天气变化为对应属性的极巨招式或超极巨招式。\n对防弹特性的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "whirlpool": {
    intro: "潮旋（日文︰うずしお，英文︰Whirlpool）是第二世代引入的水属性招式。",
    description: "将对手困在激烈的水流旋涡中，在4～5回合内进行攻击。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响", "可以在对战外使用"],
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "whirlwind": {
    intro: "吹飞（日文︰ふきとばし，英文︰Whirlwind）是第一世代引入的一般属性招式。",
    description: "吹飞对手，强制拉后备宝可梦上场。如果对手为野生宝可梦，战斗将直接结束。",
    effect: ["不是接触类招式", "不受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "结束与野生宝可梦的对战，如果使用者的等级低于目标，招式使用失败。\n在训练家的对战中，令对方队伍中随机一只没有陷入昏厥状态的宝可梦强制替换上场。\n以下情况时，招式没有效果：\n目标特性为吸盘、看门犬、乘风或黄金之躯；\n目标处于扎根状态；\n对方队伍中没有可以替换上场的宝可梦；\n目标为极巨化的宝可梦。\n吹飞一定会命中，除非目标正在使用蓄力的招式并不在场地上。\n该招式无视目标的替身状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "wicked-blow": {
    description: "将恶之流派修炼至大成的猛烈一击。必定会击中要害。"
  },
  "wide-guard": {
    description: "在1回合内防住击打我方全员的攻击。"
  },
  "wild-charge": {
    description: "让电流覆盖全身，撞向对手进行攻击。自己也会受到少许伤害。"
  },
  "wildbolt-storm": {
    description: "呼唤雷云引起风暴，用雷与风进行激烈的攻击。有时会让对手陷入麻痹状态。"
  },
  "will-o-wisp": {
    intro: "磷火（日文︰おにび，英文︰Will-O-Wisp）是第三世代引入的火属性招式。",
    description: "放出怪异的火焰，从而让对手陷入灼伤状态。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "磷火会使目标陷入灼伤状态。\n对火属性宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "wing-attack": {
    intro: "翅膀攻击（日文︰つばさでうつ，英文︰Wing Attack）是第一世代引入的飞行属性招式。",
    description: "大大地展开美丽的翅膀，将其撞向对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响", "是远程招式"],
    additionalEffect: "攻击目标造成伤害。",
    range: "除自身以外场上一只宝可梦"
  },
  "wish": {
    intro: "这篇文章讲述的是回复HP的招式，不是幸运咒语。",
    description: "在下一回合回复自己或是替换出场的宝可梦最大HP的一半。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "陷入祈愿状态，使用祈愿后的下一回合，HP会回复。\n下回合结束时，恢复自身最大HP的1⁄2。\n如果自身交换下场或使用接棒、急速折返、伏特替换离场，则新上场的宝可梦会恢复HP，恢复量为招式使用者的最大HP×1⁄2。\n如果自身被吼叫、吹飞、龙尾、巴投强制下场，该效果仍会起作用。\n如果自身昏厥，该效果将不会起作用。",
    range: "自身"
  },
  "withdraw": {
    intro: "缩入壳中（日文︰からにこもる，英文︰Withdraw）是第一世代引入的水属性招式。",
    description: "缩入壳里保护身体，从而提高自己的防御。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令使用者的防御提升1级。",
    range: "自身"
  },
  "wonder-room": {
    description: "制造出离奇的空间。在5回合内互换所有宝可梦的防御和特防。"
  },
  "wood-hammer": {
    description: "用坚硬的躯体撞击对手进行攻击。自己也会受到不小的伤害。"
  },
  "work-up": {
    description: "激励自己，从而提高攻击和特攻。"
  },
  "worry-seed": {
    description: "种植心神不宁的种子。使对手不能入眠，并将特性变成不眠。"
  },
  "wrap": {
    intro: "紧束（日文︰まきつく，英文︰Wrap）是第一世代引入的一般属性招式。",
    description: "使用长长的身体或藤蔓等，在4～5回合内紧束对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "主页面：束缚（状态）\n攻击目标造成伤害。使目标陷入束缚状态。束缚状态持续4～5回合，处于束缚状态的宝可梦会持续受到伤害并不能换下。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "wring-out": {
    description: "用力勒紧对手进行攻击。对手的HP越多，威力越大。"
  },
  "x-scissor": {
    description: "将镰刀或爪子像剪刀般地交叉，顺势劈开对手。"
  },
  "yawn": {
    intro: "哈欠（日文︰あくび，英文︰Yawn）是第三世代引入的一般属性招式。",
    description: "打个大哈欠引起睡意。在下一回合让对手陷入睡眠状态。",
    effect: ["不是接触类招式", "受守住影响", "受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：瞌睡（状态）\n使目标陷入瞌睡状态。在被施放哈欠状态的接下来的1个回合结束时，处于哈欠状态的宝可梦解除哈欠状态并陷入睡眠状态。\n哈欠一定会命中，除非目标正在使用蓄力的招式并不在场地上。\n当目标处于异常状态，哈欠会使用失败。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "zap-cannon": {
    intro: "电磁炮（日文︰でんじほう，英文︰Zap Cannon）是第二世代引入的电属性招式。",
    description: "发射大炮一样的电流进行攻击。让对手陷入麻痹状态。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n电磁炮有100%的几率使目标陷入麻痹状态。\n对防弹特性的宝可梦无效。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "zen-headbutt": {
    description: "将思念的力量集中在前额进行攻击。有时会使对手畏缩。"
  },
  "zing-zap": {
    description: "撞向对手，并发出强电，使其感到麻麻刺刺的。有时会使对手畏缩。"
  },
  "forests-curse": {
    intro: "森林诅咒（日文︰もりののろい，英文︰Forest’s Curse）是第六世代引入的草属性招式。",
    description: "用森林的诅咒将对手的属性变为草属性。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：森林诅咒\n将目标宝可梦的属性变为纯草属性（覆盖其原本的属性）。\n如果目标处于替身状态或拥有变色等特性时，招式会失败。\n该变化在目标替换下场前一直持续。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
  "kings-shield": {
    intro: "王者盾牌（日文︰キングシールド，英文︰King’s Shield）是第六世代引入的钢属性招式。",
    description: "摆出王者的盾牌架势，完全抵挡对手的攻击。被接触类招式击中时，会降低对手的攻击。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "不可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "主页面：守住（状态）\n在当回合内使自身进入守住状态，保护自身不受到来自其他宝可梦的大部分招式影响。\n如果在本回合使用者最后行动，则招式会失败。\n若被接触类招式攻击，则令该招式的使用者攻击降低1级。\n若成功使用守住，则连续使用看穿、挺住、守住、王者盾牌、尖刺防守、碉堡、拦堵、极巨防壁、线阱、火焰守护或快速防守的成功率降低至上一次的1⁄3（最低至1⁄729）。\n该招式不会被借助或挥指发动。",
    range: "自身"
  },
  "lands-wrath": {
    intro: "大地神力（日文︰グランドフォース，英文︰Lands Wrath）是第六世代引入的地面属性招式。",
    description: "制造出巨大的裂痕攻击自己周围所有的宝可梦。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。\n可以击中处于挖洞状态的宝可梦。\n场地处于青草场地时威力下降50%。",
    range: "除自身以外场上全部可以攻击到的宝可梦"
  },
  "natures-madness": {
    intro: "自然之怒（日文︰しぜんのいかり，英文︰Nature’s Madness）是第七世代引入的妖精属性招式。",
    description: "唤起自然的怒火，将对手的HP减少到现在的一半。",
    effect: ["不是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "主页面：自然之怒\n将目标的HP减少到现在的一半（向下取整）。\n对替身状态的宝可梦无效。\n无视守住等防御状态。",
    range: "除自身以外场上一只可以攻击到的宝可梦"
  },
}
