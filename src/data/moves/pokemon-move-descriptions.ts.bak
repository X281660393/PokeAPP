  "swords-dance": {
    intro: "剑舞（日文︰つるぎのまい，英文︰Swords Dance）是第一世代引入的一般属性招式。",
    description: "激烈地跳起战舞提高气势。大幅提高自己的攻击。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "令使用者的攻击提升2级。",
    range: "自身"
  },
  "synchronoise": {
    description: "用神奇电波对周围所有和自己属性相同的宝可梦给予伤害。"
  },
  "synthesis": {
    intro: "光合作用（日文︰こうごうせい，英文︰Synthesis）是第二世代引入的草属性招式。",
    description: "回复自己的HP。根据天气的不同，回复量也会有所变化。",
    effect: ["不是接触类招式", "不受守住影响", "不受魔法反射影响", "可以被化为己用", "不受鹦鹉学舌影响", "不受王者之证等类似道具影响"],
    additionalEffect: "光合作用能够回复使用者HP。回复量由当前天气型状态决定。\n在大晴天和大日照状态下，回复使用者最大HP的2⁄3。\n在没有或其他天气型状态时，回复使用者最大HP的1⁄2。在下雨、大雨、沙暴、冰雹、下雪或起雾状态下，回复使用者最大HP的1⁄4。在使用者处于回复封锁状态时无法使用。",
    range: "自身"
  },
  "syrup-bomb": {
    description: "使粘稠的麦芽糖浆爆炸，让对手陷入满身糖状态，在3回合内持续降低其速度。"
  },
  "tachyon-cutter": {
    description: "接连发射出粒子的利刃，连续2次给予伤害。攻击必定会命中。"
  },
  "tackle": {
    intro: "撞击（日文︰たいあたり，英文︰Tackle）是第一世代引入的一般属性招式。",
    description: "用整个身体撞向对手进行攻击。",
    effect: ["是接触类招式", "受守住影响", "不受魔法反射影响", "不可以被化为己用", "受鹦鹉学舌影响", "受王者之证等类似道具影响"],
    additionalEffect: "攻击目标造成伤害。",
